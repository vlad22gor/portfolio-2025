---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import AgentationToolbar from '../components/dev/AgentationToolbar';
import InViewMotionRuntime from '../components/InViewMotionRuntime.astro';
import TemporaryAdaptiveNotice from '../components/TemporaryAdaptiveNotice.astro';

export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site ?? 'https://vladhorovyy.com').toString();
const isAgentationEnabled = import.meta.env.DEV && import.meta.env.PUBLIC_AGENTATION_ENABLED === 'true';
const agentationEndpoint =
  (typeof import.meta.env.PUBLIC_AGENTATION_ENDPOINT === 'string' &&
  import.meta.env.PUBLIC_AGENTATION_ENDPOINT.trim().length > 0
    ? import.meta.env.PUBLIC_AGENTATION_ENDPOINT
    : 'http://localhost:4747');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ClientRouter fallback="swap" />
    <slot name="head" />
    <link rel="preload" href="/fonts/DMSans-VariableFont_opsz,wght.ttf" as="font" type="font/ttf" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <div class="temporary-adaptive-shell">
      <TemporaryAdaptiveNotice />
    </div>
    <div class="site-desktop-shell">
      <slot />
      <InViewMotionRuntime />
      {
        isAgentationEnabled && (
          <div id="agentation-dev-root" transition:persist>
            <AgentationToolbar client:only="react" endpoint={agentationEndpoint} />
          </div>
        )
      }
    </div>
  </body>
</html>
