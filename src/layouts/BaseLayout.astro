---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import AgentationToolbar from '../components/dev/AgentationToolbar';
import InViewMotionRuntime from '../components/InViewMotionRuntime.astro';
import TemporaryAdaptiveNotice from '../components/TemporaryAdaptiveNotice.astro';
import CriticalMediaWarmupRuntime from '../components/CriticalMediaWarmupRuntime.astro';
import FloatingThemeButton from '../components/FloatingThemeButton.astro';
import { resolveCriticalRouteIdFromPath } from '../data/critical-media';

export interface Props {
  canonicalPath?: string;
}

const { canonicalPath = '/' } = Astro.props;
const siteTitle = 'Vlad Horovyy – Product Designer';
const siteDescription = 'Product designer from Kyiv crafting standout mobile apps';
const siteBaseUrl = Astro.site ?? 'https://vladhorovyy.com';
const canonical = new URL(canonicalPath, siteBaseUrl).toString();
const criticalRouteId = resolveCriticalRouteIdFromPath(canonicalPath);
const socialCoverPath = '/media/site/site-cover.png';
const socialCoverUrl = new URL(socialCoverPath, siteBaseUrl).toString();
const socialCoverWidth = 2400;
const socialCoverHeight = 1260;
const socialCoverAlt = 'Vlad Horovyy portfolio cover';
const isAgentationEnabled = import.meta.env.DEV && import.meta.env.PUBLIC_AGENTATION_ENABLED === 'true';
const agentationEndpoint =
  (typeof import.meta.env.PUBLIC_AGENTATION_ENDPOINT === 'string' &&
  import.meta.env.PUBLIC_AGENTATION_ENDPOINT.trim().length > 0
    ? import.meta.env.PUBLIC_AGENTATION_ENDPOINT
    : 'http://localhost:4747');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const runtimeKey = '__themeBootstrapRuntime';
        const themeKey = 'vh-theme';
        const normalizeTheme = (value) => (value === 'dark' ? 'dark' : 'light');
        const resolveTheme = () => {
          let storedTheme = null;
          try {
            storedTheme = window.localStorage.getItem(themeKey);
          } catch {
            storedTheme = null;
          }

          const prefersDark =
            typeof window.matchMedia === 'function' &&
            window.matchMedia('(prefers-color-scheme: dark)').matches;
          return storedTheme ? normalizeTheme(storedTheme) : prefersDark ? 'dark' : 'light';
        };

        const readCurrentTheme = () => {
          const htmlTheme = document.documentElement.dataset.theme;
          if (htmlTheme === 'dark' || htmlTheme === 'light') {
            return htmlTheme;
          }
          return resolveTheme();
        };

        const applyTheme = () => {
          document.documentElement.dataset.theme = resolveTheme();
        };

        const syncThemeBeforeSwap = (event) => {
          const nextDocument = event?.newDocument;
          const nextRoot = nextDocument?.documentElement;
          if (!nextRoot) {
            return;
          }
          nextRoot.setAttribute('data-theme', readCurrentTheme());
        };

        if (window[runtimeKey]) {
          window[runtimeKey].applyTheme();
          return;
        }

        applyTheme();
        document.addEventListener('astro:before-swap', syncThemeBeforeSwap);
        document.addEventListener('astro:page-load', applyTheme);
        window[runtimeKey] = { applyTheme, syncThemeBeforeSwap };
      })();
    </script>
    <script is:inline>
      (() => {
        const runtimeKey = '__themedRasterRuntime';
        const imageSelector = 'img[data-theme-src-light], img[data-theme-src-dark]';
        const normalizeTheme = (value) => (value === 'dark' ? 'dark' : 'light');
        const readTheme = () => normalizeTheme(document.documentElement.dataset.theme);

        const resolveImageSrc = (image, theme) => {
          const lightSrc = image.dataset.themeSrcLight?.trim();
          const darkSrc = image.dataset.themeSrcDark?.trim();

          if (theme === 'dark' && darkSrc) {
            return darkSrc;
          }

          return lightSrc || image.getAttribute('src') || darkSrc || '';
        };

        const syncAllThemedImages = () => {
          const theme = readTheme();
          const images = Array.from(document.querySelectorAll(imageSelector));
          images.forEach((node) => {
            if (!(node instanceof HTMLImageElement)) {
              return;
            }
            const targetSrc = resolveImageSrc(node, theme);
            if (!targetSrc || node.getAttribute('src') === targetSrc) {
              return;
            }
            node.setAttribute('src', targetSrc);
          });
        };

        if (window[runtimeKey]) {
          window[runtimeKey].mount();
          return;
        }

        const onThemeMutation = (mutations) => {
          const themeChanged = mutations.some(
            (record) => record.type === 'attributes' && record.attributeName === 'data-theme',
          );
          if (!themeChanged) {
            return;
          }
          syncAllThemedImages();
        };

        const themeObserver = new MutationObserver(onThemeMutation);
        themeObserver.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-theme'],
        });

        const mount = () => {
          syncAllThemedImages();
        };

        mount();
        document.addEventListener('astro:page-load', mount);
        window[runtimeKey] = { mount };
      })();
    </script>
    <script is:inline>
      document.documentElement.setAttribute('data-js', 'true');
    </script>
    <noscript>
      <style>
        .home-hero[data-home-hero-appear='pending'] .home-hero-line {
          opacity: 1 !important;
          transform: translate3d(0px, 0px, 0px) !important;
        }

        .home-hero[data-home-hero-appear='pending'] .home-hero-asset {
          opacity: 1 !important;
          transform: translate3d(0px, 0px, 0px) scale(1) !important;
        }

        .home-hero[data-home-hero-appear='pending'] .home-hero-asset--coin {
          transform: translate3d(0px, 0px, 0px) scale(1) rotate(0deg) !important;
        }
      </style>
    </noscript>
    <ClientRouter fallback="swap" />
    <slot name="head" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/DMSans-VariableFont_opsz,wght.ttf" as="font" type="font/ttf" crossorigin />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialCoverUrl} />
    <meta property="og:image:width" content={String(socialCoverWidth)} />
    <meta property="og:image:height" content={String(socialCoverHeight)} />
    <meta property="og:image:alt" content={socialCoverAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialCoverUrl} />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <div class="temporary-adaptive-shell">
      <TemporaryAdaptiveNotice />
    </div>
    <div class="site-desktop-shell">
      <slot />
      <FloatingThemeButton />
      <InViewMotionRuntime />
      <CriticalMediaWarmupRuntime routeId={criticalRouteId} />
      {
        isAgentationEnabled && (
          <div id="agentation-dev-root" transition:persist>
            <AgentationToolbar client:only="react" endpoint={agentationEndpoint} />
          </div>
        )
      }
    </div>
  </body>
</html>
