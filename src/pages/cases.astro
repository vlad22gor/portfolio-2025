---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CasesCardsSection from '../components/CasesCardsSection.astro';
import FinalCtaSection from '../components/FinalCtaSection.astro';
---

<BaseLayout
  canonicalPath="/cases"
>
  <SiteHeader />
  <main id="content" class="page-shell page-shell--cases" transition:name="page-content">
    <CasesCardsSection />
    <FinalCtaSection />
  </main>
  <SiteFooter />
</BaseLayout>
