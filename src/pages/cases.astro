---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CaseCard from '../components/CaseCard.astro';
import { CASES } from '../data/cases';
---

<BaseLayout
  title="Cases - Vlad Horovyy"
  description="Case studies about product redesign, UX clarity, and visual systems."
  canonicalPath="/cases"
>
  <SiteHeader />
  <main id="content" class="page-shell">
    <section class="section-stack">
      <h1>Case studies</h1>
      <p class="lead-copy">
        Reusable, typed case content lives in <code>src/data/cases.ts</code> and powers both cards and detailed pages.
      </p>
      <div class="case-grid">
        {CASES.map((item) => (
          <CaseCard item={item} />
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
