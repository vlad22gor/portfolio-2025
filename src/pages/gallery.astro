---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { GALLERY_ITEMS } from '../data/gallery';
---

<BaseLayout
  title="Gallery - Vlad Horovyy"
  description="Visual explorations in motion, 3D and interface direction."
  canonicalPath="/gallery"
>
  <SiteHeader />
  <main id="content" class="page-shell" transition:name="page-content">
    <section class="section-stack">
      <h1>Gallery</h1>
      <p class="lead-copy">Local media placeholders are used to avoid runtime dependency on Framer-hosted assets.</p>
      <div class="gallery-grid">
        {GALLERY_ITEMS.map((item) => (
          <article class="gallery-card scallop-surface">
            <img src={item.src} alt={item.alt} loading="lazy" />
            <h2>{item.title}</h2>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
