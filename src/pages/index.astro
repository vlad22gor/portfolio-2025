---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CaseCard from '../components/CaseCard.astro';
import QuantizedScallop from '../components/QuantizedScallop.astro';
import QuantizedPerimeter from '../components/QuantizedPerimeter.astro';
import QuantizedWave from '../components/QuantizedWave.astro';
import Button from '../components/Button.astro';
import { CASES } from '../data/cases';

const featured = CASES.slice(0, 2);
---

<BaseLayout
  title="Vlad Horovyy - Product Designer"
  description="Product designer from Kyiv crafting standout mobile app experiences."
  canonicalPath="/"
>
  <SiteHeader />
  <main id="content" class="page-shell" transition:name="page-content">
    <section class="hero scallop-surface">
      <p class="kicker">Product Designer · Kyiv</p>
      <h1>Design with care, ship with confidence.</h1>
      <p>
        I design digital products people enjoy returning to. This migration replaces a Framer runtime
        with a maintainable Astro codebase and Git-first workflow.
      </p>
      <div class="hero-actions">
        <Button href="/cases" variant="default">View cases</Button>
        <Button href="https://linktr.ee/vladhorovyy" target="_blank" variant="bordered-icon" iconSide="right">
          message me
        </Button>
      </div>
    </section>

    <section class="section-stack">
      <div class="section-head">
        <h2>Quantized shape catalog</h2>
      </div>
      <div class="scallop-preview-grid">
        <div class="scallop-preview-slot scallop-preview-slot-rect">
          <QuantizedScallop
            class="scallop-preview scallop-preview-rect"
            minCols={12}
            minRows={8}
            label="Scallop rectangle all edges"
          >
            <p class="kicker">Rectangle</p>
            <h2>Scallop · all edges</h2>
            <p>Legacy-compatible all-edge scallop via wrapper over the new perimeter engine.</p>
          </QuantizedScallop>
        </div>

        <div class="scallop-preview-slot scallop-preview-slot-rect">
          <QuantizedScallop
            class="scallop-preview scallop-preview-rect"
            rectangleEdges="top"
            minCols={12}
            minRows={8}
            label="Scallop rectangle top edge"
          >
            <p class="kicker">Rectangle</p>
            <h2>Scallop · top only</h2>
            <p>Top-only scallop for parity with footer behavior and current production usage.</p>
          </QuantizedScallop>
        </div>

        <div class="scallop-preview-slot scallop-preview-slot-rect">
          <QuantizedPerimeter
            class="scallop-preview scallop-preview-rect"
            edgePattern="totem"
            edges="all"
            minCols={12}
            minRows={8}
            waveAmplitudeRatio={0.28}
            waveTension={0.5}
            label="Totem perimeter all edges"
          >
            <p class="kicker">Totem</p>
            <h2>Perimeter · all edges</h2>
            <p>New cubic inset-wave profile rendered on all rectangle sides.</p>
          </QuantizedPerimeter>
        </div>

        <div class="scallop-preview-slot scallop-preview-slot-rect">
          <QuantizedPerimeter
            class="scallop-preview scallop-preview-rect"
            edgePattern="totem"
            edges="top"
            minCols={12}
            minRows={8}
            waveAmplitudeRatio={0.28}
            waveTension={0.5}
            label="Totem perimeter top edge"
          >
            <p class="kicker">Totem</p>
            <h2>Perimeter · top only</h2>
            <p>Same profile limited to top edge for selective decoration without side waves.</p>
          </QuantizedPerimeter>
        </div>

        <div class="scallop-preview-slot scallop-preview-slot-rect">
          <QuantizedPerimeter
            class="scallop-preview scallop-preview-rect scallop-preview-morph"
            edgePattern="totem"
            edges="all"
            minCols={12}
            minRows={8}
            hoverMorph
            morphSpringDuration={1.05}
            morphSpringBounce={0.24}
            waveAmplitudeRatio={0.28}
            waveTension={0.5}
            label="Totem param hover animation"
          >
            <p class="kicker">Param animation test</p>
            <h2>Totem param hover</h2>
            <p>Hover or focus this card to animate totem parameters with a spring transition.</p>
          </QuantizedPerimeter>
        </div>

        <div class="scallop-preview-slot scallop-preview-slot-circle">
          <QuantizedScallop
            class="scallop-preview scallop-preview-circle"
            shape="circle"
            minLobes={8}
            clampLines={3}
            label="Scallop circle preview"
          >
            <p class="kicker">Circle</p>
            <h2 class="scallop-clamp">Circular scallop test</h2>
            <p class="scallop-clamp">
              Circle size is primary. Content adapts inside with padding and line clamp when space is limited.
            </p>
          </QuantizedScallop>
        </div>
      </div>
    </section>

    <section class="content-grid">
      <article class="panel scallop-surface">
        <h2>What moved from Framer</h2>
        <ul>
          <li>Content architecture and route contract.</li>
          <li>Visual storytelling sections and case narratives.</li>
          <li>Mobile-first foundations instead of desktop-only fallback.</li>
        </ul>
      </article>
      <article class="panel scallop-surface">
        <h2>Current route map</h2>
        <ul>
          <li><code>/</code> - home narrative and featured work</li>
          <li><code>/cases</code> - all case studies</li>
          <li><code>/fora</code> and <code>/kissa</code> - detailed case pages</li>
          <li><code>/gallery</code> - visual playground</li>
        </ul>
      </article>
    </section>

    <section class="section-stack">
      <div class="section-head">
        <h2>Featured cases</h2>
        <a href="/cases">See all</a>
      </div>
      <QuantizedWave class="wave-divider" circleDiameter={8} strokeWidth={2} minCircles={4} phase="up" />
      <div class="case-grid">
        {featured.map((item) => (
          <CaseCard item={item} />
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
