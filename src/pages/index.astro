---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CasesCardsSection from '../components/CasesCardsSection.astro';
import AboutMeQScallopSection from '../components/AboutMeQScallopSection.astro';
import DesignToolsSection from '../components/DesignToolsSection.astro';
import QuotesSection from '../components/QuotesSection.astro';
import FinalCtaSection from '../components/FinalCtaSection.astro';
import Button from '../components/Button.astro';
import AdaptivePhoneArcSlider from '../components/AdaptivePhoneArcSlider.astro';

const isDev = import.meta.env.DEV;
const coinInlineStyle = [
  'left: calc(578px * var(--home-hero-scale));',
  'top: calc(-26px * var(--home-hero-scale));',
  'width: calc(265px * var(--home-hero-scale));',
  'height: calc(265px * var(--home-hero-scale));',
].join(' ');
---

<BaseLayout
  canonicalPath="/"
>
  <SiteHeader />
  <main id="content" class="page-shell page-shell--home" transition:name="page-content">
    <section class="home-hero" data-home-hero-appear="pending" aria-labelledby="home-hero-title">
      <div class="home-hero-media">
        <h1 id="home-hero-title" class="home-hero-title">
          <span class="home-hero-line home-hero-line--tertiary">i’m Vlad —</span>
          <span class="home-hero-line home-hero-line--offset-184">product</span>
          <span class="home-hero-line home-hero-line--end">designer</span>
          <span class="home-hero-line home-hero-line--offset-206">crafting</span>
          <span class="home-hero-line home-hero-line--tertiary">standout</span>
          <span class="home-hero-line">mobile apps.</span>
        </h1>

        <div class="home-hero-asset home-hero-asset--coin" style={coinInlineStyle} aria-hidden="true">
          <img src="/media/home/coin-wheel.webp" alt="" loading="eager" decoding="async" fetchpriority="high" />
        </div>

        <div class="home-hero-asset home-hero-asset--mockup-red" aria-hidden="true">
          <img
            src="/media/home/mockup-red.webp"
            data-theme-src-light="/media/home/mockup-red.webp"
            data-theme-src-dark="/media/home/mockup-clouds.webp"
            alt=""
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="home-hero-asset home-hero-asset--mockup-path" aria-hidden="true">
          <img
            src="/media/home/mockup-path.webp"
            data-theme-src-light="/media/home/mockup-path.webp"
            data-theme-src-dark="/media/home/mockup-evening.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="home-hero-asset home-hero-asset--cube" aria-hidden="true">
          <img src="/media/home/cube.webp" alt="" loading="lazy" decoding="async" />
        </div>

        <div class="home-hero-asset home-hero-asset--ternimal" aria-hidden="true">
          <img src="/media/home/ternimal.webp" alt="" loading="lazy" decoding="async" />
        </div>
      </div>

      <div class="home-hero-cta" data-home-hero-cta>
        <p class="home-hero-cta-text" data-home-hero-cta-stage="text">
          I make apps people love return to. Shaped by product vision, fresh ideas, and an enjoyable teamwork
        </p>
        <div data-home-hero-cta-stage="button">
          <Button href="https://linktr.ee/vladhorovyy" target="_blank" variant="default">message me</Button>
        </div>
      </div>
    </section>

    <section class="home-hero-mobile" aria-labelledby="home-hero-mobile-title" data-motion-inview="appear-stagger-v1">
      <AdaptivePhoneArcSlider
        class="home-hero-mobile-screens"
        viewportClass="home-hero-mobile-screens-viewport"
        mediaMode="poster-only"
        stageItem={true}
        motionStaggerIndex={0}
      />

      <div class="home-hero-mobile-text">
        <h1 id="home-hero-mobile-title" class="home-hero-mobile-title" data-motion-stage-item data-motion-stagger-index="1">
          <span class="home-hero-mobile-title--tertiary">i’m Vlad —</span>
          <span> product designer </span>
          <span class="home-hero-mobile-title--tertiary">crafting standout</span>
          <span> mobile apps</span>
        </h1>
        <p class="home-hero-mobile-subtitle" data-motion-stage-item data-motion-stagger-index="2">
          I make apps people love return to. Shaped by product vision, fresh ideas, and an enjoyable teamwork
        </p>
        <div data-motion-stage-item data-motion-stagger-index="3">
          <Button href="https://linktr.ee/vladhorovyy" target="_blank" variant="default">message me</Button>
        </div>
      </div>
    </section>

    <CasesCardsSection />
    <DesignToolsSection />
    <AboutMeQScallopSection />
    <QuotesSection />
    <FinalCtaSection />
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  import { animate } from 'motion';

  (() => {
    const runtimeKey = '__homeHeroAppearRuntime';
    const HERO_APPEAR_PENDING = 'pending';
    const HERO_APPEAR_RUNNING = 'running';
    const HERO_APPEAR_DONE = 'done';
    if (window[runtimeKey]) {
      window[runtimeKey].mount();
      return;
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const labelSpring = { type: 'spring', duration: 0.4, bounce: 0.2 };
    const assetSpring = { type: 'spring', duration: 0.4, bounce: 0.2 };
    const coinSpring = { type: 'spring', duration: 1.2, bounce: 0.2 };
    const ctaInViewPreset = 'appear-v1';
    const ctaStageDelay = 0.1;
    const assetDelayByModifier = {
      'home-hero-asset--mockup-red': 0.05,
      'home-hero-asset--cube': 0.1,
      'home-hero-asset--ternimal': 0.2,
      'home-hero-asset--mockup-path': 0.3,
    };

    const setLabelFinal = (line) => {
      line.style.opacity = '1';
      line.style.transform = 'translate3d(0px, 0px, 0px)';
    };

    const setLabelInitial = (line) => {
      line.style.opacity = '0';
      line.style.transform = 'translate3d(0px, 25px, 0px)';
    };

    const setAssetFinal = (asset, isCoin) => {
      asset.style.opacity = '1';
      asset.style.transform = isCoin
        ? 'translate3d(0px, 0px, 0px) scale(1) rotate(360deg)'
        : 'translate3d(0px, 0px, 0px) scale(1)';
    };

    const setAssetInitial = (asset, isCoin) => {
      asset.style.opacity = '0';
      asset.style.transform = isCoin
        ? 'translate3d(0px, 25px, 0px) scale(0.5) rotate(0deg)'
        : 'translate3d(0px, 25px, 0px) scale(0.5)';
    };

    const setHeroState = (hero, state) => {
      hero.dataset.homeHeroAppear = state;
    };

    const resolveHeroCta = (hero) => {
      const cta = hero.querySelector('[data-home-hero-cta]');
      if (!(cta instanceof HTMLElement)) {
        return { cta: null, stageNodes: [] };
      }
      const stageNodes = Array.from(cta.querySelectorAll('[data-home-hero-cta-stage]')).filter(
        (node) => node instanceof HTMLElement,
      );
      return { cta, stageNodes };
    };

    const setCtaStageInitial = (node) => {
      node.style.opacity = '0';
      node.style.transform = 'translate3d(0px, 25px, 0px)';
    };

    const setCtaStageFinal = (node) => {
      node.style.opacity = '1';
      node.style.transform = 'translate3d(0px, 0px, 0px)';
    };

    const clearCtaStageStyles = (nodes) => {
      nodes.forEach((node) => {
        node.style.opacity = '';
        node.style.transform = '';
      });
    };

    const clearCtaInViewState = (cta) => {
      cta.removeAttribute('data-motion-inview');
      cta.removeAttribute('data-motion-inview-bound');
      cta.removeAttribute('data-motion-inview-animated');
    };

    const requestInViewRuntimeMount = () => {
      const runtime = window.__inViewAppearRuntime;
      if (runtime && typeof runtime.mount === 'function') {
        runtime.mount();
        return;
      }
      window.requestAnimationFrame(() => {
        const deferredRuntime = window.__inViewAppearRuntime;
        if (deferredRuntime && typeof deferredRuntime.mount === 'function') {
          deferredRuntime.mount();
        }
      });
    };

    const isElementInViewport = (element) => {
      const rect = element.getBoundingClientRect();
      const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
      return rect.bottom > 0 && rect.right > 0 && rect.left < viewportWidth && rect.top < viewportHeight;
    };

    const resolveHeroCtaMode = (hero) => {
      const { cta, stageNodes } = resolveHeroCta(hero);
      if (!(cta instanceof HTMLElement)) {
        return { mode: 'none', cta: null, stageNodes };
      }

      if (cta.dataset.homeHeroCtaRuntimeGuard === 'true') {
        return { mode: cta.dataset.homeHeroCtaMode ?? 'none', cta, stageNodes };
      }

      cta.dataset.homeHeroCtaRuntimeGuard = 'true';
      const shouldUseHeroLocalStagger = isElementInViewport(cta);

      if (shouldUseHeroLocalStagger) {
        clearCtaInViewState(cta);
        cta.dataset.homeHeroCtaMode = 'hero-local-stagger';
        return { mode: 'hero-local-stagger', cta, stageNodes };
      }

      clearCtaStageStyles(stageNodes);
      cta.setAttribute('data-motion-inview', ctaInViewPreset);
      cta.dataset.homeHeroCtaMode = 'inview';
      requestInViewRuntimeMount();
      return { mode: 'inview', cta, stageNodes };
    };

    const animateHeroCtaAsContinuation = (hero, baseIndex) => {
      const { cta, stageNodes } = resolveHeroCta(hero);
      if (!(cta instanceof HTMLElement) || stageNodes.length === 0) {
        return [];
      }
      if (cta.dataset.homeHeroCtaAnimated === 'true') {
        return [];
      }
      cta.dataset.homeHeroCtaAnimated = 'true';
      clearCtaInViewState(cta);

      const controls = [];
      stageNodes.forEach((node, stageIndex) => {
        setCtaStageInitial(node);
        const control = animate(
          node,
          {
            opacity: [0, 1],
            transform: ['translate3d(0px, 25px, 0px)', 'translate3d(0px, 0px, 0px)'],
          },
          { ...labelSpring, delay: (baseIndex + stageIndex) * ctaStageDelay },
        );
        controls.push(control);
      });
      return controls;
    };

    const setHeroCtaFinal = (hero) => {
      const { cta, stageNodes } = resolveHeroCta(hero);
      if (!(cta instanceof HTMLElement)) {
        return;
      }
      cta.dataset.homeHeroCtaRuntimeGuard = 'true';
      cta.dataset.homeHeroCtaMode = cta.dataset.homeHeroCtaMode ?? 'reduced';
      cta.dataset.homeHeroCtaAnimated = 'true';
      clearCtaInViewState(cta);
      stageNodes.forEach((node) => {
        setCtaStageFinal(node);
      });
    };

    const animateLabels = (hero) => {
      const labels = Array.from(hero.querySelectorAll('.home-hero-line'));
      const controls = [];
      labels.forEach((line, index) => {
        if (!(line instanceof HTMLElement)) {
          return;
        }
        setLabelInitial(line);
        const control = animate(
          line,
          {
            opacity: [0, 1],
            transform: ['translate3d(0px, 25px, 0px)', 'translate3d(0px, 0px, 0px)'],
          },
          { ...labelSpring, delay: index * 0.1 },
        );
        controls.push(control);
      });
      return controls;
    };

    const resolveAssetDelay = (asset) => {
      for (const [className, delay] of Object.entries(assetDelayByModifier)) {
        if (asset.classList.contains(className)) {
          return delay;
        }
      }
      return 0;
    };

    const animateAssets = (hero) => {
      const assets = Array.from(hero.querySelectorAll('.home-hero-asset'));
      const controls = [];
      assets.forEach((asset) => {
        if (!(asset instanceof HTMLElement)) {
          return;
        }

        const isCoin = asset.classList.contains('home-hero-asset--coin');
        const delay = isCoin ? 0 : resolveAssetDelay(asset);
        setAssetInitial(asset, isCoin);

        if (isCoin) {
          const control = animate(
            asset,
            {
              opacity: [0, 1],
              transform: [
                'translate3d(0px, 25px, 0px) scale(0.5) rotate(0deg)',
                'translate3d(0px, 0px, 0px) scale(1) rotate(360deg)',
              ],
            },
            { ...coinSpring, delay },
          );
          controls.push(control);
          return;
        }

        const control = animate(
          asset,
          {
            opacity: [0, 1],
            transform: ['translate3d(0px, 25px, 0px) scale(0.5)', 'translate3d(0px, 0px, 0px) scale(1)'],
          },
          { ...assetSpring, delay },
        );
        controls.push(control);
      });
      return controls;
    };

    const markDoneWhenAnimationsFinish = (hero, controls) => {
      if (!controls.length) {
        setHeroState(hero, HERO_APPEAR_DONE);
        return;
      }

      Promise.allSettled(
        controls.map((control) =>
          control && control.finished && typeof control.finished.then === 'function'
            ? control.finished
            : Promise.resolve(),
        ),
      ).finally(() => {
        if (!hero.isConnected || hero.dataset.homeHeroAppearMounted !== 'true') {
          return;
        }
        setHeroState(hero, HERO_APPEAR_DONE);
      });
    };

    const mountHero = (hero) => {
      if (!(hero instanceof HTMLElement)) {
        return;
      }
      if (hero.dataset.homeHeroAppearMounted === 'true') {
        return;
      }
      hero.dataset.homeHeroAppearMounted = 'true';

      if (hero.dataset.homeHeroAppear !== HERO_APPEAR_PENDING) {
        setHeroState(hero, HERO_APPEAR_PENDING);
      }

      if (prefersReducedMotion.matches) {
        setHeroState(hero, HERO_APPEAR_RUNNING);
        hero.querySelectorAll('.home-hero-line').forEach((line) => {
          if (line instanceof HTMLElement) {
            setLabelFinal(line);
          }
        });
        hero.querySelectorAll('.home-hero-asset').forEach((asset) => {
          if (asset instanceof HTMLElement) {
            const isCoin = asset.classList.contains('home-hero-asset--coin');
            setAssetFinal(asset, isCoin);
          }
        });
        setHeroCtaFinal(hero);
        setHeroState(hero, HERO_APPEAR_DONE);
        return;
      }

      const labelControls = animateLabels(hero);
      const ctaMode = resolveHeroCtaMode(hero);
      const ctaControls =
        ctaMode.mode === 'hero-local-stagger'
          ? animateHeroCtaAsContinuation(hero, hero.querySelectorAll('.home-hero-line').length)
          : [];
      const controls = [...labelControls, ...animateAssets(hero), ...ctaControls];
      setHeroState(hero, HERO_APPEAR_RUNNING);
      markDoneWhenAnimationsFinish(hero, controls);
    };

    const mount = () => {
      document.querySelectorAll('.home-hero').forEach((hero) => {
        mountHero(hero);
      });
    };

    mount();
    document.addEventListener('astro:page-load', mount);
    window[runtimeKey] = { mount };
  })();
</script>

{
  isDev && (
    <script is:inline>
      {`
        (() => {
          const runtimeKey = '__homeHeroCoinGuard';
          const expectedLeft = 578;
          const expectedTop = -26;
          const epsilon = 0.75;

          const check = () => {
            const media = document.querySelector('.home-hero-media');
            const coin = document.querySelector('.home-hero-asset--coin');
            if (!media || !coin) {
              return;
            }

            const mediaRect = media.getBoundingClientRect();
            const coinRect = coin.getBoundingClientRect();
            const left = coinRect.left - mediaRect.left;
            const top = coinRect.top - mediaRect.top;

            if (Math.abs(left - expectedLeft) > epsilon || Math.abs(top - expectedTop) > epsilon) {
              console.warn('[home-hero] coin offset mismatch', {
                left,
                top,
                expectedLeft,
                expectedTop,
                href: window.location.pathname,
              });
            }
          };

          if (window[runtimeKey]) {
            window[runtimeKey].check();
            return;
          }

          window[runtimeKey] = { check };
          check();
          document.addEventListener('astro:page-load', check);
          window.addEventListener('resize', check);
        })();
      `}
    </script>
  )
}
