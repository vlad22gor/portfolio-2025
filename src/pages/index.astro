---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CaseCard from '../components/CaseCard.astro';
import QuantizedWave from '../components/QuantizedWave.astro';
import Button from '../components/Button.astro';
import { CASES } from '../data/cases';

const featured = CASES.slice(0, 2);
---

<BaseLayout
  title="Vlad Horovyy - Product Designer"
  description="Product designer from Kyiv crafting standout mobile app experiences."
  canonicalPath="/"
>
  <SiteHeader />
  <main id="content" class="page-shell" transition:name="page-content">
    <section class="hero scallop-surface">
      <p class="kicker">Product Designer · Kyiv</p>
      <h1>Design with care, ship with confidence.</h1>
      <p>
        I design digital products people enjoy returning to. This migration replaces a Framer runtime
        with a maintainable Astro codebase and Git-first workflow.
      </p>
      <div class="hero-actions">
        <Button href="/cases" variant="default">View cases</Button>
        <Button href="https://linktr.ee/vladhorovyy" target="_blank" variant="bordered-icon" iconSide="right">
          message me
        </Button>
      </div>
    </section>

    <section class="section-stack">
      <div class="section-head">
        <h2>Featured cases</h2>
        <a href="/cases">See all</a>
      </div>
      <QuantizedWave class="wave-divider" circleDiameter={8} strokeWidth={2} minCircles={4} phase="up" />
      <div class="case-grid">
        {featured.map((item) => (
          <CaseCard item={item} />
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
