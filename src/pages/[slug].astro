---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CaseSwitcherSection from '../components/CaseSwitcherSection.astro';
import CaseDetailSections from '../components/case-details/CaseDetailSections.astro';
import { CASES, getCaseBySlug } from '../data/cases';
import { getCaseDetailConfig } from '../data/case-details';
import { getCriticalMediaForRoute } from '../data/critical-media';

export function getStaticPaths() {
  return CASES.map((item) => ({ params: { slug: item.slug } }));
}

const slug = Astro.params.slug ?? '';
const current = getCaseBySlug(slug);

if (!current) {
  return Astro.redirect('/cases');
}

const index = CASES.findIndex((item) => item.slug === current.slug);
const prev = CASES[(index - 1 + CASES.length) % CASES.length];
const next = CASES[(index + 1) % CASES.length];
const detailConfig = getCaseDetailConfig(current.slug);
const criticalMediaPreloads = getCriticalMediaForRoute(current.slug);
---

<BaseLayout canonicalPath={`/${current.slug}`}>
  {
    criticalMediaPreloads.length > 0 && (
      <Fragment slot="head">
        {criticalMediaPreloads.map((asset) => (
          <link
            rel="preload"
            as={asset.kind === 'video' ? 'video' : 'image'}
            href={asset.href}
            fetchpriority={asset.kind === 'video' ? undefined : 'high'}
          />
        ))}
      </Fragment>
    )
  }
  <SiteHeader />
  <main
    id="content"
    class:list={['page-shell', ...(detailConfig?.pageShellClasses ?? [])]}
    transition:name="page-content"
  >
    {
      detailConfig ? (
        <CaseDetailSections config={detailConfig} currentCase={current} prevCase={prev} nextCase={next} />
      ) : (
        <>
          <section class="section-stack">
            <p class="kicker">Case Study</p>
            <h1>{current.title}</h1>
            <p class="lead-copy">{current.subtitle}</p>
            <img
              class="hero-media"
              src={current.media[0]?.src}
              alt={current.media[0]?.alt ?? current.title}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </section>

          <section class="metrics-grid" aria-label="Case metrics">
            {current.metrics.map((metric) => (
              <article>
                <p>{metric.label}</p>
                <strong>{metric.value}</strong>
              </article>
            ))}
          </section>

          <section class="section-stack prose-like">
            <p>{current.summary}</p>
            {current.sections.map((section) => (
              <article>
                <h2>{section.title}</h2>
                {section.body.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </article>
            ))}
          </section>

          <nav class="case-pager" aria-label="Case navigation">
            <a href={`/${prev.slug}`}>Prev case: {prev.slug}</a>
            <a href="/cases">All cases</a>
            <a href={`/${next.slug}`}>Next case: {next.slug}</a>
          </nav>

          <CaseSwitcherSection currentCase={current} prevCase={prev} nextCase={next} inViewPreset="appear-v1" />
        </>
      )
    }
  </main>
  <SiteFooter />
</BaseLayout>
