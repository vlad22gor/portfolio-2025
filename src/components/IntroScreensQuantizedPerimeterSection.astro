---
import QuantizedPerimeter from './QuantizedPerimeter.astro';
import DeviceMockup from './DeviceMockup.astro';
import foraIntroDeliverySrc from '../../assets/images/fora/fora-intro-delivery.png';
import foraIntroCategorySrc from '../../assets/images/fora/fora-intro-category.png';
import foraIntroMapSrc from '../../assets/images/fora/fora-intro-map.png';
import kissaTerminalSrc from '../../assets/images/kissa/kissa-terminal.png';
import kissaWelcomeSrc from '../../assets/images/kissa/kissa-welcome.png';
import kissaTraySrc from '../../assets/images/kissa/kissa-tray.png';

type IntroScreensVariant = 'phone' | 'tablet';

interface Props {
  variant?: IntroScreensVariant;
  inViewPreset?: 'appear-v1';
  class?: string;
}

const {
  variant = 'phone',
  inViewPreset = 'appear-v1',
  class: className = '',
} = Astro.props;

const resolvedVariant: IntroScreensVariant = variant === 'tablet' ? 'tablet' : 'phone';
---

<QuantizedPerimeter
  class:list={[
    'fora-intro-screens-section',
    `fora-intro-screens-section--${resolvedVariant}`,
    className,
  ]}
  inViewPreset={inViewPreset}
  shape="rectangle"
  edgePattern="scallop"
  step={48}
  bg="var(--color-bg-darkened)"
  pad="0"
  label={`Fora intro screens (${resolvedVariant})`}
>
  {
    resolvedVariant === 'phone' ? (
      <div class="fora-intro-screens-track fora-intro-screens-track--phone" aria-hidden="true">
        <div class="fora-intro-screens-phone-item fora-intro-screens-phone-item--left">
          <DeviceMockup
            class="fora-intro-screens-device"
            device="phone"
            screenKind="image"
            screenSrc={foraIntroDeliverySrc.src}
            screenAlt=""
          />
        </div>

        <div class="fora-intro-screens-phone-item fora-intro-screens-phone-item--center">
          <DeviceMockup
            class="fora-intro-screens-device"
            device="phone"
            screenKind="image"
            screenSrc={foraIntroCategorySrc.src}
            screenAlt=""
          />
        </div>

        <div class="fora-intro-screens-phone-item fora-intro-screens-phone-item--right">
          <DeviceMockup
            class="fora-intro-screens-device"
            device="phone"
            screenKind="image"
            screenSrc={foraIntroMapSrc.src}
            screenAlt=""
          />
        </div>
      </div>
    ) : (
      <div class="fora-intro-screens-track fora-intro-screens-track--tablet" aria-hidden="true">
        <div class="fora-intro-screens-tablet-item fora-intro-screens-tablet-item--left">
          <DeviceMockup
            class="fora-intro-screens-device"
            device="tablet"
            screenKind="image"
            screenSrc={kissaTerminalSrc.src}
            screenAlt=""
          />
        </div>

        <div class="fora-intro-screens-tablet-item fora-intro-screens-tablet-item--center">
          <DeviceMockup
            class="fora-intro-screens-device"
            device="tablet"
            screenKind="image"
            screenSrc={kissaWelcomeSrc.src}
            screenAlt=""
          />
        </div>

        <div class="fora-intro-screens-tablet-item fora-intro-screens-tablet-item--right">
          <DeviceMockup
            class="fora-intro-screens-device"
            device="tablet"
            screenKind="image"
            screenSrc={kissaTraySrc.src}
            screenAlt=""
          />
        </div>
      </div>
    )
  }
</QuantizedPerimeter>
