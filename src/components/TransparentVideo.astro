---
interface Props {
  class?: string;
  webmSrc: string;
  movSrc?: string;
  poster?: string;
  preload?: 'none' | 'metadata' | 'auto';
  autoplay?: boolean;
  muted?: boolean;
  loop?: boolean;
  playsinline?: boolean;
  ariaHidden?: 'true' | 'false';
  tabindex?: number | string;
}

const {
  class: className = '',
  webmSrc,
  movSrc,
  poster,
  preload = 'metadata',
  autoplay = true,
  muted = true,
  loop = true,
  playsinline = true,
  ariaHidden = 'true',
  tabindex,
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const resolvedTabIndex =
  typeof tabindex === 'string' || typeof tabindex === 'number' ? tabindex : undefined;
---

<video
  {...rest}
  class={className}
  src={webmSrc}
  autoplay={autoplay}
  muted={muted}
  loop={loop}
  playsinline={playsinline}
  preload={preload}
  poster={poster}
  aria-hidden={ariaHidden}
  tabindex={resolvedTabIndex}
  data-transparent-video="true"
  data-transparent-video-webm={webmSrc}
  data-transparent-video-hevc={movSrc ?? ''}
  data-transparent-video-codec="pending"
/>

<script is:inline>
  (() => {
    const supportPromiseKey = '__transparentVideoHevcAlphaSupportPromise';
    const runtimeKey = '__transparentVideoRuntime';
    const managedVideoPlaybackRuntimeKey = '__managedVideoPlaybackRuntime';
    const iOSUserAgentPattern = /(iPad|iPhone|iPod)/i;
    const isIOSWebKit = (() => {
      const ua = typeof navigator.userAgent === 'string' ? navigator.userAgent : '';
      const platform = typeof navigator.platform === 'string' ? navigator.platform : '';
      const maxTouchPoints = Number.isFinite(navigator.maxTouchPoints) ? navigator.maxTouchPoints : 0;
      const isIOSDevice = iOSUserAgentPattern.test(ua) || (platform === 'MacIntel' && maxTouchPoints > 1);
      return isIOSDevice && /AppleWebKit/i.test(ua);
    })();

    const decodeConfigCandidates = [
      'video/quicktime; codecs="hvc1.1.6.L93.B0"',
      'video/quicktime; codecs="hvc1"',
    ];

    const detectHevcAlphaSupport = async () => {
      const mediaCapabilities = navigator.mediaCapabilities;
      if (!mediaCapabilities || typeof mediaCapabilities.decodingInfo !== 'function') {
        return false;
      }

      for (const contentType of decodeConfigCandidates) {
        try {
          const result = await mediaCapabilities.decodingInfo({
            type: 'file',
            video: {
              contentType,
              width: 720,
              height: 720,
              bitrate: 1_500_000,
              framerate: 30,
              hasAlphaChannel: true,
            },
          });
          if (result?.supported) {
            return true;
          }
        } catch {
          // Ignore unsupported/invalid media capability queries and continue fallback chain.
        }
      }

      return false;
    };

    const getHevcAlphaSupport = () => {
      if (window[supportPromiseKey] instanceof Promise) {
        return window[supportPromiseKey];
      }

      const supportPromise = detectHevcAlphaSupport().catch(() => false);
      window[supportPromiseKey] = supportPromise;
      return supportPromise;
    };

    const shouldDeferInviewAutoplay = (video) =>
      isIOSWebKit && (video.dataset.videoPlayback ?? '') === 'inview';
    const isVideoInViewport = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return false;
      }
      const rect = video.getBoundingClientRect();
      return rect.bottom > 0 && rect.top < window.innerHeight && rect.right > 0 && rect.left < window.innerWidth;
    };
    const resetMockupFrameReady = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      const mockup = video.closest('.device-mockup[data-device-mockup]');
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if ((mockup.dataset.deviceMediaKind ?? '') !== 'video') {
        return;
      }
      mockup.setAttribute('data-video-frame-ready', 'false');
    };

    const applyVideoSource = (video, shouldUseHevc) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }

      const webmSrc = video.dataset.transparentVideoWebm ?? '';
      const hevcSrc = video.dataset.transparentVideoHevc ?? '';
      const selectedSrc = shouldUseHevc && hevcSrc ? hevcSrc : webmSrc;
      const selectedCodec = shouldUseHevc && hevcSrc ? 'hevc-alpha' : 'webm-vp9';

      if (!selectedSrc) {
        return;
      }

      const managedRuntime = window[managedVideoPlaybackRuntimeKey];
      const shouldDeferAutoplay = shouldDeferInviewAutoplay(video);
      const isSourceChanged = video.dataset.transparentVideoActiveSrc !== selectedSrc;

      if (isSourceChanged) {
        video.setAttribute('src', selectedSrc);
        video.dataset.transparentVideoActiveSrc = selectedSrc;
        if (shouldDeferAutoplay) {
          video.preload = 'none';
          video.setAttribute('preload', 'none');
          resetMockupFrameReady(video);
          const resetViaRuntime =
            managedRuntime &&
            typeof managedRuntime.resetVideo === 'function' &&
            managedRuntime.resetVideo(video) === true;
          if (isVideoInViewport(video)) {
            video.preload = 'auto';
            video.setAttribute('preload', 'auto');
            if (!resetViaRuntime) {
              try {
                video.load();
              } catch {
                // Ignore manual warmup load failures and let runtime retry on next sync.
              }
            }
          }
          if (managedRuntime && typeof managedRuntime.sync === 'function') {
            managedRuntime.sync();
          }
        } else {
          video.load();
        }
      }

      video.dataset.transparentVideoCodec = selectedCodec;
      video.muted = true;

      if (video.autoplay && !shouldDeferAutoplay) {
        const playPromise = video.play();
        if (playPromise && typeof playPromise.catch === 'function') {
          playPromise.catch(() => {});
        }
      }
    };

    const refreshTransparentVideos = async () => {
      const videos = Array.from(document.querySelectorAll('video[data-transparent-video="true"]')).filter(
        (node) => node instanceof HTMLVideoElement,
      );
      if (videos.length === 0) {
        const managedRuntime = window[managedVideoPlaybackRuntimeKey];
        if (managedRuntime && typeof managedRuntime.mount === 'function') {
          managedRuntime.mount();
        }
        return;
      }

      const supportsHevcAlpha = await getHevcAlphaSupport();
      videos.forEach((video) => applyVideoSource(video, supportsHevcAlpha));
      const managedRuntime = window[managedVideoPlaybackRuntimeKey];
      if (managedRuntime && typeof managedRuntime.mount === 'function') {
        managedRuntime.mount();
      }
      if (managedRuntime && typeof managedRuntime.sync === 'function') {
        managedRuntime.sync();
      }
    };

    if (window[runtimeKey]) {
      window[runtimeKey].refresh();
      return;
    }

    window[runtimeKey] = { refresh: refreshTransparentVideos };
    refreshTransparentVideos();
    document.addEventListener('astro:page-load', refreshTransparentVideos);
  })();
</script>
