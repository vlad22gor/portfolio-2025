---
import QuantizedPerimeter from './QuantizedPerimeter.astro';
import ThemedSvgIcon from './ThemedSvgIcon.astro';
import type { InViewPreset } from '../data/case-details/types';

interface Props {
  class?: string;
  inViewPreset?: InViewPreset;
  photoSrc?: string;
  photoAlt?: string;
  caption?: string;
  heartLeftSrc?: string;
  heartRightSrc?: string;
}

const {
  class: className = '',
  inViewPreset = 'appear-v1',
  photoSrc = '/media/cases/fora/team-photo/team-photo.webp',
  photoAlt = 'Fora team photo',
  caption = 'finally the project turned for us into a shared adventure we truly enjoyed',
  heartLeftSrc = '/media/cases/fora/team-photo/heart-left.svg',
  heartRightSrc = '/media/cases/fora/team-photo/heart-right.svg',
} = Astro.props as Props;

const rootClassName = ['fora-team-photo-section', className].filter(Boolean).join(' ');
const resolvedInViewPreset = inViewPreset === 'appear-v1' ? 'appear-v1' : undefined;
---

<section class={rootClassName} aria-label="Fora team photo section" data-motion-inview={resolvedInViewPreset}>
  <QuantizedPerimeter
    class="fora-team-photo-surface fora-team-photo-surface--desktop"
    shape="rectangle"
    edgePattern="scallop"
    step={48}
    bg="var(--color-bg-darkened)"
    pad="0"
    clipContentToShape={true}
    label="Fora team photo"
  >
    <img class="fora-team-photo-image" src={photoSrc} alt={photoAlt} loading="lazy" decoding="async" />
  </QuantizedPerimeter>

  <QuantizedPerimeter
    class="fora-team-photo-surface fora-team-photo-surface--mobile"
    shape="rectangle"
    edgePattern="scallop"
    step={40}
    bg="var(--color-bg-darkened)"
    pad="0"
    clipContentToShape={true}
    label="Fora team photo"
  >
    <img class="fora-team-photo-image" src={photoSrc} alt={photoAlt} loading="lazy" decoding="async" />
  </QuantizedPerimeter>

  <div class="fora-team-photo-caption-group">
    <p class="type-description-medium fora-team-photo-caption">{caption}</p>

    <ThemedSvgIcon
      class="fora-team-photo-heart fora-team-photo-heart--right"
      src={heartRightSrc}
      aria-hidden="true"
    />

    <ThemedSvgIcon
      class="fora-team-photo-heart fora-team-photo-heart--left"
      src={heartLeftSrc}
      aria-hidden="true"
    />
  </div>
</section>
