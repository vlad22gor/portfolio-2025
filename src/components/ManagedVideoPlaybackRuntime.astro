<script>
  import {
    createLifecycle,
    getOrCreateWindowRuntime,
    getRouteFlags,
    getWindowRuntime,
    onAstroBeforeSwap,
    onAstroPageLoad,
    readDataString,
  } from '../lib/runtime';

  (() => {
    const runtimeKey = '__managedVideoPlaybackRuntime';
    const existingRuntime = getWindowRuntime(runtimeKey);
    if (existingRuntime) {
      existingRuntime.mount?.();
      existingRuntime.sync?.();
      return;
    }

    const lifecycle = createLifecycle();
    const selector = 'video[data-video-playback="inview"]';
    const initAttr = 'data-video-playback-init';
    const mobileDowngradedAttr = 'data-video-mobile-downgraded';
    const frameReadyAttr = 'data-video-frame-ready';
    const iOSUserAgentPattern = /(iPad|iPhone|iPod)/i;
    const originalPreloadFallback = 'metadata';
    const managed = new Map();
    let observer = null;
    const isIOSWebKit = (() => {
      const ua = typeof navigator.userAgent === 'string' ? navigator.userAgent : '';
      const platform = typeof navigator.platform === 'string' ? navigator.platform : '';
      const maxTouchPoints = Number.isFinite(navigator.maxTouchPoints) ? navigator.maxTouchPoints : 0;
      const isIOSDevice = iOSUserAgentPattern.test(ua) || (platform === 'MacIntel' && maxTouchPoints > 1);
      return isIOSDevice && /AppleWebKit/i.test(ua);
    })();

    const hasCurrentFrameData = (video) => video.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA;

    const readPlaybackPolicy = (video) => readDataString(video, 'videoPlayback', '');

    const rememberOriginalPreload = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      if (typeof video.dataset.videoOriginalPreload === 'string') {
        return;
      }
      video.dataset.videoOriginalPreload = video.getAttribute('preload') ?? '';
    };

    const setVideoPreload = (video, value) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      if (typeof value === 'string' && value.length > 0) {
        video.preload = value;
        video.setAttribute('preload', value);
        return;
      }
      video.removeAttribute('preload');
      video.preload = '';
    };

    const restoreOriginalPreload = (video, fallback = originalPreloadFallback) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      rememberOriginalPreload(video);
      const original =
        typeof video.dataset.videoOriginalPreload === 'string' ? video.dataset.videoOriginalPreload : '';
      setVideoPreload(video, original || fallback);
    };

    const applyMemorySafeInviewPreload = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      if (!isIOSWebKit) {
        return;
      }
      if (readPlaybackPolicy(video) !== 'inview') {
        return;
      }
      rememberOriginalPreload(video);
      setVideoPreload(video, 'none');
    };

    const markMockupFrameReady = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      const mockup = video.closest('.device-mockup[data-device-mockup]');
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (readDataString(mockup, 'deviceMediaKind', '') !== 'video') {
        return;
      }
      mockup.setAttribute(frameReadyAttr, 'true');
    };

    const shouldDowngradeAlwaysPlaybackForMobileGallery = () => {
      const { isGalleryRoute } = getRouteFlags();
      if (!isGalleryRoute) {
        return false;
      }
      if (typeof window.matchMedia !== 'function') {
        return false;
      }
      return window.matchMedia('(max-width: 767px)').matches;
    };

    const unregisterManagedVideo = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      const state = managed.get(video);
      if (state) {
        if (typeof state.onLoadedData === 'function') {
          video.removeEventListener('loadeddata', state.onLoadedData);
        }
        if (typeof state.onCanPlay === 'function') {
          video.removeEventListener('canplay', state.onCanPlay);
        }
      }
      observer?.unobserve(video);
      managed.delete(video);
      video.removeAttribute(initAttr);
    };

    const releaseVideoResources = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      video.pause();
      if (!isIOSWebKit) {
        return;
      }
      try {
        video.removeAttribute('src');
        video.src = '';
        video.load();
      } catch {
        // Ignore release failures; pause already lowered active media pressure.
      }
    };

    const syncMobileGalleryPlaybackPolicy = () => {
      const forceInViewPolicy = shouldDowngradeAlwaysPlaybackForMobileGallery();
      const galleryVideos = Array.from(document.querySelectorAll('.gallery-row video')).filter(
        (node) => node instanceof HTMLVideoElement,
      );
      if (galleryVideos.length === 0) {
        return;
      }

      galleryVideos.forEach((video) => {
        const isDowngraded = video.getAttribute(mobileDowngradedAttr) === 'true';
        if (forceInViewPolicy) {
          if (readPlaybackPolicy(video) !== 'always') {
            return;
          }
          video.dataset.videoPlayback = 'inview';
          video.setAttribute(mobileDowngradedAttr, 'true');
          video.autoplay = false;
          video.removeAttribute('autoplay');
          applyMemorySafeInviewPreload(video);
          video.pause();
          return;
        }

        if (!isDowngraded) {
          return;
        }

        video.dataset.videoPlayback = 'always';
        video.removeAttribute(mobileDowngradedAttr);
        video.autoplay = true;
        video.setAttribute('autoplay', '');
        restoreOriginalPreload(video);
        unregisterManagedVideo(video);
      });
    };

    const cleanupStaleVideos = () => {
      for (const [video] of managed.entries()) {
        if (!(video instanceof HTMLVideoElement) || !video.isConnected) {
          unregisterManagedVideo(video);
        }
      }
    };

    const syncVideoPlayback = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      if (readPlaybackPolicy(video) !== 'inview') {
        return;
      }
      const state = managed.get(video);
      if (!state) {
        return;
      }
      if (!state.hasFrameData && hasCurrentFrameData(video)) {
        state.hasFrameData = true;
      }
      if (state.hasFrameData) {
        markMockupFrameReady(video);
      }
      const shouldPlay = Boolean(state?.inView) && !document.hidden && video.isConnected;
      if (!shouldPlay) {
        video.pause();
        return;
      }
      if (!state.hasFrameData) {
        if (!state.warmupRequested) {
          state.warmupRequested = true;
          setVideoPreload(video, 'auto');
          if (video.networkState === HTMLMediaElement.NETWORK_EMPTY) {
            try {
              video.load();
            } catch {
              // Ignore media load errors here; playback gate will remain closed.
            }
          }
        }
        return;
      }
      const playPromise = video.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {});
      }
    };

    const syncAllVideos = () => {
      cleanupStaleVideos();
      managed.forEach((_, video) => {
        syncVideoPlayback(video);
      });
    };

    const pauseAllVideos = () => {
      managed.forEach((_, video) => {
        video.pause();
      });
    };

    const releaseManagedVideosForSwap = () => {
      for (const video of Array.from(managed.keys())) {
        releaseVideoResources(video);
        unregisterManagedVideo(video);
      }
    };

    observer = lifecycle.trackObserver(
      new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const target = entry.target;
            if (!(target instanceof HTMLVideoElement)) {
              return;
            }
            const state = managed.get(target);
            if (!state) {
              return;
            }
            state.inView = entry.isIntersecting && entry.intersectionRatio > 0.15;
            syncVideoPlayback(target);
          });
        },
        { threshold: [0, 0.15, 0.35] },
      ),
    );

    const registerVideo = (video) => {
      if (!(video instanceof HTMLVideoElement)) {
        return;
      }
      if (readPlaybackPolicy(video) !== 'inview') {
        return;
      }
      if (video.getAttribute(initAttr) === 'true') {
        return;
      }
      video.setAttribute(initAttr, 'true');
      video.muted = true;
      video.playsInline = true;
      applyMemorySafeInviewPreload(video);
      const initialHasFrameData = hasCurrentFrameData(video);
      const onFrameDataReady = () => {
        const state = managed.get(video);
        if (!state) {
          return;
        }
        state.hasFrameData = true;
        markMockupFrameReady(video);
        syncVideoPlayback(video);
      };
      managed.set(video, {
        inView: false,
        hasFrameData: initialHasFrameData,
        warmupRequested: initialHasFrameData || (video.getAttribute('preload') ?? '') === 'auto',
        onLoadedData: onFrameDataReady,
        onCanPlay: onFrameDataReady,
      });
      if (initialHasFrameData) {
        markMockupFrameReady(video);
      }
      video.addEventListener('loadeddata', onFrameDataReady);
      video.addEventListener('canplay', onFrameDataReady);
      observer?.observe(video);
      syncVideoPlayback(video);
    };

    const mount = () => {
      syncMobileGalleryPlaybackPolicy();
      cleanupStaleVideos();
      document.querySelectorAll(selector).forEach((node) => {
        registerVideo(node);
      });
      syncAllVideos();
    };

    lifecycle.addCleanup(onAstroPageLoad(mount));
    lifecycle.addCleanup(
      onAstroBeforeSwap(() => {
        if (isIOSWebKit) {
          releaseManagedVideosForSwap();
          return;
        }
        pauseAllVideos();
      }),
    );
    lifecycle.on(document, 'visibilitychange', syncAllVideos);
    lifecycle.on(window, 'pagehide', pauseAllVideos);
    lifecycle.on(window, 'resize', mount);

    const runtime = {
      mount,
      sync: syncAllVideos,
      pauseAll: pauseAllVideos,
      releaseForSwap: releaseManagedVideosForSwap,
      destroy() {
        releaseManagedVideosForSwap();
        lifecycle.dispose();
      },
    };

    const installedRuntime = getOrCreateWindowRuntime(runtimeKey, () => runtime);
    if (installedRuntime !== runtime) {
      lifecycle.dispose();
      installedRuntime?.mount?.();
      installedRuntime?.sync?.();
      return;
    }

    mount();
  })();
</script>
