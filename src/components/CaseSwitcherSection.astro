---
import Button from './Button.astro';
import QuantizedPerimeter from './QuantizedPerimeter.astro';

import type { Case } from '../data/cases';

interface Props {
  currentCase: Case;
  prevCase: Case;
  nextCase: Case;
  inViewPreset?: 'appear-v1';
  class?: string;
}

const { currentCase, prevCase, nextCase, inViewPreset, class: className = '' } = Astro.props as Props;
const resolvedCover = {
  src: currentCase.cardCover.src,
  alt: currentCase.cardCover.alt,
};

const rootClassName = ['case-switcher-section', className].filter(Boolean).join(' ');
const resolvedInViewPreset = inViewPreset === 'appear-v1' ? 'appear-v1' : undefined;
---

<section class={rootClassName} aria-label="Case switcher section" data-motion-inview={resolvedInViewPreset}>
  <div class="case-switcher-scene-wrap">
    <nav class="case-switcher-scene" aria-label="Case switcher navigation">
      <Button
        href={`/${prevCase.slug}`}
        variant="bordered-icon"
        iconSide="left"
        class="case-switcher-button case-switcher-button--prev"
      >
        prev
      </Button>

      <QuantizedPerimeter
        class="case-switcher-cover"
        shape="circle"
        edgePattern="scallop"
        fit="contain"
        step={40}
        minLobes={8}
        pad="0"
        bg="var(--color-bg-darkened)"
        clipContentToShape={false}
        exportShapeMask
        label={`${currentCase.title} case cover (Perimetr Scallop Circle)`}
      >
        <img
          class="case-switcher-cover-image"
          src={resolvedCover.src}
          alt={resolvedCover.alt}
          loading="lazy"
          decoding="async"
        />
      </QuantizedPerimeter>

      <Button
        href={`/${nextCase.slug}`}
        variant="bordered-icon"
        iconSide="right"
        class="case-switcher-button case-switcher-button--next"
      >
        next
      </Button>
    </nav>
  </div>
</section>

<script>
  import { navigate } from 'astro:transitions/client';

  (() => {
    const runtimeKey = '__caseSwitcherTransitionRuntime';
    if (window[runtimeKey]) {
      window[runtimeKey].mount();
      return;
    }

    const leavingMainAttribute = 'data-case-switcher-leaving';
    const introSyncMarkerKey = '__case-switcher-intro-sync';
    const preFadeDurationMs = 180;
    const preFadeFallbackDelayMs = 420;
    const fallbackCleanupMs = 3000;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const boundButtons = new WeakSet();

    let preFadeFallbackTimeoutId = 0;
    let fallbackTimeoutId = 0;
    let navigationLocked = false;

    const clearTimers = () => {
      if (preFadeFallbackTimeoutId !== 0) {
        window.clearTimeout(preFadeFallbackTimeoutId);
        preFadeFallbackTimeoutId = 0;
      }
      if (fallbackTimeoutId !== 0) {
        window.clearTimeout(fallbackTimeoutId);
        fallbackTimeoutId = 0;
      }
    };

    const clearLeaveStateFromMain = () => {
      document.querySelectorAll(`main#content[${leavingMainAttribute}]`).forEach((node) => {
        if (node instanceof HTMLElement) {
          node.removeAttribute(leavingMainAttribute);
        }
      });
    };

    const clearLeavingState = () => {
      clearTimers();
      navigationLocked = false;
      clearLeaveStateFromMain();
    };

    const setIntroSyncMarker = () => {
      try {
        window.sessionStorage.setItem(introSyncMarkerKey, String(Date.now()));
      } catch {
        // Ignore quota/security errors for private mode.
      }
    };

    const canInterceptClick = (button, event) => {
      if (!button?.href || event.defaultPrevented) {
        return false;
      }

      if (event.button !== 0 || event.metaKey || event.ctrlKey || event.altKey || event.shiftKey) {
        return false;
      }

      if (button.hasAttribute('download')) {
        return false;
      }

      if (button.target && button.target !== '_self') {
        return false;
      }

      let targetUrl;
      try {
        targetUrl = new URL(button.href, window.location.href);
      } catch {
        return false;
      }

      if (targetUrl.origin !== window.location.origin) {
        return false;
      }

      if (targetUrl.href === window.location.href) {
        return false;
      }

      return true;
    };

    const navigateToButtonTarget = (button) => {
      if (!button?.href) {
        return;
      }

      const history = button.dataset.astroHistory === 'replace' ? 'replace' : 'auto';
      navigate(button.href, {
        history,
        sourceElement: button,
      });
    };

    const startNavigationWithPreFade = (button) => {
      if (navigationLocked) {
        return;
      }

      if (prefersReducedMotion.matches) {
        navigateToButtonTarget(button);
        return;
      }

      const main = document.querySelector('main#content');
      if (!(main instanceof HTMLElement)) {
        setIntroSyncMarker();
        navigateToButtonTarget(button);
        return;
      }

      navigationLocked = true;
      let settled = false;

      const cleanupTransitionListeners = () => {
        main.removeEventListener('transitionend', onTransitionEnd);
        main.removeEventListener('transitioncancel', onTransitionCancel);
      };

      const finalizeNavigation = () => {
        if (settled) {
          return;
        }
        settled = true;
        clearTimers();
        cleanupTransitionListeners();
        setIntroSyncMarker();
        navigateToButtonTarget(button);
      };

      const onTransitionEnd = (event) => {
        if (!(event.target instanceof HTMLElement) || event.target !== main) {
          return;
        }
        if (event.propertyName !== 'opacity') {
          return;
        }
        finalizeNavigation();
      };

      const onTransitionCancel = (event) => {
        if (!(event.target instanceof HTMLElement) || event.target !== main) {
          return;
        }
        if (event.propertyName !== 'opacity') {
          return;
        }
        finalizeNavigation();
      };

      main.addEventListener('transitionend', onTransitionEnd);
      main.addEventListener('transitioncancel', onTransitionCancel);
      main.setAttribute(leavingMainAttribute, 'true');

      preFadeFallbackTimeoutId = window.setTimeout(
        finalizeNavigation,
        preFadeDurationMs + preFadeFallbackDelayMs,
      );

      fallbackTimeoutId = window.setTimeout(() => {
        clearLeavingState();
      }, fallbackCleanupMs);
    };

    const bindButton = (button) => {
      if (boundButtons.has(button)) {
        return;
      }

      boundButtons.add(button);
      button.dataset.astroReload = '';
      button.addEventListener('click', (event) => {
        if (!canInterceptClick(button, event)) {
          return;
        }

        event.preventDefault();
        startNavigationWithPreFade(button);
      });
    };

    const mount = () => {
      clearLeavingState();
      const buttons = document.querySelectorAll('.case-switcher-section a.case-switcher-button[href]');
      buttons.forEach((button) => {
        if (button instanceof HTMLAnchorElement) {
          bindButton(button);
        }
      });
    };

    mount();
    document.addEventListener('astro:page-load', mount);
    window.addEventListener('pagehide', clearLeavingState);
    window[runtimeKey] = { mount };
  })();
</script>

<style>
  .case-switcher-section {
    width: 100%;
    min-height: 480px;
  }

  .case-switcher-scene-wrap {
    --case-switcher-scale: min(1, calc((100vw - 2rem) / 816));
    width: 100%;
    height: calc(480px * var(--case-switcher-scale));
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .case-switcher-scene {
    width: 816px;
    height: 480px;
    display: flex;
    align-items: center;
    gap: 24px;
    transform-origin: top center;
    transform: scale(var(--case-switcher-scale));
  }

  .case-switcher-button {
    width: 144px;
    min-width: 144px;
    max-width: 144px;
    flex: 0 0 144px;
  }

  @media (min-width: 848px) {
    .case-switcher-scene-wrap {
      --case-switcher-scale: 1;
      height: 480px;
    }
  }
</style>
