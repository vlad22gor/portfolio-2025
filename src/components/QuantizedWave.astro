---
type WaveAlign = 'left' | 'center' | 'right';
type WavePhase = 'up' | 'down';
type WaveEdge = 'equator';
type WaveFit = 'contain' | 'cover';

interface Props {
  class?: string;
  circleDiameter?: number;
  strokeWidth?: number;
  minCircles?: number;
  count?: number;
  phase?: WavePhase;
  align?: WaveAlign;
  edge?: WaveEdge;
  fit?: WaveFit;
  color?: string;
}

const {
  class: className = '',
  circleDiameter = 8,
  strokeWidth = 2,
  minCircles = 4,
  count,
  phase = 'up',
  align = 'left',
  edge = 'equator',
  fit = 'contain',
  color = 'var(--color-accent-green)',
} = Astro.props;

const round3 = (value: number) => Math.round(value * 1000) / 1000;
const fixedCount =
  typeof count === 'number' && Number.isFinite(count) ? Math.max(1, Math.floor(count)) : undefined;
const initialWidth = fixedCount ? round3(fixedCount * circleDiameter) : 1;
const initialHeight = fixedCount ? round3(circleDiameter + strokeWidth) : 1;
const initialSignature = fixedCount
  ? ['equator', initialWidth, round3(circleDiameter), round3(strokeWidth), fixedCount, phase].join(':')
  : '';

const buildPath = (resolvedCount: number, diameter: number, stroke: number, resolvedPhase: WavePhase) => {
  const radius = diameter / 2;
  const strokeHalf = stroke / 2;
  const baseline = round3(radius + strokeHalf);
  const commands = [`M 0 ${baseline}`];
  let nextUp = resolvedPhase === 'up';

  for (let index = 0; index < resolvedCount; index += 1) {
    const endX = round3((index + 1) * diameter);
    const sweep = nextUp ? 0 : 1;
    commands.push(`A ${round3(radius)} ${round3(radius)} 0 0 ${sweep} ${endX} ${baseline}`);
    nextUp = !nextUp;
  }

  return commands.join(' ');
};

const initialPath = fixedCount ? buildPath(fixedCount, circleDiameter, strokeWidth, phase) : 'M0 0L1 0';
const initialStyle = `${
  `--wave-color: ${color}; --wave-diameter: ${circleDiameter}px; --wave-stroke: ${strokeWidth}px;`
}${fixedCount ? ` width: ${initialWidth}px; height: ${initialHeight}px;` : ''}`;
---

<div
  class={`quantized-wave ${className}`.trim()}
  data-quantized-wave
  data-ready={fixedCount ? 'true' : 'false'}
  data-wave-diameter={String(circleDiameter)}
  data-wave-stroke={String(strokeWidth)}
  data-wave-min-circles={String(minCircles)}
  data-wave-count={typeof fixedCount === 'number' ? String(fixedCount) : ''}
  data-wave-count-resolved={typeof fixedCount === 'number' ? String(fixedCount) : ''}
  data-wave-signature={initialSignature}
  data-wave-phase={phase}
  data-wave-align={align}
  data-wave-edge={edge}
  data-wave-fit={fit}
  style={initialStyle}
  role="presentation"
  aria-hidden="true"
>
  <svg
    class="wave-frame"
    viewBox={fixedCount ? `0 0 ${initialWidth} ${initialHeight}` : '0 0 1 1'}
    preserveAspectRatio="none"
    focusable="false"
  >
    <path
      class="wave-path"
      d={initialPath}
      fill="none"
      stroke="currentColor"
      stroke-width={String(round3(strokeWidth))}
      stroke-linecap="butt"
    ></path>
  </svg>
</div>

<script>
  (() => {
    const runtimeKey = '__quantizedWaveRuntime';
    if (window[runtimeKey]) {
      window[runtimeKey].mountNewRoots();
      window[runtimeKey].scheduleAll();
      return;
    }

    const runtime = {
      roots: new Set(),
      states: new WeakMap(),
    };

    const readNumber = (value, fallback) => {
      const parsed = Number.parseFloat(value ?? '');
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const clampNumber = (value, min, max) => Math.min(max, Math.max(min, value));
    const clampInt = (value, min) => Math.max(min, Math.floor(value));
    const round3 = (value) => Math.round(value * 1000) / 1000;

    const resolveAlign = (value) => {
      if (value === 'center' || value === 'right') {
        return value;
      }
      return 'left';
    };

    const resolvePhase = (value) => {
      if (value === 'down') {
        return 'down';
      }
      return 'up';
    };

    const resolveFit = (value) => {
      if (value === 'cover') {
        return 'cover';
      }
      return 'contain';
    };

    const applyAlignment = (root, align) => {
      if (align === 'center') {
        root.style.marginLeft = 'auto';
        root.style.marginRight = 'auto';
        return;
      }

      if (align === 'right') {
        root.style.marginLeft = 'auto';
        root.style.marginRight = '0';
        return;
      }

      root.style.marginLeft = '0';
      root.style.marginRight = 'auto';
    };

    const resolveCircleCount = (root, availableWidth, diameter) => {
      const explicitCount = clampInt(readNumber(root.dataset.waveCount, 0), 0);
      if (explicitCount > 0) {
        return explicitCount;
      }

      const minCircles = clampInt(readNumber(root.dataset.waveMinCircles, 4), 1);
      const fit = resolveFit(root.dataset.waveFit);

      if (fit === 'cover') {
        const ceilCount = Math.ceil(availableWidth / diameter);
        const reducedCount = ceilCount - 1;
        return Math.max(minCircles, Math.max(1, reducedCount));
      }

      const floorCount = Math.floor(availableWidth / diameter);
      if (floorCount < 1) {
        return 1;
      }

      const preferredCount = Math.max(minCircles, floorCount);
      return preferredCount * diameter <= availableWidth ? preferredCount : floorCount;
    };

    const renderWave = (svg, diameter, strokeWidth, count, phase) => {
      const radius = diameter / 2;
      const strokeHalf = strokeWidth / 2;
      const baseline = radius + strokeHalf;
      const width = round3(count * diameter);
      const height = round3(diameter + strokeWidth);
      const commands = [`M 0 ${round3(baseline)}`];

      let nextUp = phase === 'up';
      for (let index = 0; index < count; index += 1) {
        const endX = round3((index + 1) * diameter);
        const sweep = nextUp ? 0 : 1;
        commands.push(`A ${round3(radius)} ${round3(radius)} 0 0 ${sweep} ${endX} ${round3(baseline)}`);
        nextUp = !nextUp;
      }

      svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
      svg.innerHTML = `<path class="wave-path" d="${commands.join(' ')}" fill="none" stroke="currentColor" stroke-width="${round3(strokeWidth)}" stroke-linecap="butt"></path>`;
    };

    const resolveAvailableWidth = (root, parent) => {
      const directWidth = Math.floor(parent.clientWidth);
      if (directWidth > 1) {
        return directWidth;
      }

      let current = parent.parentElement;
      while (current) {
        const width = Math.floor(current.clientWidth);
        if (width > 1) {
          return width;
        }
        current = current.parentElement;
      }

      const ownWidth = Math.floor(root.clientWidth);
      return ownWidth > 1 ? ownWidth : 1;
    };

    const update = (root) => {
      const svg = root.querySelector('.wave-frame');
      const parent = root.parentElement;
      if (!svg || !parent) {
        return;
      }

      const diameter = clampNumber(readNumber(root.dataset.waveDiameter, 8), 2, 512);
      const strokeWidth = clampNumber(readNumber(root.dataset.waveStroke, 2), 1, diameter);
      const availableWidth = resolveAvailableWidth(root, parent);
      const count = resolveCircleCount(root, availableWidth, diameter);
      const quantizedWidth = round3(count * diameter);
      const phase = resolvePhase(root.dataset.wavePhase);
      const align = resolveAlign(root.dataset.waveAlign);
      const height = round3(diameter + strokeWidth);

      const signature = ['equator', quantizedWidth, diameter, strokeWidth, count, phase].join(':');
      const prevSignature = root.dataset.waveSignature;

      root.style.width = `${quantizedWidth}px`;
      root.style.height = `${height}px`;
      root.dataset.waveCountResolved = String(count);
      root.dataset.waveSignature = signature;
      root.dataset.ready = 'true';
      applyAlignment(root, align);

      if (signature !== prevSignature) {
        renderWave(svg, diameter, strokeWidth, count, phase);
      }
    };

    const schedule = (root) => {
      const state = runtime.states.get(root);
      if (!state || state.rafId !== 0) {
        return;
      }

      state.rafId = window.requestAnimationFrame(() => {
        state.rafId = 0;
        update(root);
      });
    };

    const unmount = (root) => {
      const state = runtime.states.get(root);
      if (state) {
        if (state.rafId !== 0) {
          window.cancelAnimationFrame(state.rafId);
        }
        state.observer.disconnect();
        runtime.states.delete(root);
      }
      runtime.roots.delete(root);
    };

    const cleanupDisconnectedRoots = () => {
      runtime.roots.forEach((root) => {
        if (!root.isConnected) {
          unmount(root);
        }
      });
    };

    const mount = (root) => {
      if (runtime.roots.has(root)) {
        schedule(root);
        return;
      }

      const parent = root.parentElement;
      if (!parent) {
        return;
      }

      const observer = new ResizeObserver(() => {
        schedule(root);
      });

      runtime.roots.add(root);
      runtime.states.set(root, { observer, rafId: 0 });
      observer.observe(parent);
      update(root);
    };

    const mountNewRoots = () => {
      cleanupDisconnectedRoots();
      const roots = document.querySelectorAll('[data-quantized-wave]');
      roots.forEach((root) => {
        mount(root);
      });
    };

    const scheduleAll = () => {
      cleanupDisconnectedRoots();
      runtime.roots.forEach((root) => {
        schedule(root);
      });
    };

    document.addEventListener('astro:page-load', () => {
      mountNewRoots();
      scheduleAll();
    });

    window.addEventListener('resize', () => {
      scheduleAll();
    });

    window[runtimeKey] = {
      mountNewRoots,
      scheduleAll,
    };

    mountNewRoots();
  })();
</script>
