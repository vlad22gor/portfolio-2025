---
type WaveAlign = 'left' | 'center' | 'right';
type WavePhase = 'up' | 'down';
type WaveEdge = 'equator';
type WaveFit = 'contain' | 'cover' | 'cover-full' | 'cover-bleed';
type WaveSize = 'small' | 'medium' | 'large';
type WaveTrimMode = 'none' | 'reveal';
type WaveTrimDirection = 'start-to-end' | 'end-to-start';

interface Props {
  class?: string;
  size?: WaveSize;
  circleDiameter?: number;
  strokeWidth?: number;
  minCircles?: number;
  count?: number;
  phase?: WavePhase;
  align?: WaveAlign;
  edge?: WaveEdge;
  fit?: WaveFit;
  bleedCircles?: number;
  color?: string;
  trimMode?: WaveTrimMode;
  trimProgress?: number;
  trimDirection?: WaveTrimDirection;
}

const {
  class: className = '',
  size = 'small',
  circleDiameter,
  strokeWidth,
  minCircles = 4,
  count,
  phase = 'up',
  align = 'left',
  edge = 'equator',
  fit = 'contain',
  bleedCircles = 0,
  color = 'var(--color-divider-bg)',
  trimMode = 'none',
  trimProgress,
  trimDirection = 'start-to-end',
} = Astro.props;

const round3 = (value: number) => Math.round(value * 1000) / 1000;
const clampUnit = (value: number) => Math.min(1, Math.max(0, value));
const isFiniteNumber = (value: unknown): value is number =>
  typeof value === 'number' && Number.isFinite(value);
const waveSizeMap: Record<WaveSize, { diameter: number; stroke: number }> = {
  small: { diameter: 8, stroke: 2 },
  medium: { diameter: 14, stroke: 4 },
  large: { diameter: 20, stroke: 10 },
};
const resolvedSize: WaveSize = size === 'medium' || size === 'large' ? size : 'small';
const resolvedSizeConfig = waveSizeMap[resolvedSize];
const resolvedDiameter = isFiniteNumber(circleDiameter) ? circleDiameter : resolvedSizeConfig.diameter;
const resolvedStroke = isFiniteNumber(strokeWidth) ? strokeWidth : resolvedSizeConfig.stroke;
const resolvedTrimMode: WaveTrimMode = trimMode === 'reveal' ? 'reveal' : 'none';
const resolvedTrimDirection: WaveTrimDirection =
  trimDirection === 'end-to-start' ? 'end-to-start' : 'start-to-end';
const resolvedTrimProgress = clampUnit(isFiniteNumber(trimProgress) ? trimProgress : 1);
const fixedCount =
  typeof count === 'number' && Number.isFinite(count) ? Math.max(1, Math.floor(count)) : undefined;
const initialWidth = fixedCount ? round3(fixedCount * resolvedDiameter) : 1;
const initialHeight = fixedCount ? round3(resolvedDiameter + resolvedStroke) : 1;
const initialSignature = fixedCount
  ? ['equator', initialWidth, round3(resolvedDiameter), round3(resolvedStroke), fixedCount, phase].join(':')
  : '';

const buildPath = (resolvedCount: number, diameter: number, stroke: number, resolvedPhase: WavePhase) => {
  const radius = diameter / 2;
  const strokeHalf = stroke / 2;
  const baseline = round3(radius + strokeHalf);
  const commands = [`M 0 ${baseline}`];
  let nextUp = resolvedPhase === 'up';

  for (let index = 0; index < resolvedCount; index += 1) {
    const endX = round3((index + 1) * diameter);
    const sweep = nextUp ? 0 : 1;
    commands.push(`A ${round3(radius)} ${round3(radius)} 0 0 ${sweep} ${endX} ${baseline}`);
    nextUp = !nextUp;
  }

  return commands.join(' ');
};

const initialPath = fixedCount ? buildPath(fixedCount, resolvedDiameter, resolvedStroke, phase) : 'M0 0L1 0';
const initialTotalLength = fixedCount ? round3(fixedCount * Math.PI * (resolvedDiameter / 2)) : 0;
const initialVisibleLength = round3(initialTotalLength * resolvedTrimProgress);
const initialDashOffset =
  resolvedTrimDirection === 'end-to-start' ? round3(-(initialTotalLength - initialVisibleLength)) : 0;
const initialTrimStyle =
  fixedCount && resolvedTrimMode === 'reveal'
    ? `stroke-dasharray: ${initialVisibleLength} ${initialTotalLength}; stroke-dashoffset: ${initialDashOffset};`
    : '';
const initialStyle = `${
  `--wave-color: ${color}; --wave-diameter: ${resolvedDiameter}px; --wave-stroke: ${resolvedStroke}px;`
}${fixedCount ? ` width: ${initialWidth}px; height: ${initialHeight}px;` : ''}`;
---

<div
  class={`quantized-wave ${className}`.trim()}
  data-quantized-wave
  data-ready={fixedCount ? 'true' : 'false'}
  data-wave-size={resolvedSize}
  data-wave-diameter={String(resolvedDiameter)}
  data-wave-stroke={String(resolvedStroke)}
  data-wave-min-circles={String(minCircles)}
  data-wave-count={typeof fixedCount === 'number' ? String(fixedCount) : ''}
  data-wave-count-resolved={typeof fixedCount === 'number' ? String(fixedCount) : ''}
  data-wave-signature={initialSignature}
  data-wave-phase={phase}
  data-wave-align={align}
  data-wave-edge={edge}
  data-wave-fit={fit}
  data-wave-bleed-circles={String(Math.max(0, Math.floor(bleedCircles)))}
  data-wave-trim-mode={resolvedTrimMode}
  data-wave-trim-progress={String(resolvedTrimProgress)}
  data-wave-trim-direction={resolvedTrimDirection}
  style={initialStyle}
  role="presentation"
  aria-hidden="true"
>
  <svg
    class="wave-frame"
    viewBox={fixedCount ? `0 0 ${initialWidth} ${initialHeight}` : '0 0 1 1'}
    preserveAspectRatio="none"
    focusable="false"
  >
    <path
      class="wave-path"
      d={initialPath}
      fill="none"
      stroke="currentColor"
      stroke-width={String(round3(resolvedStroke))}
      stroke-linecap="butt"
      style={initialTrimStyle || undefined}
    ></path>
  </svg>
</div>

<script>
  (() => {
    const runtimeKey = '__quantizedWaveRuntime';
    if (window[runtimeKey]) {
      window[runtimeKey].mountNewRoots({ scheduleExisting: false });
      return;
    }

    const runtime = {
      roots: new Set(),
      states: new WeakMap(),
    };

    const readNumber = (value, fallback) => {
      const parsed = Number.parseFloat(value ?? '');
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const clampNumber = (value, min, max) => Math.min(max, Math.max(min, value));
    const clampInt = (value, min) => Math.max(min, Math.floor(value));
    const clampUnit = (value) => Math.min(1, Math.max(0, value));
    const round3 = (value) => Math.round(value * 1000) / 1000;

    const resolveAlign = (value) => {
      if (value === 'center' || value === 'right') {
        return value;
      }
      return 'left';
    };

    const resolvePhase = (value) => {
      if (value === 'down') {
        return 'down';
      }
      return 'up';
    };

    const resolveFit = (value) => {
      if (value === 'cover-bleed') {
        return 'cover-bleed';
      }
      if (value === 'cover-full') {
        return 'cover-full';
      }
      if (value === 'cover') {
        return 'cover';
      }
      return 'contain';
    };

    const resolveTrimMode = (value) => {
      if (value === 'reveal') {
        return 'reveal';
      }
      return 'none';
    };

    const resolveTrimDirection = (value) => {
      if (value === 'end-to-start') {
        return 'end-to-start';
      }
      return 'start-to-end';
    };

    const applyTrimReveal = (path, mode, progress, direction) => {
      if (!path || mode !== 'reveal') {
        return;
      }

      const totalLength = path.getTotalLength();
      if (!(totalLength > 0)) {
        return;
      }

      const visibleLength = clampUnit(progress) * totalLength;
      const dashOffset = direction === 'end-to-start' ? -(totalLength - visibleLength) : 0;
      path.style.strokeDasharray = `${round3(visibleLength)} ${round3(totalLength)}`;
      path.style.strokeDashoffset = `${round3(dashOffset)}`;
    };

    const applyAlignment = (root, align, bleedOffsetPx = 0) => {
      if (bleedOffsetPx > 0) {
        root.style.transform = `translateX(-${bleedOffsetPx}px)`;
      } else {
        root.style.transform = '';
      }

      if (align === 'center') {
        root.style.marginLeft = 'auto';
        root.style.marginRight = 'auto';
        return;
      }

      if (align === 'right') {
        root.style.marginLeft = 'auto';
        root.style.marginRight = '0';
        return;
      }

      root.style.marginLeft = '0';
      root.style.marginRight = 'auto';
    };

    const resolveCircleCount = (root, availableWidth, diameter) => {
      const explicitCount = clampInt(readNumber(root.dataset.waveCount, 0), 0);
      if (explicitCount > 0) {
        return explicitCount;
      }

      const minCircles = clampInt(readNumber(root.dataset.waveMinCircles, 4), 1);
      const fit = resolveFit(root.dataset.waveFit);
      const bleedCircles = clampInt(readNumber(root.dataset.waveBleedCircles, 0), 0);

      if (fit === 'cover-full') {
        const ceilCount = Math.ceil(availableWidth / diameter);
        return Math.max(minCircles, Math.max(1, ceilCount));
      }

      if (fit === 'cover-bleed') {
        const ceilCount = Math.ceil(availableWidth / diameter);
        const overscannedCount = ceilCount + bleedCircles * 2;
        return Math.max(minCircles, Math.max(1, overscannedCount));
      }

      if (fit === 'cover') {
        const ceilCount = Math.ceil(availableWidth / diameter);
        const reducedCount = ceilCount - 1;
        return Math.max(minCircles, Math.max(1, reducedCount));
      }

      const floorCount = Math.floor(availableWidth / diameter);
      if (floorCount < 1) {
        return 1;
      }

      const preferredCount = Math.max(minCircles, floorCount);
      return preferredCount * diameter <= availableWidth ? preferredCount : floorCount;
    };

    const renderWave = (svg, diameter, strokeWidth, count, phase) => {
      const radius = diameter / 2;
      const strokeHalf = strokeWidth / 2;
      const baseline = radius + strokeHalf;
      const width = round3(count * diameter);
      const height = round3(diameter + strokeWidth);
      const commands = [`M 0 ${round3(baseline)}`];

      let nextUp = phase === 'up';
      for (let index = 0; index < count; index += 1) {
        const endX = round3((index + 1) * diameter);
        const sweep = nextUp ? 0 : 1;
        commands.push(`A ${round3(radius)} ${round3(radius)} 0 0 ${sweep} ${endX} ${round3(baseline)}`);
        nextUp = !nextUp;
      }

      svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
      svg.innerHTML = `<path class="wave-path" d="${commands.join(' ')}" fill="none" stroke="currentColor" stroke-width="${round3(strokeWidth)}" stroke-linecap="butt"></path>`;
    };

    const resolveGridSlotWidth = (root, parent) => {
      const parentStyle = window.getComputedStyle(parent);
      if (parentStyle.display !== 'grid' && parentStyle.display !== 'inline-grid') {
        return 0;
      }

      const rootStyle = window.getComputedStyle(root);
      const columnStart = Number.parseInt(rootStyle.gridColumnStart, 10);
      const columnEnd = Number.parseInt(rootStyle.gridColumnEnd, 10);
      if (!Number.isFinite(columnStart) || !Number.isFinite(columnEnd) || columnEnd <= columnStart) {
        return 0;
      }

      const trackSizes = parentStyle.gridTemplateColumns
        .split(' ')
        .map((token) => Number.parseFloat(token))
        .filter((value) => Number.isFinite(value) && value > 0);
      if (!trackSizes.length || columnEnd - 1 > trackSizes.length) {
        return 0;
      }

      const spannedTracks = trackSizes.slice(columnStart - 1, columnEnd - 1);
      if (!spannedTracks.length) {
        return 0;
      }

      const trackWidth = spannedTracks.reduce((sum, value) => sum + value, 0);
      const internalGaps = Math.max(0, columnEnd - columnStart - 1);
      const columnGap = Number.parseFloat(parentStyle.columnGap);
      const gapWidth = Number.isFinite(columnGap) ? columnGap : 0;
      return Math.floor(trackWidth + internalGaps * gapWidth);
    };

    const resolveAvailableWidth = (root, parent) => {
      const gridSlotWidth = resolveGridSlotWidth(root, parent);
      if (gridSlotWidth > 1) {
        return gridSlotWidth;
      }

      const directWidth = Math.floor(parent.clientWidth);
      if (directWidth > 1) {
        return directWidth;
      }

      let current = parent.parentElement;
      while (current) {
        const width = Math.floor(current.clientWidth);
        if (width > 1) {
          return width;
        }
        current = current.parentElement;
      }

      const ownWidth = Math.floor(root.clientWidth || root.getBoundingClientRect().width);
      return ownWidth > 1 ? ownWidth : 1;
    };

    const update = (root) => {
      const svg = root.querySelector('.wave-frame');
      const parent = root.parentElement;
      if (!svg || !parent) {
        return;
      }

      const diameter = clampNumber(readNumber(root.dataset.waveDiameter, 8), 2, 512);
      const strokeWidth = clampNumber(readNumber(root.dataset.waveStroke, 2), 1, diameter);
      const availableWidth = resolveAvailableWidth(root, parent);
      const count = resolveCircleCount(root, availableWidth, diameter);
      const quantizedWidth = round3(count * diameter);
      const phase = resolvePhase(root.dataset.wavePhase);
      const align = resolveAlign(root.dataset.waveAlign);
      const fit = resolveFit(root.dataset.waveFit);
      const bleedCircles = clampInt(readNumber(root.dataset.waveBleedCircles, 0), 0);
      const bleedOffsetPx = fit === 'cover-bleed' ? bleedCircles * diameter : 0;
      const trimMode = resolveTrimMode(root.dataset.waveTrimMode);
      const trimProgress = clampUnit(readNumber(root.dataset.waveTrimProgress, 1));
      const trimDirection = resolveTrimDirection(root.dataset.waveTrimDirection);
      const height = round3(diameter + strokeWidth);

      const signature = ['equator', quantizedWidth, diameter, strokeWidth, count, phase].join(':');
      const prevSignature = root.dataset.waveSignature;

      root.style.width = `${quantizedWidth}px`;
      root.style.height = `${height}px`;
      root.dataset.waveCountResolved = String(count);
      root.dataset.waveSignature = signature;
      root.dataset.ready = 'true';
      applyAlignment(root, align, bleedOffsetPx);

      if (signature !== prevSignature) {
        renderWave(svg, diameter, strokeWidth, count, phase);
      }

      const path = svg.querySelector('.wave-path');
      applyTrimReveal(path, trimMode, trimProgress, trimDirection);
    };

    const schedule = (root) => {
      const state = runtime.states.get(root);
      if (!state || state.rafId !== 0) {
        return;
      }

      state.rafId = window.requestAnimationFrame(() => {
        state.rafId = 0;
        update(root);
      });
    };

    const unmount = (root) => {
      const state = runtime.states.get(root);
      if (state) {
        if (state.rafId !== 0) {
          window.cancelAnimationFrame(state.rafId);
        }
        state.observer.disconnect();
        runtime.states.delete(root);
      }
      runtime.roots.delete(root);
    };

    const cleanupDisconnectedRoots = () => {
      runtime.roots.forEach((root) => {
        if (!root.isConnected) {
          unmount(root);
        }
      });
    };

    const mount = (root, options = {}) => {
      const { scheduleExisting = false } = options;
      if (runtime.roots.has(root)) {
        if (scheduleExisting) {
          schedule(root);
        }
        return false;
      }

      const parent = root.parentElement;
      if (!parent) {
        return false;
      }

      const observer = new ResizeObserver(() => {
        schedule(root);
      });

      runtime.roots.add(root);
      runtime.states.set(root, { observer, rafId: 0 });
      observer.observe(parent);
      update(root);
      return true;
    };

    const mountNewRoots = (options = {}) => {
      const { scheduleExisting = false } = options;
      cleanupDisconnectedRoots();
      const roots = document.querySelectorAll('[data-quantized-wave]');
      roots.forEach((root) => {
        mount(root, { scheduleExisting });
      });
    };

    const scheduleAll = () => {
      cleanupDisconnectedRoots();
      runtime.roots.forEach((root) => {
        schedule(root);
      });
    };

    document.addEventListener('astro:page-load', () => {
      mountNewRoots({ scheduleExisting: false });
    });

    window.addEventListener('resize', () => {
      scheduleAll();
    });

    window[runtimeKey] = {
      mountNewRoots,
      scheduleAll,
    };

    mountNewRoots({ scheduleExisting: false });
  })();
</script>
