---
import GalleryCard from './GalleryCard.astro';
import { GALLERY_ROWS } from '../data/gallery';
import type { GalleryCardType, GalleryDeviceLoadPriority, GalleryRowItem } from '../data/gallery';

const isDeviceCard = (item: GalleryRowItem) => item.type === 'phone' || item.type === 'tablet';
const resolvePriorityForRow = (rowIndex: number, item: GalleryRowItem): GalleryDeviceLoadPriority | undefined => {
  if (!isDeviceCard(item)) {
    return undefined;
  }
  if (rowIndex === 0) {
    return 'critical';
  }
  return item.priority;
};

type MobileGalleryCardKind = 'device' | 'illustration' | 'image';

const MOBILE_GALLERY_GAP_MATRIX: Record<MobileGalleryCardKind, Record<MobileGalleryCardKind, number>> = {
  device: { device: 120, illustration: 92, image: 92 },
  illustration: { device: 92, illustration: 64, image: 64 },
  image: { device: 92, illustration: 64, image: 64 },
};

const MOBILE_GALLERY_BASE_BOTTOM_PAD: Record<MobileGalleryCardKind, number> = {
  device: 60,
  illustration: 32,
  image: 32,
};

const resolveMobileGalleryKind = (type: GalleryCardType): MobileGalleryCardKind => {
  if (type === 'image') {
    return 'image';
  }
  if (type === 'illustration') {
    return 'illustration';
  }
  return 'device';
};

const flattenedItems = GALLERY_ROWS.flatMap((row) => row.items);
const flattenedKinds = flattenedItems.map((item) => resolveMobileGalleryKind(item.type));
const lastFlatIndex = flattenedItems.length - 1;
const entryByCardId = new Map<
  string,
  {
    kind: MobileGalleryCardKind;
    prevKind: MobileGalleryCardKind | null;
    nextKind: MobileGalleryCardKind | null;
    mobilePadTop: number;
    mobilePadBottom: number;
    flatIndex: number;
  }
>();

flattenedItems.forEach((item, flatIndex) => {
  const kind = flattenedKinds[flatIndex] ?? 'device';
  const prevKind = flatIndex > 0 ? flattenedKinds[flatIndex - 1] ?? null : null;
  const nextKind = flatIndex < lastFlatIndex ? flattenedKinds[flatIndex + 1] ?? null : null;
  const bottomBase = MOBILE_GALLERY_BASE_BOTTOM_PAD[kind];
  const topFromPair = prevKind
    ? MOBILE_GALLERY_GAP_MATRIX[prevKind][kind] - MOBILE_GALLERY_BASE_BOTTOM_PAD[prevKind]
    : 0;
  const mobilePadTop = flatIndex === 0 ? 0 : Math.max(0, topFromPair);
  const mobilePadBottom = flatIndex === lastFlatIndex ? 0 : bottomBase;
  entryByCardId.set(item.id, {
    kind,
    prevKind,
    nextKind,
    mobilePadTop,
    mobilePadBottom,
    flatIndex,
  });
});

---

<section class="gallery-rows-section" aria-labelledby="gallery-page-title">
  <h1 id="gallery-page-title" class="gallery-page-title">Gallery</h1>
  <div class="gallery-rows">
    {GALLERY_ROWS.map((row, rowIndex) => (
      <div class="gallery-row" data-gallery-row-id={row.id} data-gallery-row-index={String(rowIndex)}>
        {row.items.map((item, itemIndex) => {
          const cardEntry = entryByCardId.get(item.id);
          const mobilePadTop = cardEntry?.mobilePadTop ?? 0;
          const mobilePadBottom = cardEntry?.mobilePadBottom ?? 0;
          const inlineStyle = `--gallery-mobile-card-pad-top:${mobilePadTop}px; --gallery-mobile-card-pad-bottom:${mobilePadBottom}px;`;
          return (
            <div
              class={`gallery-card-container gallery-card-container--span-${item.colSpan}`.trim()}
              data-gallery-card-kind={cardEntry?.kind ?? resolveMobileGalleryKind(item.type)}
              data-gallery-prev-kind={cardEntry?.prevKind ?? undefined}
              data-gallery-next-kind={cardEntry?.nextKind ?? undefined}
              data-gallery-mobile-pad-top={String(mobilePadTop)}
              data-gallery-mobile-pad-bottom={String(mobilePadBottom)}
              data-gallery-flat-index={cardEntry ? String(cardEntry.flatIndex) : undefined}
              style={inlineStyle}
            >
              <GalleryCard item={item} priorityOverride={resolvePriorityForRow(rowIndex, item)} staggerIndex={itemIndex} />
            </div>
          );
        })}
      </div>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const runtimeKey = '__galleryDesktopRowStaggerRuntime';
    const desktopMediaQuery = '(min-width: 1360px)';
    const firstTwoRowsPreset = 'gallery-first-two-rows-stagger-v1';
    const desktopRowStaggerPreset = 'gallery-row-stagger-v1';
    const rootSelector = '.gallery-rows';
    const stagedRowSelector = '.gallery-row';
    const rowStagedItemSelector = '[data-motion-stagger-item]';
    const firstTwoStageSelector = '[data-gallery-first-two-stage-item]';
    const cardContainerSelector = '.gallery-card-container';
    const store = window;
    const existingRuntime = store[runtimeKey];
    if (existingRuntime && typeof existingRuntime.mount === 'function') {
      existingRuntime.mount();
      return;
    }

    const mediaQuery = window.matchMedia(desktopMediaQuery);

    const clearInViewState = (element) => {
      if (!(element instanceof HTMLElement)) {
        return;
      }
      element.removeAttribute('data-motion-inview');
      element.removeAttribute('data-motion-inview-bound');
      element.removeAttribute('data-motion-inview-animated');
    };

    const clearElementStyles = (elements) => {
      elements.forEach((item) => {
        if (!(item instanceof HTMLElement)) {
          return;
        }
        item.style.opacity = '';
        item.style.transform = '';
      });
    };

    const applyFirstTwoRowsStageMetadata = (root) => {
      const containers = Array.from(root.querySelectorAll(cardContainerSelector)).filter(
        (node) => node instanceof HTMLElement,
      );
      containers.forEach((container) => {
        container.removeAttribute('data-gallery-first-two-stage-item');
        container.removeAttribute('data-motion-stagger-index');
      });

      const firstTwoContainers = containers
        .map((container) => {
          const rawIndex = container.dataset.galleryFlatIndex ?? '';
          const flatIndex = Number.parseInt(rawIndex, 10);
          return { container, flatIndex };
        })
        .filter(({ flatIndex }) => Number.isFinite(flatIndex) && flatIndex >= 0 && flatIndex <= 7)
        .sort((left, right) => left.flatIndex - right.flatIndex);

      firstTwoContainers.forEach(({ container, flatIndex }) => {
        container.setAttribute('data-gallery-first-two-stage-item', '');
        container.setAttribute('data-motion-stagger-index', String(flatIndex));
      });
    };

    const applyDesktopRowStagger = (rows, root) => {
      clearInViewState(root);
      root.setAttribute('data-motion-inview', firstTwoRowsPreset);
      applyFirstTwoRowsStageMetadata(root);

      rows.forEach((row, index) => {
        clearInViewState(row);
        if (index >= 2) {
          row.setAttribute('data-motion-inview', desktopRowStaggerPreset);
        }
      });
    };

    const clearDesktopGalleryStagger = (root, rows) => {
      clearInViewState(root);
      const firstTwoStageNodes = Array.from(root.querySelectorAll(firstTwoStageSelector));
      const rowStagedNodes = Array.from(root.querySelectorAll(rowStagedItemSelector));
      clearElementStyles(firstTwoStageNodes);
      clearElementStyles(rowStagedNodes);

      const containers = Array.from(root.querySelectorAll(cardContainerSelector)).filter(
        (node) => node instanceof HTMLElement,
      );
      containers.forEach((container) => {
        container.removeAttribute('data-gallery-first-two-stage-item');
        container.removeAttribute('data-motion-stagger-index');
      });

      rows.forEach((row) => {
        clearInViewState(row);
      });
    };

    const syncMode = () => {
      const root = document.querySelector(rootSelector);
      const rows = Array.from(document.querySelectorAll(stagedRowSelector)).filter(
        (node) => node instanceof HTMLElement,
      );
      if (!(root instanceof HTMLElement) || rows.length === 0) {
        return;
      }

      if (!mediaQuery.matches) {
        clearDesktopGalleryStagger(root, rows);
        return;
      }

      applyDesktopRowStagger(rows, root);
      const inViewRuntime = window.__inViewAppearRuntime;
      if (inViewRuntime && typeof inViewRuntime.mount === 'function') {
        inViewRuntime.mount();
      }
    };

    const handleMediaChange = () => {
      syncMode();
    };
    const handlePageLoad = () => {
      syncMode();
    };
    const handlePageHide = () => {
      const rows = Array.from(document.querySelectorAll(stagedRowSelector)).filter(
        (node) => node instanceof HTMLElement,
      );
      const root = document.querySelector(rootSelector);
      if (!(root instanceof HTMLElement)) {
        return;
      }
      clearDesktopGalleryStagger(root, rows);
    };

    if (typeof mediaQuery.addEventListener === 'function') {
      mediaQuery.addEventListener('change', handleMediaChange);
    } else if (typeof mediaQuery.addListener === 'function') {
      mediaQuery.addListener(handleMediaChange);
    }
    document.addEventListener('astro:page-load', handlePageLoad);
    window.addEventListener('pagehide', handlePageHide);

    const runtime = {
      mount: syncMode,
      destroy() {
        if (typeof mediaQuery.removeEventListener === 'function') {
          mediaQuery.removeEventListener('change', handleMediaChange);
        } else if (typeof mediaQuery.removeListener === 'function') {
          mediaQuery.removeListener(handleMediaChange);
        }
        document.removeEventListener('astro:page-load', handlePageLoad);
        window.removeEventListener('pagehide', handlePageHide);
      },
    };

    store[runtimeKey] = runtime;
    syncMode();
  })();
</script>
