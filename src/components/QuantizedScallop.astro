---
import QuantizedPerimeter from './QuantizedPerimeter.astro';

interface Props {
  class?: string;
  shape?: 'rectangle' | 'circle';
  rectangleEdges?: 'all' | 'top';
  fit?: 'contain' | 'cover';
  step?: number;
  minCols?: number;
  minRows?: number;
  minLobes?: number;
  clampLines?: number;
  label?: string;
  bg?: string;
  pad?: string;
  hoverMorph?: boolean;
  hoverMorphPreset?: 'default' | 'strong';
  hoverMorphDesktopOnly?: boolean;
  hoverMorphFocusMode?: 'pointer-and-focus' | 'pointer-only';
  clipContentToShape?: boolean;
  exportShapeMask?: boolean;
  outlineEnabled?: boolean;
  outlineMode?: 'alpha' | 'geometric';
  outlinePlacement?: 'center' | 'outside';
  outlineWidth?: number;
  outlineColor?: string;
  outlineOpacity?: number;
}

const {
  class: className = '',
  shape = 'rectangle',
  rectangleEdges = 'all',
  fit = 'contain',
  step = 48,
  minCols = 12,
  minRows = 8,
  minLobes = 8,
  clampLines = 4,
  label = 'Quantized scallop surface',
  bg,
  pad,
  hoverMorph = false,
  hoverMorphPreset = 'default',
  hoverMorphDesktopOnly = false,
  hoverMorphFocusMode = 'pointer-and-focus',
  clipContentToShape = false,
  exportShapeMask = false,
  outlineEnabled = false,
  outlineMode = 'alpha',
  outlinePlacement = 'center',
  outlineWidth,
  outlineColor,
  outlineOpacity,
} = Astro.props;

const resolvedEdges = rectangleEdges === 'top' ? 'top' : 'all';
---

<QuantizedPerimeter
  class={className}
  shape={shape}
  edgePattern="scallop"
  edges={resolvedEdges}
  fit={fit}
  step={step}
  minCols={minCols}
  minRows={minRows}
  minLobes={minLobes}
  clampLines={clampLines}
  label={label}
  bg={bg}
  pad={pad}
  hoverMorph={hoverMorph}
  hoverMorphPreset={hoverMorphPreset}
  hoverMorphDesktopOnly={hoverMorphDesktopOnly}
  hoverMorphFocusMode={hoverMorphFocusMode}
  clipContentToShape={clipContentToShape}
  exportShapeMask={exportShapeMask}
  outlineEnabled={outlineEnabled}
  outlineMode={outlineMode}
  outlinePlacement={outlinePlacement}
  outlineWidth={outlineWidth}
  outlineColor={outlineColor}
  outlineOpacity={outlineOpacity}
>
  <slot />
</QuantizedPerimeter>
