---
import QuantizedPerimeter from './QuantizedPerimeter.astro';

interface Props {
  class?: string;
  shape?: 'rectangle' | 'circle';
  rectangleEdges?: 'all' | 'top';
  step?: number;
  minCols?: number;
  minRows?: number;
  minLobes?: number;
  clampLines?: number;
  label?: string;
  bg?: string;
  pad?: string;
}

const {
  class: className = '',
  shape = 'rectangle',
  rectangleEdges = 'all',
  step = 40,
  minCols = 12,
  minRows = 8,
  minLobes = 8,
  clampLines = 4,
  label = 'Quantized scallop surface',
  bg,
  pad,
} = Astro.props;

const resolvedEdges = rectangleEdges === 'top' ? 'top' : 'all';
---

<QuantizedPerimeter
  class={className}
  shape={shape}
  edgePattern="scallop"
  edges={resolvedEdges}
  step={step}
  minCols={minCols}
  minRows={minRows}
  minLobes={minLobes}
  clampLines={clampLines}
  label={label}
  bg={bg}
  pad={pad}
>
  <slot />
</QuantizedPerimeter>
