---
import type { ImageMetadata } from 'astro';
import shellPhoneSrc from '../../assets/devices/Shell-phone.png';
import shellTabletSrc from '../../assets/devices/Shell-tablet.png';

type DeviceKind = 'phone' | 'tablet';
type ScreenKind = 'image' | 'video';
type DeviceLoadPriority = 'critical' | 'lazy';

interface DevicePreset {
  width: number;
  height: number;
  shellSrc: ImageMetadata;
  screenZ: number;
  shellZ: number;
  screen: {
    top: string;
    right: string;
    bottom: string;
    left: string;
    radius: string;
  };
}

interface Props {
  device?: DeviceKind;
  screenKind: ScreenKind;
  screenSrc: string;
  screenAlt?: string;
  screenPoster?: string;
  priority?: DeviceLoadPriority;
  class?: string;
}

const {
  device = 'phone',
  screenKind,
  screenSrc,
  screenAlt,
  screenPoster,
  priority = 'lazy',
  class: className = '',
} = Astro.props;

const presets: Record<DeviceKind, DevicePreset> = {
  phone: {
    width: 244,
    height: 501,
    shellSrc: shellPhoneSrc,
    screenZ: 1,
    shellZ: 2,
    screen: {
      top: '2.18%',
      right: '4.97%',
      bottom: '2.19%',
      left: '5.2%',
      radius: '40px',
    },
  },
  tablet: {
    width: 296,
    height: 508,
    shellSrc: shellTabletSrc,
    screenZ: 1,
    shellZ: 2,
    screen: {
      top: '2.2637795276%',
      right: '3.8851351351%',
      bottom: '2.2637795276%',
      left: '3.8851351351%',
      radius: '0px',
    },
  },
};

const resolvedDevice: DeviceKind = device === 'tablet' ? 'tablet' : 'phone';
const resolvedPriority: DeviceLoadPriority = priority === 'critical' ? 'critical' : 'lazy';
const preset = presets[resolvedDevice];
const mediaLoading = resolvedPriority === 'critical' ? 'eager' : 'lazy';
const mediaDecoding = resolvedPriority === 'critical' ? 'sync' : 'async';
const mediaFetchPriority = resolvedPriority === 'critical' ? 'high' : 'auto';
const composedClassName = ['device-mockup', `device-mockup--${resolvedDevice}`, className].filter(Boolean).join(' ');
const styleVars = [
  `--device-width: ${preset.width}px`,
  `--device-height: ${preset.height}px`,
  `--screen-top: ${preset.screen.top}`,
  `--screen-right: ${preset.screen.right}`,
  `--screen-bottom: ${preset.screen.bottom}`,
  `--screen-left: ${preset.screen.left}`,
  `--screen-radius: ${preset.screen.radius}`,
  `--screen-z: ${preset.screenZ}`,
  `--shell-z: ${preset.shellZ}`,
].join('; ');
---

<div
  class={composedClassName}
  style={styleVars}
  data-device-mockup
  data-device-priority={resolvedPriority}
  data-ready="false"
>
  <div class="device-mockup__screen" data-layer="screen">
    {
      screenKind === 'video' ? (
        <video
          class="device-mockup__media"
          src={screenSrc}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={screenPoster}
          aria-hidden="true"
        />
      ) : (
        <img
          class="device-mockup__media"
          src={screenSrc}
          alt={screenAlt ?? ''}
          loading={mediaLoading}
          decoding={mediaDecoding}
          fetchpriority={mediaFetchPriority}
        />
      )
    }
  </div>

  <img
    class="device-mockup__shell"
    src={preset.shellSrc.src}
    alt=""
    aria-hidden="true"
    loading={mediaLoading}
    decoding={mediaDecoding}
    fetchpriority={mediaFetchPriority}
  />
</div>

<style>
  .device-mockup {
    --device-scale: 1;
    position: relative;
    width: calc(var(--device-width) * var(--device-scale));
    height: calc(var(--device-height) * var(--device-scale));
    max-width: 100%;
    isolation: isolate;
    opacity: 1;
    transition: opacity 0.16s ease;
  }

  .device-mockup[data-ready='false'] {
    opacity: 0;
  }

  .device-mockup__screen {
    position: absolute;
    top: var(--screen-top);
    right: var(--screen-right);
    bottom: var(--screen-bottom);
    left: var(--screen-left);
    z-index: var(--screen-z);
    overflow: hidden;
    border-radius: calc(var(--screen-radius) * var(--device-scale));
    background: var(--color-bg-darkened, #1a1a1a);
  }

  .device-mockup__media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .device-mockup__shell {
    position: absolute;
    inset: 0;
    z-index: var(--shell-z);
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .device-mockup {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const runtimeKey = '__deviceMockupRevealRuntime';
    if (window[runtimeKey]) {
      window[runtimeKey].mount();
      return;
    }

    const mockupSelector = '.device-mockup[data-device-mockup]';
    const initAttr = 'data-device-mockup-ready-init';
    const fallbackDelayMs = 1200;

    const markReady = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.dataset.ready === 'true') {
        return;
      }
      mockup.dataset.ready = 'true';
    };

    const initMockup = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.getAttribute(initAttr) === 'true') {
        return;
      }
      mockup.setAttribute(initAttr, 'true');

      const shell = mockup.querySelector('.device-mockup__shell');
      const media = mockup.querySelector('.device-mockup__media');
      let shellReady = !(shell instanceof HTMLImageElement);
      let mediaReady = !media;
      let settled = false;
      const cleanups = [];

      const settle = () => {
        if (settled) {
          return;
        }
        settled = true;
        cleanups.forEach((cleanup) => cleanup());
        markReady(mockup);
      };

      const trySettle = () => {
        if (shellReady && mediaReady) {
          settle();
        }
      };

      const bindOnce = (target, eventName, handler) => {
        target.addEventListener(eventName, handler, { once: true });
        cleanups.push(() => target.removeEventListener(eventName, handler));
      };

      if (shell instanceof HTMLImageElement) {
        shellReady = shell.complete && shell.naturalWidth > 0;
        if (!shellReady) {
          bindOnce(shell, 'load', () => {
            shellReady = true;
            trySettle();
          });
          bindOnce(shell, 'error', () => {
            shellReady = true;
            trySettle();
          });
        }
      }

      if (media instanceof HTMLImageElement) {
        mediaReady = media.complete && media.naturalWidth > 0;
        if (!mediaReady) {
          bindOnce(media, 'load', () => {
            mediaReady = true;
            trySettle();
          });
          bindOnce(media, 'error', () => {
            mediaReady = true;
            trySettle();
          });
        }
      } else if (media instanceof HTMLVideoElement) {
        mediaReady = media.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA;
        if (!mediaReady) {
          bindOnce(media, 'loadeddata', () => {
            mediaReady = true;
            trySettle();
          });
          bindOnce(media, 'error', () => {
            mediaReady = true;
            trySettle();
          });
        }
      }

      const fallbackTimer = window.setTimeout(() => {
        settle();
      }, fallbackDelayMs);
      cleanups.push(() => window.clearTimeout(fallbackTimer));

      trySettle();
    };

    const mount = () => {
      document.querySelectorAll(mockupSelector).forEach((mockup) => {
        initMockup(mockup);
      });
    };

    document.addEventListener('astro:page-load', mount);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }

    window[runtimeKey] = { mount };
  })();
</script>
