---

type DeviceKind = 'phone' | 'tablet';
type DeviceSize = 'default' | 'compact';
type ScreenKind = 'image' | 'video';
type DeviceLoadPriority = 'critical' | 'lazy';

interface DeviceFramePreset {
  width: number;
  height: number;
  screen: {
    x: number;
    y: number;
    width: number;
    height: number;
    radius: number;
  };
}

interface DevicePreset {
  shellSrc: string;
  screenZ: number;
  shellZ: number;
  sizes: Record<DeviceSize, DeviceFramePreset>;
}

interface ApertureRatios {
  left: number;
  right: number;
  top: number;
  bottom: number;
}

interface Props {
  device?: DeviceKind;
  size?: DeviceSize;
  screenKind: ScreenKind;
  screenSrc: string;
  screenAlt?: string;
  screenPoster?: string;
  priority?: DeviceLoadPriority;
  scale?: number;
  class?: string;
}

const {
  device = 'phone',
  size = 'default',
  screenKind,
  screenSrc,
  screenAlt,
  screenPoster,
  priority = 'lazy',
  scale,
  class: className = '',
} = Astro.props;

const frameFromAperture = (
  width: number,
  height: number,
  ratios: ApertureRatios,
  radius: number,
): DeviceFramePreset['screen'] => ({
  x: width * ratios.left,
  y: height * ratios.top,
  width: width * (1 - ratios.left - ratios.right),
  height: height * (1 - ratios.top - ratios.bottom),
  radius,
});

const phoneCompactApertureRatios: ApertureRatios = {
  left: 50 / 976,
  right: 48 / 976,
  top: 43 / 2004,
  bottom: 43 / 2004,
};

const presets: Record<DeviceKind, DevicePreset> = {
  phone: {
    shellSrc: '/media/gallery/device-shells/phone-shell.webp',
    screenZ: 1,
    shellZ: 2,
    sizes: {
      default: {
        width: 244,
        height: 501,
        screen: {
          x: 12.6797,
          y: 10.94,
          width: 219.2,
          height: 479.1,
          radius: 20,
        },
      },
      compact: {
        width: 216,
        height: 443,
        screen: frameFromAperture(216, 443, phoneCompactApertureRatios, 20),
      },
    },
  },
  tablet: {
    shellSrc: '/media/gallery/device-shells/tablet-shell.webp',
    screenZ: 1,
    shellZ: 2,
    sizes: {
      default: {
        width: 296,
        height: 508,
        screen: {
          x: 11.5,
          y: 11.5,
          width: 273,
          height: 485,
          radius: 0,
        },
      },
      compact: {
        width: 258,
        height: 443,
        screen: {
          x: 10,
          y: 10,
          width: 238,
          height: 423,
          radius: 0,
        },
      },
    },
  },
};

const resolvedDevice: DeviceKind = device === 'tablet' ? 'tablet' : 'phone';
const resolvedSize: DeviceSize = size === 'compact' ? 'compact' : 'default';
const resolvedPriority: DeviceLoadPriority = priority === 'critical' ? 'critical' : 'lazy';
const resolvedScale =
  typeof scale === 'number' && Number.isFinite(scale) && scale > 0 ? scale : undefined;
const preset = presets[resolvedDevice];
const framePreset = preset.sizes[resolvedSize];
const screenCalibrationMarker =
  resolvedDevice === 'phone' && resolvedSize === 'compact' ? 'aperture-compact-v2-aa' : undefined;
const mediaLoading = resolvedPriority === 'critical' ? 'eager' : 'lazy';
const mediaDecoding = resolvedPriority === 'critical' ? 'sync' : 'async';
const mediaFetchPriority = resolvedPriority === 'critical' ? 'high' : 'auto';
const composedClassName = ['device-mockup', `device-mockup--${resolvedDevice}`, className].filter(Boolean).join(' ');
const styleVars = [
  `--device-width: ${framePreset.width}px`,
  `--device-height: ${framePreset.height}px`,
  ...(typeof resolvedScale === 'number' ? [`--device-scale: ${resolvedScale}`] : []),
  `--screen-x: ${framePreset.screen.x}px`,
  `--screen-y: ${framePreset.screen.y}px`,
  `--screen-width: ${framePreset.screen.width}px`,
  `--screen-height: ${framePreset.screen.height}px`,
  `--screen-radius: ${framePreset.screen.radius}px`,
  `--screen-z: ${preset.screenZ}`,
  `--shell-z: ${preset.shellZ}`,
].join('; ');
---

<div
  class={composedClassName}
  style={styleVars}
  data-device-mockup
  data-device-priority={resolvedPriority}
  data-device-size={resolvedSize}
  data-device-screen-calibration={screenCalibrationMarker}
  data-ready="false"
>
  <div class="device-mockup__screen" data-layer="screen">
    {
      screenKind === 'video' ? (
        <div class="device-mockup__video-bleed" data-device-video-bleed>
          <video
            class="device-mockup__media device-mockup__media--video"
            src={screenSrc}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={screenPoster}
            aria-hidden="true"
          />
        </div>
      ) : (
        <img
          class="device-mockup__media"
          src={screenSrc}
          alt={screenAlt ?? ''}
          loading={mediaLoading}
          decoding={mediaDecoding}
          fetchpriority={mediaFetchPriority}
        />
      )
    }
  </div>

  <img
    class="device-mockup__shell"
    src={preset.shellSrc}
    alt=""
    aria-hidden="true"
    loading={mediaLoading}
    decoding={mediaDecoding}
    fetchpriority={mediaFetchPriority}
  />
</div>

<style>
  .device-mockup {
    --device-scale: 1;
    position: relative;
    width: calc(var(--device-width) * var(--device-scale));
    height: calc(var(--device-height) * var(--device-scale));
    max-width: 100%;
    isolation: isolate;
    opacity: 1;
    transition: opacity 0.16s ease;
  }

  .device-mockup[data-ready='false'] {
    opacity: 0;
  }

  .device-mockup__screen {
    position: absolute;
    top: calc(var(--screen-y) * var(--device-scale));
    left: calc(var(--screen-x) * var(--device-scale));
    width: calc(var(--screen-width) * var(--device-scale));
    height: calc(var(--screen-height) * var(--device-scale));
    z-index: var(--screen-z);
    overflow: hidden;
    border-radius: calc(var(--screen-radius) * var(--device-scale));
    background: var(--color-bg-darkened, #1a1a1a);
  }

  .device-mockup__media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .device-mockup__video-bleed {
    position: absolute;
    top: -1px;
    right: -1px;
    bottom: -1px;
    left: -1px;
    overflow: hidden;
    pointer-events: none;
  }

  .device-mockup__media--video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: none;
  }

  .device-mockup__shell {
    position: absolute;
    inset: 0;
    z-index: var(--shell-z);
    display: block;
    width: 100%;
    height: 100%;
    object-fit: fill;
    pointer-events: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .device-mockup {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const runtimeKey = '__deviceMockupRevealRuntime';
    if (window[runtimeKey]) {
      window[runtimeKey].mount();
      return;
    }

    const mockupSelector = '.device-mockup[data-device-mockup]';
    const initAttr = 'data-device-mockup-ready-init';
    const fallbackDelayMs = 1200;

    const markReady = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.dataset.ready === 'true') {
        return;
      }
      mockup.dataset.ready = 'true';
    };

    const initMockup = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.getAttribute(initAttr) === 'true') {
        return;
      }
      mockup.setAttribute(initAttr, 'true');

      const shell = mockup.querySelector('.device-mockup__shell');
      const media = mockup.querySelector('.device-mockup__media');
      let shellReady = !(shell instanceof HTMLImageElement);
      let mediaReady = !media;
      let settled = false;
      const cleanups = [];

      const settle = () => {
        if (settled) {
          return;
        }
        settled = true;
        cleanups.forEach((cleanup) => cleanup());
        markReady(mockup);
      };

      const trySettle = () => {
        if (shellReady && mediaReady) {
          settle();
        }
      };

      const bindOnce = (target, eventName, handler) => {
        target.addEventListener(eventName, handler, { once: true });
        cleanups.push(() => target.removeEventListener(eventName, handler));
      };

      if (shell instanceof HTMLImageElement) {
        shellReady = shell.complete && shell.naturalWidth > 0;
        if (!shellReady) {
          bindOnce(shell, 'load', () => {
            shellReady = true;
            trySettle();
          });
          bindOnce(shell, 'error', () => {
            shellReady = true;
            trySettle();
          });
        }
      }

      if (media instanceof HTMLImageElement) {
        mediaReady = media.complete && media.naturalWidth > 0;
        if (!mediaReady) {
          bindOnce(media, 'load', () => {
            mediaReady = true;
            trySettle();
          });
          bindOnce(media, 'error', () => {
            mediaReady = true;
            trySettle();
          });
        }
      } else if (media instanceof HTMLVideoElement) {
        mediaReady = media.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA;
        if (!mediaReady) {
          bindOnce(media, 'loadeddata', () => {
            mediaReady = true;
            trySettle();
          });
          bindOnce(media, 'error', () => {
            mediaReady = true;
            trySettle();
          });
        }
      }

      const fallbackTimer = window.setTimeout(() => {
        settle();
      }, fallbackDelayMs);
      cleanups.push(() => window.clearTimeout(fallbackTimer));

      trySettle();
    };

    const mount = () => {
      document.querySelectorAll(mockupSelector).forEach((mockup) => {
        initMockup(mockup);
      });
    };

    document.addEventListener('astro:page-load', mount);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }

    window[runtimeKey] = { mount };
  })();
</script>
