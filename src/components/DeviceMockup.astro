---

type DeviceKind = 'phone' | 'tablet';
type DeviceSize = 'default' | 'compact' | 'small';
type ScreenKind = 'image' | 'video';
type DeviceLoadPriority = 'critical' | 'lazy';

interface DeviceFramePreset {
  width: number;
  height: number;
  screen: {
    x: number;
    y: number;
    width: number;
    height: number;
    radius: number;
  };
}

interface DevicePreset {
  shellSrc: string;
  screenZ: number;
  shellZ: number;
  videoBleedPxBySize?: Partial<Record<DeviceSize, number>>;
  sizes: {
    default: DeviceFramePreset;
    compact: DeviceFramePreset;
    small?: DeviceFramePreset;
  };
}

interface ApertureRatios {
  left: number;
  right: number;
  top: number;
  bottom: number;
}

interface Props {
  device?: DeviceKind;
  size?: DeviceSize;
  screenKind: ScreenKind;
  screenSrc: string;
  screenAlt?: string;
  screenPoster?: string;
  priority?: DeviceLoadPriority;
  scale?: number;
  class?: string;
}

const {
  device = 'phone',
  size = 'default',
  screenKind,
  screenSrc,
  screenAlt,
  screenPoster,
  priority = 'lazy',
  scale,
  class: className = '',
} = Astro.props;

const frameFromAperture = (
  width: number,
  height: number,
  ratios: ApertureRatios,
  radius: number,
): DeviceFramePreset['screen'] => ({
  x: width * ratios.left,
  y: height * ratios.top,
  width: width * (1 - ratios.left - ratios.right),
  height: height * (1 - ratios.top - ratios.bottom),
  radius,
});

const phoneCompactApertureRatios: ApertureRatios = {
  left: 50 / 976,
  right: 48 / 976,
  top: 43 / 2004,
  bottom: 43 / 2004,
};

const phoneDefaultApertureRatios: ApertureRatios = {
  left: 50 / 976,
  right: 48 / 976,
  top: 43 / 2004,
  bottom: 43 / 2004,
};

const frameWithOverscan = (
  frame: DeviceFramePreset['screen'],
  overscan: number,
): DeviceFramePreset['screen'] => ({
  x: frame.x - overscan,
  y: frame.y - overscan,
  width: frame.width + overscan * 2,
  height: frame.height + overscan * 2,
  radius: frame.radius,
});

const presets: Record<DeviceKind, DevicePreset> = {
  phone: {
    shellSrc: '/media/gallery/device-shells/phone-shell.webp',
    screenZ: 1,
    shellZ: 2,
    videoBleedPxBySize: {
      small: 0,
    },
    sizes: {
      default: {
        width: 244,
        height: 501,
        screen: frameFromAperture(244, 501, phoneDefaultApertureRatios, 20),
      },
      compact: {
        width: 216,
        height: 443,
        screen: frameFromAperture(216, 443, phoneCompactApertureRatios, 20),
      },
      small: {
        width: 142.74,
        height: 293.085,
        screen: (() => {
          const base = frameFromAperture(142.74, 293.085, phoneDefaultApertureRatios, 12);
          return frameWithOverscan(base, 1);
        })(),
      },
    },
  },
  tablet: {
    shellSrc: '/media/gallery/device-shells/tablet-shell.webp',
    screenZ: 1,
    shellZ: 2,
    sizes: {
      default: {
        width: 296,
        height: 508,
        screen: {
          x: 11.5,
          y: 11.5,
          width: 273,
          height: 485,
          radius: 0,
        },
      },
      compact: {
        width: 258,
        height: 443,
        screen: {
          x: 10,
          y: 10,
          width: 238,
          height: 423,
          radius: 0,
        },
      },
    },
  },
};

const resolvedDevice: DeviceKind = device === 'tablet' ? 'tablet' : 'phone';
const requestedSize: DeviceSize = size === 'compact' || size === 'small' ? size : 'default';
const resolvedPriority: DeviceLoadPriority = priority === 'critical' ? 'critical' : 'lazy';
const resolvedScale =
  typeof scale === 'number' && Number.isFinite(scale) && scale > 0 ? scale : undefined;
const preset = presets[resolvedDevice];
const framePreset = preset.sizes[requestedSize] ?? preset.sizes.default;
const resolvedSize: DeviceSize = preset.sizes[requestedSize] ? requestedSize : 'default';
const resolvedVideoBleedPx =
  typeof preset.videoBleedPxBySize?.[resolvedSize] === 'number'
    ? (preset.videoBleedPxBySize?.[resolvedSize] as number)
    : 1;
const screenCalibrationMarker =
  resolvedDevice === 'phone'
    ? resolvedSize === 'compact'
      ? 'aperture-compact-v2-aa'
      : resolvedSize === 'small'
        ? 'aperture-small-v2-aa'
        : 'aperture-default-v1-aa'
    : undefined;
const mediaLoading = resolvedPriority === 'critical' ? 'eager' : 'lazy';
const mediaDecoding = resolvedPriority === 'critical' ? 'sync' : 'async';
const mediaFetchPriority = resolvedPriority === 'critical' ? 'high' : 'auto';
const videoPreload = resolvedPriority === 'critical' ? 'auto' : 'metadata';
const videoPlaybackPolicy = resolvedPriority === 'critical' ? 'always' : 'inview';
const composedClassName = ['device-mockup', `device-mockup--${resolvedDevice}`, className].filter(Boolean).join(' ');
const styleVars = [
  `--device-width: ${framePreset.width}px`,
  `--device-height: ${framePreset.height}px`,
  ...(typeof resolvedScale === 'number' ? [`--device-scale: ${resolvedScale}`] : []),
  `--screen-x: ${framePreset.screen.x}px`,
  `--screen-y: ${framePreset.screen.y}px`,
  `--screen-width: ${framePreset.screen.width}px`,
  `--screen-height: ${framePreset.screen.height}px`,
  `--screen-radius: ${framePreset.screen.radius}px`,
  `--video-bleed-px: ${resolvedVideoBleedPx}px`,
  `--screen-z: ${preset.screenZ}`,
  `--shell-z: ${preset.shellZ}`,
].join('; ');
---

<div
  class={composedClassName}
  style={styleVars}
  data-device-mockup
  data-device-priority={resolvedPriority}
  data-device-kind={resolvedDevice}
  data-device-media-kind={screenKind}
  data-device-media-src={screenSrc}
  data-device-media-poster={screenPoster ?? ''}
  data-device-size={resolvedSize}
  data-device-screen-calibration={screenCalibrationMarker}
  data-video-frame-ready={screenKind === 'video' ? 'false' : undefined}
  data-ready="false"
>
  <div class="device-mockup__screen" data-layer="screen">
    {
      screenKind === 'video' ? (
        <div class="device-mockup__video-bleed" data-device-video-bleed>
          <video
            class="device-mockup__media device-mockup__media--video"
            src={screenSrc}
            autoplay={resolvedPriority === 'critical' ? true : undefined}
            muted
            loop
            playsinline
            preload={videoPreload}
            fetchpriority={mediaFetchPriority}
            poster={screenPoster}
            data-video-playback={videoPlaybackPolicy}
            aria-hidden="true"
          />
          {
            screenPoster ? (
              <img
                class="device-mockup__video-poster"
                src={screenPoster}
                alt=""
                aria-hidden="true"
                loading={mediaLoading}
                decoding={mediaDecoding}
                fetchpriority={mediaFetchPriority}
              />
            ) : null
          }
        </div>
      ) : (
        <img
          class="device-mockup__media"
          src={screenSrc}
          alt={screenAlt ?? ''}
          loading={mediaLoading}
          decoding={mediaDecoding}
          fetchpriority={mediaFetchPriority}
        />
      )
    }
  </div>

  <img
    class="device-mockup__shell"
    src={preset.shellSrc}
    alt=""
    aria-hidden="true"
    loading={mediaLoading}
    decoding={mediaDecoding}
    fetchpriority={mediaFetchPriority}
  />
</div>

<style>
  .device-mockup {
    --device-scale: 1;
    --video-bleed-px: 1px;
    position: relative;
    width: calc(var(--device-width) * var(--device-scale, 1));
    height: calc(var(--device-height) * var(--device-scale, 1));
    max-width: 100%;
    isolation: isolate;
    opacity: 1;
    transition: opacity 0.16s ease;
  }

  .device-mockup[data-ready='false'] {
    opacity: 0;
  }

  .device-mockup__screen {
    position: absolute;
    top: calc(var(--screen-y) * var(--device-scale));
    left: calc(var(--screen-x) * var(--device-scale));
    width: calc(var(--screen-width) * var(--device-scale));
    height: calc(var(--screen-height) * var(--device-scale));
    z-index: var(--screen-z);
    overflow: hidden;
    border-radius: calc(var(--screen-radius) * var(--device-scale));
    background: var(--color-bg-darkened, #1a1a1a);
  }

  .device-mockup__media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .device-mockup__video-bleed {
    position: absolute;
    top: calc(var(--video-bleed-px) * -1);
    right: calc(var(--video-bleed-px) * -1);
    bottom: calc(var(--video-bleed-px) * -1);
    left: calc(var(--video-bleed-px) * -1);
    overflow: hidden;
    pointer-events: none;
  }

  .device-mockup__media--video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transform: none;
  }

  .device-mockup__video-poster {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.16s ease;
  }

  .device-mockup[data-video-frame-ready='true'] .device-mockup__video-poster {
    opacity: 0;
  }

  .device-mockup__shell {
    position: absolute;
    inset: 0;
    z-index: var(--shell-z);
    display: block;
    width: 100%;
    height: 100%;
    object-fit: fill;
    pointer-events: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .device-mockup {
      transition: none;
    }

    .device-mockup__video-poster {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const runtimeKey = '__deviceMockupRevealRuntime';
    const videoPlaybackRuntimeKey = '__managedVideoPlaybackRuntime';
    const warmVideoSrcsKey = '__deviceMockupWarmVideoSrcs';
    const warmVideoKeysKey = '__deviceMockupWarmVideoKeys';
    const warmedVideoSrcs =
      window[warmVideoSrcsKey] instanceof Set ? window[warmVideoSrcsKey] : new Set();
    const warmedVideoKeys =
      window[warmVideoKeysKey] instanceof Set ? window[warmVideoKeysKey] : new Set();
    window[warmVideoSrcsKey] = warmedVideoSrcs;
    window[warmVideoKeysKey] = warmedVideoKeys;

    const resolveVideoSrc = (media, mockup) => {
      if (media instanceof HTMLVideoElement) {
        if (typeof media.currentSrc === 'string' && media.currentSrc.length > 0) {
          return media.currentSrc;
        }
        const mediaSrc = media.getAttribute('src');
        if (typeof mediaSrc === 'string' && mediaSrc.length > 0) {
          return mediaSrc;
        }
      }
      return mockup?.dataset.deviceMediaSrc ?? '';
    };

    const resolveVideoPoster = (media, mockup) => {
      if (media instanceof HTMLVideoElement) {
        const poster = media.getAttribute('poster');
        if (typeof poster === 'string' && poster.length > 0) {
          return poster;
        }
      }
      return mockup?.dataset.deviceMediaPoster ?? '';
    };

    const buildVideoWarmKey = (mockup, media) => {
      if (!(mockup instanceof HTMLElement)) {
        return null;
      }
      const src = resolveVideoSrc(media, mockup);
      if (src.length === 0) {
        return null;
      }
      const deviceKind = mockup.dataset.deviceKind ?? 'phone';
      const size = mockup.dataset.deviceSize ?? 'default';
      const poster = resolveVideoPoster(media, mockup);
      return `${deviceKind}|${size}|${src}|${poster}`;
    };

    const markVideoWarm = (mockup, media) => {
      if (!(media instanceof HTMLVideoElement)) {
        return;
      }
      const src = resolveVideoSrc(media, mockup);
      if (src.length > 0) {
        warmedVideoSrcs.add(src);
      }
      const key = buildVideoWarmKey(mockup, media);
      if (key) {
        warmedVideoKeys.add(key);
      }
    };

    const isVideoWarm = (mockup, media) => {
      if (!(media instanceof HTMLVideoElement)) {
        return false;
      }
      const src = resolveVideoSrc(media, mockup);
      if (src.length > 0 && warmedVideoSrcs.has(src)) {
        return true;
      }
      const key = buildVideoWarmKey(mockup, media);
      return typeof key === 'string' && warmedVideoKeys.has(key);
    };

    const requestManagedVideoPlaybackSync = () => {
      const runtime = window[videoPlaybackRuntimeKey];
      if (runtime && typeof runtime.mount === 'function') {
        runtime.mount();
        if (typeof runtime.sync === 'function') {
          runtime.sync();
        }
        return;
      }
      window.requestAnimationFrame(() => {
        const deferredRuntime = window[videoPlaybackRuntimeKey];
        if (deferredRuntime && typeof deferredRuntime.mount === 'function') {
          deferredRuntime.mount();
          if (typeof deferredRuntime.sync === 'function') {
            deferredRuntime.sync();
          }
        }
      });
    };

    if (window[runtimeKey]) {
      requestManagedVideoPlaybackSync();
      window[runtimeKey].mount();
      return;
    }

    const mockupSelector = '.device-mockup[data-device-mockup]';
    const initAttr = 'data-device-mockup-ready-init';
    const frameReadyAttr = 'data-video-frame-ready';
    const fallbackDelayMs = 1200;

    const markReady = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.dataset.ready === 'true') {
        return;
      }
      mockup.dataset.ready = 'true';
    };

    const markVideoFramePending = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.dataset.deviceMediaKind !== 'video') {
        return;
      }
      mockup.setAttribute(frameReadyAttr, 'false');
    };

    const markVideoFrameReady = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.dataset.deviceMediaKind !== 'video') {
        return;
      }
      if (mockup.getAttribute(frameReadyAttr) === 'true') {
        return;
      }
      mockup.setAttribute(frameReadyAttr, 'true');
    };

    const initMockup = (mockup) => {
      if (!(mockup instanceof HTMLElement)) {
        return;
      }
      if (mockup.getAttribute(initAttr) === 'true') {
        return;
      }
      mockup.setAttribute(initAttr, 'true');

      const shell = mockup.querySelector('.device-mockup__shell');
      const media = mockup.querySelector('.device-mockup__media');
      let shellReady = !(shell instanceof HTMLImageElement);
      let mediaReady = !media;
      let settled = false;
      const cleanups = [];

      const settle = () => {
        if (settled) {
          return;
        }
        settled = true;
        cleanups.forEach((cleanup) => cleanup());
        markReady(mockup);
      };

      const trySettle = () => {
        if (shellReady && mediaReady) {
          settle();
        }
      };

      const bindOnce = (target, eventName, handler) => {
        target.addEventListener(eventName, handler, { once: true });
        cleanups.push(() => target.removeEventListener(eventName, handler));
      };

      if (shell instanceof HTMLImageElement) {
        shellReady = shell.complete && shell.naturalWidth > 0;
        if (!shellReady) {
          bindOnce(shell, 'load', () => {
            shellReady = true;
            trySettle();
          });
          bindOnce(shell, 'error', () => {
            shellReady = true;
            trySettle();
          });
        }
      }

      if (media instanceof HTMLImageElement) {
        mediaReady = media.complete && media.naturalWidth > 0;
        if (!mediaReady) {
          bindOnce(media, 'load', () => {
            mediaReady = true;
            trySettle();
          });
          bindOnce(media, 'error', () => {
            mediaReady = true;
            trySettle();
          });
        }
      } else if (media instanceof HTMLVideoElement) {
        markVideoFramePending(mockup);
        const frameReadyNow = media.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA;
        if (frameReadyNow) {
          markVideoFrameReady(mockup);
        } else {
          let firstFrameResolved = false;
          const resolveFirstFrame = () => {
            if (firstFrameResolved) {
              return;
            }
            firstFrameResolved = true;
            markVideoFrameReady(mockup);
          };
          if (typeof media.requestVideoFrameCallback === 'function') {
            const callbackId = media.requestVideoFrameCallback(() => {
              resolveFirstFrame();
            });
            cleanups.push(() => {
              if (typeof media.cancelVideoFrameCallback === 'function') {
                media.cancelVideoFrameCallback(callbackId);
              }
            });
          }
          bindOnce(media, 'loadeddata', resolveFirstFrame);
          bindOnce(media, 'canplay', resolveFirstFrame);
        }
        mediaReady =
          media.readyState >= HTMLMediaElement.HAVE_METADATA ||
          isVideoWarm(mockup, media);
        if (media.readyState >= HTMLMediaElement.HAVE_METADATA) {
          markVideoWarm(mockup, media);
        }
        if (!mediaReady) {
          bindOnce(media, 'loadedmetadata', () => {
            mediaReady = true;
            markVideoWarm(mockup, media);
            trySettle();
          });
          bindOnce(media, 'loadeddata', () => {
            mediaReady = true;
            markVideoWarm(mockup, media);
            trySettle();
          });
          bindOnce(media, 'canplay', () => {
            trySettle();
          });
          bindOnce(media, 'error', () => {
            mediaReady = true;
            trySettle();
          });
        }
      }

      const fallbackTimer = window.setTimeout(() => {
        settle();
      }, fallbackDelayMs);
      cleanups.push(() => window.clearTimeout(fallbackTimer));

      trySettle();
    };

    const mount = () => {
      requestManagedVideoPlaybackSync();
      document.querySelectorAll(mockupSelector).forEach((mockup) => {
        initMockup(mockup);
      });
    };

    document.addEventListener('astro:page-load', mount);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }

    window[runtimeKey] = { mount };
  })();
</script>
