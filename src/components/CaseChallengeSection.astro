---
import DeviceMockup from './DeviceMockup.astro';
import type { InViewPreset } from '../data/case-details/types';

export type CaseChallengeScreen = {
  src: string;
  alt: string;
};

export type CaseChallengeNote = {
  id: string;
  text: string;
  left: number;
  top: number;
  width: number;
  arrowSrc: string;
  arrowLeft: number;
  arrowTop: number;
  arrowWidth: number;
  arrowHeight: number;
};

interface Props {
  title: string;
  columns: [string, string];
  device: 'phone' | 'tablet';
  screen: CaseChallengeScreen;
  notes: CaseChallengeNote[];
  inViewPreset?: InViewPreset;
  class?: string;
}

const { title, columns, device, screen, notes, inViewPreset, class: className = '' } = Astro.props as Props;
const rootClassName = ['case-challenge-section', className].filter(Boolean).join(' ');
const resolvedInViewPreset =
  inViewPreset === 'appear-v1' ||
  inViewPreset === 'appear-stagger-v1' ||
  inViewPreset === 'appear-stagger-dynamic-v1'
    ? inViewPreset
    : undefined;
const resolvedDevice = device === 'tablet' ? 'tablet' : 'phone';
const titleIdBase = title
  .toLowerCase()
  .trim()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-+|-+$/g, '');
const titleId = `case-challenge-title-${titleIdBase || 'section'}`;
---

<section class={rootClassName} aria-labelledby={titleId} data-motion-inview={resolvedInViewPreset}>
  <div class="case-challenge-top">
    <h2 id={titleId} class="type-t3 case-challenge-title">{title}</h2>

    <div class="case-challenge-columns">
      <p class="type-body case-challenge-column case-challenge-column--first">{columns[0]}</p>
      <p class="type-body case-challenge-column case-challenge-column--second">{columns[1]}</p>
    </div>
  </div>

  <div class="case-challenge-scene-wrap">
    <div class="case-challenge-scene" aria-label={`${title} details`}>
      <div class:list={['case-challenge-device', `case-challenge-device--${resolvedDevice}`]}>
        <DeviceMockup
          device={resolvedDevice}
          screenKind="image"
          screenSrc={screen.src}
          screenAlt={screen.alt}
          priority="critical"
        />
      </div>

      {
        notes.map((note) => (
          <>
            <p
              class="type-description-medium case-challenge-note"
              data-note-id={note.id}
              style={`--case-note-left:${note.left}px;--case-note-top:${note.top}px;--case-note-width:${note.width}px;`}
            >
              {note.text}
            </p>

            <img
              class="case-challenge-arrow"
              src={note.arrowSrc}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              style={`--case-arrow-left:${note.arrowLeft}px;--case-arrow-top:${note.arrowTop}px;--case-arrow-width:${note.arrowWidth}px;--case-arrow-height:${note.arrowHeight}px;`}
            />
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  .case-challenge-section {
    width: 100%;
    min-height: 740px;
    display: flex;
    flex-direction: column;
    gap: 72px;
  }

  .case-challenge-top {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .case-challenge-title {
    width: 100%;
    margin: 0;
    color: var(--color-text-default);
  }

  .case-challenge-columns {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }

  .case-challenge-column {
    margin: 0;
    color: var(--color-text-default);
  }

  .case-challenge-column--first {
    width: 312px;
    flex: 0 0 312px;
  }

  .case-challenge-column--second {
    width: 313px;
    flex: 0 0 313px;
  }

  .case-challenge-scene-wrap {
    --case-challenge-scene-scale: min(1, calc((100vw - 2rem) / 816));
    width: 100%;
    height: calc(501px * var(--case-challenge-scene-scale));
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .case-challenge-scene {
    position: relative;
    width: 816px;
    height: 501px;
    transform-origin: top center;
    transform: scale(var(--case-challenge-scene-scale));
  }

  .case-challenge-device {
    position: absolute;
    top: 0;
  }

  .case-challenge-device--phone {
    left: 286px;
    width: 244px;
    height: 501px;
  }

  .case-challenge-device--tablet {
    left: 260px;
    width: 296px;
    height: 508px;
  }

  .case-challenge-device :global(.device-mockup) {
    --device-scale: 1;
  }

  .case-challenge-note {
    position: absolute;
    margin: 0;
    left: var(--case-note-left);
    top: var(--case-note-top);
    width: var(--case-note-width);
    color: var(--color-text-tertiary);
  }

  .case-challenge-arrow {
    position: absolute;
    left: var(--case-arrow-left);
    top: var(--case-arrow-top);
    width: var(--case-arrow-width);
    height: var(--case-arrow-height);
    display: block;
    pointer-events: none;
    user-select: none;
  }

  @media (min-width: 848px) {
    .case-challenge-scene-wrap {
      --case-challenge-scene-scale: 1;
      height: 501px;
    }
  }

  @media (max-width: 847px) {
    .case-challenge-columns {
      flex-direction: column;
      gap: 16px;
    }

    .case-challenge-column--first,
    .case-challenge-column--second {
      width: 100%;
      max-width: none;
      flex: 1 1 auto;
    }
  }
</style>
