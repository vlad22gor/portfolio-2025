---
import DeviceMockup from './DeviceMockup.astro';
import ThemedSvgIcon from './ThemedSvgIcon.astro';
import type { InViewPreset } from '../data/case-details/types';

export type CaseChallengeScreen = {
  src: string;
  alt: string;
};

export type CaseChallengeNote = {
  id: string;
  text: string;
  left: number;
  top: number;
  width: number;
  arrowSrc: string;
  arrowLeft: number;
  arrowTop: number;
  arrowWidth: number;
  arrowHeight: number;
};

export type CaseChallengeMobileDeviceGeometry = {
  left: number;
  top: number;
  width: number;
  height: number;
  screenLeft: number;
  screenRight: number;
};

export type CaseChallengeMobileNote = {
  id: string;
  text: string;
  side: 'left' | 'right';
  top: number;
  width: number;
  textOffsetFromAnchor: number;
  arrowSrc: string;
  arrowTop: number;
  arrowWidth: number;
  arrowHeight: number;
  arrowOffsetFromAnchor: number;
};

export type CaseChallengeMobileData = {
  sceneWidth: number;
  sceneHeight: number;
  deviceSize?: 'default' | 'compact';
  device: CaseChallengeMobileDeviceGeometry;
  notes: CaseChallengeMobileNote[];
};

interface Props {
  title: string;
  columns: [string, string];
  device: 'phone' | 'tablet';
  screen: CaseChallengeScreen;
  notes: CaseChallengeNote[];
  mobile?: CaseChallengeMobileData;
  inViewPreset?: InViewPreset;
  class?: string;
}

const { title, columns, device, screen, notes, mobile, inViewPreset, class: className = '' } = Astro.props as Props;
const rootClassName = ['case-challenge-section', className].filter(Boolean).join(' ');
const resolvedInViewPreset =
  inViewPreset === 'appear-v1' ||
  inViewPreset === 'appear-stagger-v1' ||
  inViewPreset === 'appear-stagger-dynamic-v1'
    ? inViewPreset
    : undefined;
const resolvedDevice = device === 'tablet' ? 'tablet' : 'phone';
const resolvedMobile =
  mobile &&
  Number.isFinite(mobile.sceneWidth) &&
  Number.isFinite(mobile.sceneHeight) &&
  mobile.sceneWidth > 0 &&
  mobile.sceneHeight > 0 &&
  mobile.notes.length > 0
    ? mobile
    : null;
const resolvedMobileDeviceSize: 'default' | 'compact' =
  resolvedMobile?.deviceSize === 'compact' ? 'compact' : 'default';
const MOBILE_CHALLENGE_NOTE_WIDTH_PX = 184;
const toPercent = (value: number, total: number): string => `${(value / total) * 100}%`;
const mobileSceneStyle = resolvedMobile
  ? `--case-mobile-scene-width:${resolvedMobile.sceneWidth}px;--case-mobile-scene-height:${resolvedMobile.sceneHeight}px;--case-mobile-scene-height-ratio:${resolvedMobile.sceneHeight / resolvedMobile.sceneWidth};--case-mobile-scene-max-width:480px;--case-mobile-device-left:${toPercent(resolvedMobile.device.left, resolvedMobile.sceneWidth)};--case-mobile-device-top:${toPercent(resolvedMobile.device.top, resolvedMobile.sceneHeight)};--case-mobile-device-width:${toPercent(resolvedMobile.device.width, resolvedMobile.sceneWidth)};--case-mobile-device-height:${toPercent(resolvedMobile.device.height, resolvedMobile.sceneHeight)};--case-mobile-screen-left:${toPercent(resolvedMobile.device.screenLeft, resolvedMobile.sceneWidth)};--case-mobile-screen-right:${toPercent(resolvedMobile.device.screenRight, resolvedMobile.sceneWidth)};`
  : '';
const mobileNotes =
  resolvedMobile?.notes.map((note) => ({
    ...note,
    textTopPercent: toPercent(note.top, resolvedMobile.sceneHeight),
    textWidthPx: `${MOBILE_CHALLENGE_NOTE_WIDTH_PX}px`,
    textOffsetPercent: toPercent(note.textOffsetFromAnchor, resolvedMobile.sceneWidth),
    arrowTopPercent: toPercent(note.arrowTop, resolvedMobile.sceneHeight),
    arrowWidthPercent: toPercent(note.arrowWidth, resolvedMobile.sceneWidth),
    arrowHeightPercent: toPercent(note.arrowHeight, resolvedMobile.sceneHeight),
    arrowOffsetPercent: toPercent(note.arrowOffsetFromAnchor, resolvedMobile.sceneWidth),
  })) ?? [];
const titleIdBase = title
  .toLowerCase()
  .trim()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-+|-+$/g, '');
const titleId = `case-challenge-title-${titleIdBase || 'section'}`;
---

<section class={rootClassName} aria-labelledby={titleId} data-motion-inview={resolvedInViewPreset}>
  <div class="case-challenge-top">
    <h2 id={titleId} class="type-t3 case-challenge-title">{title}</h2>

    <div class="case-challenge-columns">
      <p class="type-body case-challenge-column case-challenge-column--first">{columns[0]}</p>
      <p class="type-body case-challenge-column case-challenge-column--second">{columns[1]}</p>
    </div>
  </div>

  <div class="case-challenge-scene-wrap case-challenge-scene-wrap--desktop">
    <div class="case-challenge-scene" aria-label={`${title} details`}>
      <div class:list={['case-challenge-device', `case-challenge-device--${resolvedDevice}`]}>
        <DeviceMockup
          device={resolvedDevice}
          screenKind="image"
          screenSrc={screen.src}
          screenAlt={screen.alt}
          priority="critical"
        />
      </div>

      {
        notes.map((note) => (
          <>
            <p
              class="type-description-medium case-challenge-note"
              data-note-id={note.id}
              style={`--case-note-left:${note.left}px;--case-note-top:${note.top}px;--case-note-width:${note.width}px;`}
            >
              {note.text}
            </p>

            <ThemedSvgIcon
              class="case-challenge-arrow"
              src={note.arrowSrc}
              aria-hidden="true"
              style={`--case-arrow-left:${note.arrowLeft}px;--case-arrow-top:${note.arrowTop}px;--case-arrow-width:${note.arrowWidth}px;--case-arrow-height:${note.arrowHeight}px;`}
            />
          </>
        ))
      }
    </div>
  </div>

  {
    resolvedMobile && (
      <div
        class="case-challenge-scene-wrap case-challenge-scene-wrap--mobile"
        style={mobileSceneStyle}
      >
        <div class="case-challenge-scene-viewport case-challenge-scene-viewport--mobile">
          <div class="case-challenge-scene case-challenge-scene--mobile" aria-label={`${title} details mobile`}>
            <div class="case-challenge-device case-challenge-device--mobile">
              <DeviceMockup
                device={resolvedDevice}
                size={resolvedMobileDeviceSize}
                screenKind="image"
                screenSrc={screen.src}
                screenAlt={screen.alt}
                priority="lazy"
              />
            </div>

            {mobileNotes.map((note) => (
              <>
                <p
                  class="type-description-medium case-challenge-mobile-note"
                  data-note-id={note.id}
                  data-mobile-anchor-side={note.side}
                  style={`--case-mobile-note-top:${note.textTopPercent};--case-mobile-note-width:${note.textWidthPx};--case-mobile-note-offset:${note.textOffsetPercent};`}
                >
                  {note.text}
                </p>

                <ThemedSvgIcon
                  class="case-challenge-mobile-arrow"
                  src={note.arrowSrc}
                  color="var(--color-ink-bg)"
                  aria-hidden="true"
                  data-note-id={note.id}
                  data-mobile-anchor-side={note.side}
                  style={`--case-mobile-arrow-top:${note.arrowTopPercent};--case-mobile-arrow-width:${note.arrowWidthPercent};--case-mobile-arrow-height:${note.arrowHeightPercent};--case-mobile-arrow-offset:${note.arrowOffsetPercent};`}
                />
              </>
            ))}
          </div>
        </div>
      </div>
    )
  }
</section>

<style>
  .case-challenge-section {
    width: 100%;
    min-height: 740px;
    display: flex;
    flex-direction: column;
    gap: 72px;
  }

  .case-challenge-top {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .case-challenge-title {
    width: 100%;
    margin: 0;
    color: var(--color-text-default);
  }

  .case-challenge-columns {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }

  .case-challenge-column {
    margin: 0;
    color: var(--color-text-default);
  }

  .case-challenge-column--first {
    width: 312px;
    flex: 0 0 312px;
  }

  .case-challenge-column--second {
    width: 313px;
    flex: 0 0 313px;
  }

  .case-challenge-scene-wrap {
    --case-challenge-scene-scale: min(1, calc((100vw - 2rem) / 816));
    width: 100%;
    height: calc(501px * var(--case-challenge-scene-scale));
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .case-challenge-scene {
    position: relative;
    width: 816px;
    height: 501px;
    transform-origin: top center;
    transform: scale(var(--case-challenge-scene-scale));
  }

  .case-challenge-scene-wrap--mobile {
    display: none;
  }

  .case-challenge-device {
    position: absolute;
    top: 0;
  }

  .case-challenge-device--phone {
    left: 286px;
    width: 244px;
    height: 501px;
  }

  .case-challenge-device--tablet {
    left: 260px;
    width: 296px;
    height: 508px;
  }

  .case-challenge-device :global(.device-mockup) {
    --device-scale: 1;
  }

  .case-challenge-note {
    position: absolute;
    margin: 0;
    left: var(--case-note-left);
    top: var(--case-note-top);
    width: var(--case-note-width);
    color: var(--color-text-tertiary);
  }

  .case-challenge-arrow {
    position: absolute;
    left: var(--case-arrow-left);
    top: var(--case-arrow-top);
    width: var(--case-arrow-width);
    height: var(--case-arrow-height);
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .case-challenge-mobile-note,
  .case-challenge-mobile-arrow {
    display: none;
  }

  @media (min-width: 848px) {
    .case-challenge-scene-wrap {
      --case-challenge-scene-scale: 1;
      height: 501px;
    }
  }

  @media (max-width: 847px) {
    .case-challenge-columns {
      flex-direction: column;
      gap: 16px;
    }

    .case-challenge-column--first,
    .case-challenge-column--second {
      width: 100%;
      max-width: none;
      flex: 1 1 auto;
    }
  }

  @media (max-width: 767px) {
    .case-challenge-section {
      min-height: 0;
      height: auto;
      gap: 72px;
    }

    .case-challenge-top {
      gap: 12px;
      padding-inline: 10px;
      box-sizing: border-box;
    }

    .case-challenge-columns {
      gap: 10px;
    }

    .case-challenge-scene-wrap--desktop {
      display: none;
    }

    .case-challenge-scene-wrap--mobile {
      --case-mobile-scene-available-width: calc(100vw - 40px);
      --case-mobile-scene-current-width: min(
        var(--case-mobile-scene-width, 350px),
        var(--case-mobile-scene-available-width)
      );
      --case-mobile-scene-scale: calc(var(--case-mobile-scene-current-width) / var(--case-mobile-scene-width, 350px));
      display: flex;
      width: 100%;
      min-width: 0;
      align-items: flex-start;
      justify-content: center;
      overflow: visible;
    }

    .case-challenge-scene-viewport--mobile {
      position: relative;
      width: var(--case-mobile-scene-current-width);
      max-width: 100%;
      height: calc(var(--case-mobile-scene-current-width) * var(--case-mobile-scene-height-ratio));
      margin-inline: auto;
      overflow: visible;
    }

    .case-challenge-scene--mobile {
      width: var(--case-mobile-scene-width, 350px);
      height: var(--case-mobile-scene-height, 823px);
      transform: scale(var(--case-mobile-scene-scale, 1));
      transform-origin: top left;
    }

    .case-challenge-device--mobile {
      left: var(--case-mobile-device-left);
      top: var(--case-mobile-device-top);
      width: var(--case-mobile-device-width);
      height: var(--case-mobile-device-height);
    }

    .case-challenge-device--mobile :global(.device-mockup) {
      --device-scale: 1;
    }

    .case-challenge-mobile-note {
      position: absolute;
      top: var(--case-mobile-note-top);
      width: var(--case-mobile-note-width);
      margin: 0;
      color: var(--color-text-tertiary);
      display: block;
    }

    .case-challenge-mobile-note[data-mobile-anchor-side='left'] {
      left: calc(var(--case-mobile-screen-left) + var(--case-mobile-note-offset));
    }

    .case-challenge-mobile-note[data-mobile-anchor-side='right'] {
      left: calc(var(--case-mobile-screen-right) + var(--case-mobile-note-offset));
    }

    .case-challenge-mobile-arrow {
      position: absolute;
      top: var(--case-mobile-arrow-top);
      width: var(--case-mobile-arrow-width);
      height: var(--case-mobile-arrow-height);
      display: block;
      pointer-events: none;
      user-select: none;
    }

    .case-challenge-mobile-arrow[data-mobile-anchor-side='left'] {
      left: calc(var(--case-mobile-screen-left) + var(--case-mobile-arrow-offset));
    }

    .case-challenge-mobile-arrow[data-mobile-anchor-side='right'] {
      left: calc(var(--case-mobile-screen-right) + var(--case-mobile-arrow-offset));
    }
  }
</style>
