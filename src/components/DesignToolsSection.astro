---
import QuantizedWave from './QuantizedWave.astro';
---

<section class="design-tools-section" aria-labelledby="design-tools-title" data-motion-inview="appear-v1">
  <div class="design-tools-top">
    <h2 id="design-tools-title" class="design-tools-title type-t2">design stack and craft</h2>
    <div class="design-tools-copy-wrap">
      <p class="design-tools-copy type-body">
        Beyond Figma, I work across 2D/3D graphics and motion, and use AI tools to explore visuals and interface
        ideas quickly
      </p>
    </div>
  </div>

  <div class="design-tools-bottom" aria-label="Design tools labels and dividers">
    <div class="design-tools-label-row">
      <p class="design-tools-label type-t6 design-tools-col-5" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="0">
        Figma
      </p>
    </div>
    <div class="design-tools-divider-row">
      <QuantizedWave class="design-tools-divider design-tools-wave-span-1" size="small" fit="cover" align="right" minCircles={1} />
    </div>

    <div class="design-tools-label-row">
      <p class="design-tools-label type-t6 design-tools-col-4" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="0">
        Rive
      </p>
    </div>
    <div class="design-tools-divider-row">
      <QuantizedWave class="design-tools-divider design-tools-wave-span-2" size="small" fit="cover" align="right" minCircles={1} />
    </div>

    <div class="design-tools-label-row">
      <p class="design-tools-label type-t6 design-tools-col-3" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="0">
        After Effects
      </p>
      <p class="design-tools-label type-t6 design-tools-col-5" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="1">
        Cinema 4D
      </p>
    </div>
    <div class="design-tools-divider-row">
      <QuantizedWave class="design-tools-divider design-tools-wave-span-3" size="small" fit="cover" align="right" minCircles={1} />
    </div>

    <div class="design-tools-label-row">
      <p class="design-tools-label type-t6 design-tools-col-2" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="0">
        Midjourney
      </p>
      <p class="design-tools-label type-t6 design-tools-col-4" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="1">
        Nano Banana 2
      </p>
    </div>
    <div class="design-tools-divider-row">
      <QuantizedWave class="design-tools-divider design-tools-wave-span-4" size="small" fit="cover" align="right" minCircles={1} />
    </div>

    <div class="design-tools-label-row">
      <p class="design-tools-label type-t6 design-tools-col-1" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="0">
        Codex App
      </p>
      <p class="design-tools-label type-t6 design-tools-col-3" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="1">
        Xcode
      </p>
      <p class="design-tools-label type-t6 design-tools-col-5" data-motion-inview="design-tools-label-char-v1" data-motion-row-index="2">
        Perplexity
      </p>
    </div>
    <div class="design-tools-divider-row">
      <QuantizedWave class="design-tools-divider design-tools-wave-span-5" size="small" fit="cover" align="right" minCircles={1} />
    </div>
  </div>
</section>
