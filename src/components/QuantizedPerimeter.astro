---
interface Props {
  class?: string;
  shape?: 'rectangle' | 'circle';
  edgePattern?: 'scallop' | 'totem';
  edges?: 'all' | 'top';
  fit?: 'contain' | 'cover';
  step?: number;
  minCols?: number;
  minRows?: number;
  minLobes?: number;
  clampLines?: number;
  label?: string;
  bg?: string;
  pad?: string;
  waveAmplitudeRatio?: number;
  waveTension?: number;
  hoverMorph?: boolean;
  hoverMorphPreset?: 'default' | 'strong';
  hoverWaveAmplitudeDelta?: number;
  hoverWaveTensionDelta?: number;
  /** @deprecated kept for backward compatibility; ignored by single-type param animation */
  hoverMorphTo?: 'scallop' | 'totem';
  morphSpringDuration?: number;
  morphSpringBounce?: number;
  clipContentToShape?: boolean;
  exportShapeMask?: boolean;
  outlineEnabled?: boolean;
  outlineMode?: 'alpha' | 'geometric';
  outlinePlacement?: 'center' | 'outside';
  outlineWidth?: number;
  outlineColor?: string;
  outlineOpacity?: number;
  inViewPreset?: 'appear-v1' | 'appear-stagger-v1' | 'appear-stagger-dynamic-v1';
  'data-motion-stage-item'?: string;
  'data-motion-stagger-index'?: string;
  'data-motion-stage-side'?: 'left' | 'right';
}

const {
  class: className = '',
  shape = 'rectangle',
  edgePattern = 'scallop',
  edges = 'all',
  fit = 'contain',
  step = 48,
  minCols = 12,
  minRows = 8,
  minLobes = 8,
  clampLines = 4,
  label = 'Quantized perimeter surface',
  bg,
  pad,
  waveAmplitudeRatio = 0.28,
  waveTension = 0.5,
  hoverMorph = false,
  hoverMorphPreset = 'default',
  hoverWaveAmplitudeDelta,
  hoverWaveTensionDelta,
  hoverMorphTo = 'totem',
  morphSpringDuration = 1.05,
  morphSpringBounce = 0.24,
  clipContentToShape = false,
  exportShapeMask = false,
  outlineEnabled = false,
  outlineMode = 'alpha',
  outlinePlacement = 'center',
  outlineWidth,
  outlineColor,
  outlineOpacity,
  inViewPreset,
  'data-motion-stage-item': motionStageItem,
  'data-motion-stagger-index': motionStaggerIndex,
  'data-motion-stage-side': motionStageSide,
} = Astro.props;

const resolvedShape = shape === 'circle' ? 'circle' : 'rectangle';
const resolvedPattern = edgePattern === 'totem' ? 'totem' : 'scallop';
const resolvedEdges = edges === 'top' ? 'top' : 'all';
const resolvedFit = fit === 'cover' ? 'cover' : 'contain';
const resolvedHoverMorphPreset = hoverMorphPreset === 'strong' ? 'strong' : 'default';
const resolvedOutlineMode = outlineMode === 'geometric' ? 'geometric' : 'alpha';
const resolvedOutlinePlacement = outlinePlacement === 'outside' ? 'outside' : 'center';
// Deprecated dataset for backward compatibility; runtime ignores target pattern now.
const resolvedHoverMorphTo = hoverMorphTo === 'scallop' ? 'scallop' : 'totem';
const resolvedHoverAnimationEnabled =
  hoverMorph && resolvedShape === 'rectangle' && (resolvedPattern === 'totem' || resolvedPattern === 'scallop');
const legacyRectangleEdges = resolvedEdges === 'top' ? 'top' : 'all';
const styleParts = [`--scallop-line-clamp: ${clampLines};`];

if (typeof bg === 'string' && bg.trim()) {
  styleParts.push(`--scallop-bg: ${bg};`);
}

if (typeof pad === 'string' && pad.trim()) {
  styleParts.push(`--scallop-pad: ${pad};`);
}

if (typeof outlineWidth === 'number' && Number.isFinite(outlineWidth) && outlineWidth >= 0) {
  styleParts.push(`--perimeter-outline-width: ${outlineWidth}px;`);
}

if (typeof outlineColor === 'string' && outlineColor.trim()) {
  styleParts.push(`--perimeter-outline-color: ${outlineColor};`);
}

if (typeof outlineOpacity === 'number' && Number.isFinite(outlineOpacity)) {
  styleParts.push(`--perimeter-outline-opacity: ${outlineOpacity};`);
}

const rootStyle = styleParts.join(' ');
const resolvedInViewPreset =
  inViewPreset === 'appear-v1' ||
  inViewPreset === 'appear-stagger-v1' ||
  inViewPreset === 'appear-stagger-dynamic-v1'
    ? inViewPreset
    : undefined;
---

<div
  class={`quantized-perimeter quantized-scallop ${className}`.trim()}
  data-quantized-perimeter
  data-perimeter-shape={resolvedShape}
  data-perimeter-edge-pattern={resolvedPattern}
  data-perimeter-edges={resolvedEdges}
  data-perimeter-fit={resolvedFit}
  data-perimeter-step={String(step)}
  data-perimeter-min-cols={String(minCols)}
  data-perimeter-min-rows={String(minRows)}
  data-perimeter-min-lobes={String(minLobes)}
  data-perimeter-wave-amplitude-ratio={String(waveAmplitudeRatio)}
  data-perimeter-wave-tension={String(waveTension)}
  data-perimeter-hover-morph={hoverMorph ? 'true' : 'false'}
  data-perimeter-hover-morph-preset={resolvedHoverMorphPreset}
  data-perimeter-hover-wave-amplitude-delta={typeof hoverWaveAmplitudeDelta === 'number' ? String(hoverWaveAmplitudeDelta) : undefined}
  data-perimeter-hover-wave-tension-delta={typeof hoverWaveTensionDelta === 'number' ? String(hoverWaveTensionDelta) : undefined}
  data-perimeter-hover-morph-to={resolvedHoverMorphTo}
  data-perimeter-morph-spring-duration={String(morphSpringDuration)}
  data-perimeter-morph-spring-bounce={String(morphSpringBounce)}
  data-perimeter-clip-content-to-shape={clipContentToShape ? 'true' : 'false'}
  data-perimeter-export-shape-mask={exportShapeMask ? 'true' : 'false'}
  data-perimeter-outline-enabled={outlineEnabled ? 'true' : 'false'}
  data-perimeter-outline-mode={resolvedOutlineMode}
  data-perimeter-outline-placement={resolvedOutlinePlacement}
  data-quantized-scallop
  data-scallop-shape={resolvedShape}
  data-scallop-rectangle-edges={legacyRectangleEdges}
  data-scallop-step={String(step)}
  data-scallop-min-cols={String(minCols)}
  data-scallop-min-rows={String(minRows)}
  data-scallop-min-lobes={String(minLobes)}
  data-motion-inview={resolvedInViewPreset}
  data-motion-stage-item={motionStageItem !== undefined ? '' : undefined}
  data-motion-stagger-index={motionStaggerIndex}
  data-motion-stage-side={motionStageSide}
  style={rootStyle}
  aria-label={label}
  tabindex={resolvedHoverAnimationEnabled ? '0' : undefined}
>
  <svg class="scallop-frame" viewBox="0 0 1 1" preserveAspectRatio="none" aria-hidden="true" focusable="false"></svg>
  <svg
    class="scallop-outline-frame"
    viewBox="0 0 1 1"
    preserveAspectRatio="none"
    aria-hidden="true"
    focusable="false"
  ></svg>
  <div class="scallop-content">
    <slot />
  </div>
</div>

<script>
  import { animate } from 'motion';
  import {
    createLifecycle,
    getOrCreateWindowRuntime,
    getWindowRuntime,
    onAstroPageLoad,
    readDataBool,
    readDataEnum,
    readDataInt,
    readDataNumber,
  } from '../lib/runtime';

  (() => {
    const runtimeKey = '__quantizedPerimeterRuntime';
    const existingRuntime = getWindowRuntime(runtimeKey);
    if (existingRuntime) {
      existingRuntime.mountNewRoots({ scheduleExisting: false });
      return;
    }

    const lifecycle = createLifecycle();
    const runtime = {
      roots: new Set(),
      states: new WeakMap(),
    };
    let outlineIdCounter = 0;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const isLocalDebugHost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';

    const readNumber = (value, fallback) => {
      const parsed = Number.parseFloat(value);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const clampInt = (value, min) => Math.max(min, Math.floor(value));
    const clamp01 = (value) => Math.max(0, Math.min(1, value));
    const round3 = (value) => Math.round(value * 1000) / 1000;
    const lerp = (from, to, progress) => from + (to - from) * progress;

    const parseAbsoluteSize = (value) => {
      if (typeof value !== 'string') {
        return null;
      }
      const normalized = value.trim().toLowerCase();
      if (!normalized || normalized === 'auto' || normalized === 'none') {
        return null;
      }
      if (
        normalized.includes('%') ||
        normalized.includes('calc(') ||
        normalized.includes('min(') ||
        normalized.includes('max(') ||
        normalized.includes('clamp(') ||
        normalized.includes('fit-content') ||
        normalized.includes('min-content') ||
        normalized.includes('max-content')
      ) {
        return null;
      }
      const absoluteMatch = normalized.match(/^(-?\d*\.?\d+)(px)?$/);
      if (!absoluteMatch) {
        return null;
      }
      const parsed = Number.parseFloat(absoluteMatch[1]);
      return Number.isFinite(parsed) ? parsed : null;
    };

    const resolveFixedAxisSize = (computedStyle, minProp, maxProp) => {
      const minSize = parseAbsoluteSize(computedStyle[minProp]);
      const maxRaw = computedStyle[maxProp];
      const maxSize = parseAbsoluteSize(maxRaw);
      if (
        minSize !== null &&
        maxSize !== null &&
        minSize > 0 &&
        maxSize > 0 &&
        Math.abs(minSize - maxSize) < 0.5
      ) {
        return Math.floor(minSize);
      }
      return 0;
    };

    const resolveAvailableSize = (root, parent, step) => {
      const safeStep = Math.max(1, Math.floor(step));
      const rootRect = root.getBoundingClientRect();
      const rootWidth = Math.floor(rootRect.width);
      const rootHeight = Math.floor(rootRect.height);
      const parentComputedStyle = window.getComputedStyle(parent);
      const parentPaddingX =
        readNumber(parentComputedStyle.paddingLeft, 0) + readNumber(parentComputedStyle.paddingRight, 0);
      const parentPaddingY =
        readNumber(parentComputedStyle.paddingTop, 0) + readNumber(parentComputedStyle.paddingBottom, 0);
      const parentWidth = Math.max(1, Math.floor(parent.clientWidth - parentPaddingX));
      const parentHeight = Math.max(1, Math.floor(parent.clientHeight - parentPaddingY));
      const rootComputedStyle = window.getComputedStyle(root);
      const fixedWidth = resolveFixedAxisSize(rootComputedStyle, 'minWidth', 'maxWidth');
      const fixedHeight = resolveFixedAxisSize(rootComputedStyle, 'minHeight', 'maxHeight');
      // Use parent box as primary sizing budget; root size may contain previous quantized snap.
      // For fixed-size containers (min=max), keep sizing on root to avoid stretching from taller parents.
      const width = Math.max(1, fixedWidth || parentWidth || rootWidth || safeStep);
      const height = Math.max(1, fixedHeight || parentHeight || rootHeight || safeStep);
      return { width, height };
    };

    const resolveEffectiveStep = (baseStep, availableWidth, availableHeight) => {
      const safeStep = Math.max(1, Math.floor(baseStep));
      const minAxis = Math.floor(Math.min(availableWidth, availableHeight));
      if (minAxis <= 0) {
        return safeStep;
      }
      const bounded = Math.min(safeStep, minAxis);
      if (minAxis < 4) {
        return Math.max(1, bounded);
      }
      return Math.max(4, bounded);
    };

    const resolveFitMode = (value) => {
      if (value === 'cover') {
        return 'cover';
      }
      return 'contain';
    };

    const applyBoxSize = (root, state, width, height) => {
      if (state.lastWidth !== width) {
        root.style.width = `${width}px`;
        state.lastWidth = width;
      }
      if (state.lastHeight !== height) {
        root.style.height = `${height}px`;
        state.lastHeight = height;
      }
    };

    const resolveEvenCenter = (edgeLength, radius, count, index) => {
      if (count <= 1) {
        return edgeLength / 2;
      }
      const start = radius;
      const end = edgeLength - radius;
      return start + ((end - start) * index) / (count - 1);
    };

    const resolveScallopRadius = (width, height, baseRadius, edges, scallopRadiusScale) => {
      const scale = Math.max(0.7, Math.min(1.45, scallopRadiusScale));
      const maxByWidth = Math.max(1, width / 2 - 0.5);
      const maxByHeight = edges === 'top' ? Math.max(1, height - 0.5) : Math.max(1, height / 2 - 0.5);
      const maxRadius = Math.max(1, Math.min(maxByWidth, maxByHeight));
      return Math.max(1, Math.min(baseRadius * scale, maxRadius));
    };

    const renderRectangleScallop = (svg, width, height, step, edges, scallopRadiusScale = 1) => {
      const cols = Math.max(1, Math.floor(width / step));
      const rows = Math.max(1, Math.floor(height / step));
      const baseRadius = step / 2;
      const radius = resolveScallopRadius(width, height, baseRadius, edges, scallopRadiusScale);
      const centerX = (index) => resolveEvenCenter(width, radius, cols, index);
      const centerY = (index) => resolveEvenCenter(height, radius, rows, index);
      const pieces = [];

      if (edges === 'top') {
        const rectHeight = Math.max(0, height - radius);
        pieces.push(`<rect x="0" y="${radius}" width="${width}" height="${rectHeight}" fill="currentColor"></rect>`);

        for (let i = 0; i < cols; i += 1) {
          pieces.push(`<circle cx="${centerX(i)}" cy="${radius}" r="${radius}" fill="currentColor"></circle>`);
        }
      } else {
        const rectWidth = Math.max(0, width - radius * 2);
        const rectHeight = Math.max(0, height - radius * 2);
        pieces.push(`<rect x="${radius}" y="${radius}" width="${rectWidth}" height="${rectHeight}" fill="currentColor"></rect>`);

        for (let i = 0; i < cols; i += 1) {
          pieces.push(`<circle cx="${centerX(i)}" cy="${radius}" r="${radius}" fill="currentColor"></circle>`);
          pieces.push(`<circle cx="${centerX(i)}" cy="${height - radius}" r="${radius}" fill="currentColor"></circle>`);
        }

        for (let j = 1; j < rows - 1; j += 1) {
          pieces.push(`<circle cx="${radius}" cy="${centerY(j)}" r="${radius}" fill="currentColor"></circle>`);
          pieces.push(`<circle cx="${width - radius}" cy="${centerY(j)}" r="${radius}" fill="currentColor"></circle>`);
        }
      }

      svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
      svg.innerHTML = pieces.join('');
    };

    const SCALLOP_KAPPA = 0.5522847498;

    const appendArcSegment = (commands, cx, cy, radius, fromAngle, toAngle) => {
      const delta = toAngle - fromAngle;
      if (!Number.isFinite(delta) || Math.abs(delta) < 1e-6 || radius <= 0) {
        return;
      }

      const segments = Math.max(1, Math.ceil(Math.abs(delta) / (Math.PI / 2)));
      const segmentAngle = delta / segments;

      for (let segment = 0; segment < segments; segment += 1) {
        const t0 = fromAngle + segmentAngle * segment;
        const t1 = t0 + segmentAngle;
        const k = (4 / 3) * Math.tan((t1 - t0) / 4);

        const p0x = cx + radius * Math.cos(t0);
        const p0y = cy + radius * Math.sin(t0);
        const p1x = cx + radius * Math.cos(t1);
        const p1y = cy + radius * Math.sin(t1);
        const d0x = -radius * Math.sin(t0);
        const d0y = radius * Math.cos(t0);
        const d1x = -radius * Math.sin(t1);
        const d1y = radius * Math.cos(t1);

        const c1x = p0x + d0x * k;
        const c1y = p0y + d0y * k;
        const c2x = p1x - d1x * k;
        const c2y = p1y - d1y * k;

        commands.push(
          `C ${round3(c1x)} ${round3(c1y)} ${round3(c2x)} ${round3(c2y)} ${round3(p1x)} ${round3(p1y)}`,
        );
      }
    };

    const buildRectangleScallopOutlinePath = (width, height, step, edges, scallopRadiusScale = 1) => {
      const cols = Math.max(1, Math.floor(width / step));
      const rows = Math.max(1, Math.floor(height / step));
      const baseRadius = step / 2;
      const radius = resolveScallopRadius(width, height, baseRadius, edges, scallopRadiusScale);
      const centerX = (index) => resolveEvenCenter(width, radius, cols, index);
      const centerY = (index) => resolveEvenCenter(height, radius, rows, index);
      const commands = [`M ${round3(0)} ${round3(radius)}`];
      let currentX = 0;
      let currentY = radius;

      for (let i = 0; i < cols; i += 1) {
        const cx = centerX(i);
        const lobeStartX = cx - radius;
        if (Math.abs(lobeStartX - currentX) > 1e-6) {
          commands.push(`L ${round3(lobeStartX)} ${round3(radius)}`);
          currentX = lobeStartX;
        }
        appendArcSegment(commands, cx, radius, radius, Math.PI, Math.PI * 2);
        currentX = cx + radius;
      }

      if (edges === 'top') {
        if (Math.abs(width - currentX) > 1e-6 || Math.abs(radius - currentY) > 1e-6) {
          commands.push(`L ${round3(width)} ${round3(radius)}`);
          currentX = width;
          currentY = radius;
        }
        commands.push(`L ${round3(width)} ${round3(height)}`);
        commands.push(`L ${round3(0)} ${round3(height)}`);
        commands.push('Z');
        return commands.join(' ');
      }

      const rightCenterX = width - radius;
      appendArcSegment(commands, rightCenterX, radius, radius, 0, Math.PI / 2);
      currentX = rightCenterX;
      currentY = radius * 2;

      for (let j = 1; j < rows - 1; j += 1) {
        const cy = centerY(j);
        const lobeStartY = cy - radius;
        if (Math.abs(lobeStartY - currentY) > 1e-6) {
          commands.push(`L ${round3(rightCenterX)} ${round3(lobeStartY)}`);
          currentY = lobeStartY;
        }
        appendArcSegment(commands, rightCenterX, cy, radius, Math.PI * 1.5, Math.PI * 2.5);
        currentY = cy + radius;
      }

      const bottomCenterY = height - radius;
      const bottomRightArcStartY = height - radius * 2;
      if (Math.abs(bottomRightArcStartY - currentY) > 1e-6) {
        commands.push(`L ${round3(rightCenterX)} ${round3(bottomRightArcStartY)}`);
        currentY = bottomRightArcStartY;
      }
      appendArcSegment(commands, rightCenterX, bottomCenterY, radius, Math.PI * 1.5, Math.PI * 2);
      currentX = width;
      currentY = bottomCenterY;

      for (let i = cols - 1; i >= 0; i -= 1) {
        const cx = centerX(i);
        const lobeStartX = cx + radius;
        if (Math.abs(lobeStartX - currentX) > 1e-6) {
          commands.push(`L ${round3(lobeStartX)} ${round3(bottomCenterY)}`);
          currentX = lobeStartX;
        }
        appendArcSegment(commands, cx, bottomCenterY, radius, 0, Math.PI);
        currentX = cx - radius;
      }

      const leftCenterX = radius;
      appendArcSegment(commands, leftCenterX, bottomCenterY, radius, Math.PI, Math.PI * 1.5);
      currentX = leftCenterX;
      currentY = height - radius * 2;

      for (let j = rows - 2; j >= 1; j -= 1) {
        const cy = centerY(j);
        const lobeStartY = cy + radius;
        if (Math.abs(lobeStartY - currentY) > 1e-6) {
          commands.push(`L ${round3(leftCenterX)} ${round3(lobeStartY)}`);
          currentY = lobeStartY;
        }
        appendArcSegment(commands, leftCenterX, cy, radius, Math.PI / 2, Math.PI * 1.5);
        currentY = cy - radius;
      }

      const topLeftArcStartY = radius * 2;
      if (Math.abs(topLeftArcStartY - currentY) > 1e-6) {
        commands.push(`L ${round3(leftCenterX)} ${round3(topLeftArcStartY)}`);
      }
      appendArcSegment(commands, leftCenterX, radius, radius, Math.PI / 2, Math.PI);
      commands.push('Z');
      return commands.join(' ');
    };

    const appendLegacyTotemWaveCommands = (commands, config) => {
      const { sx, sy, ex, ey, nx, ny, segments, amplitude, tension } = config;
      const count = Math.max(1, Math.floor(segments));
      const dx = (ex - sx) / count;
      const dy = (ey - sy) / count;
      const normalizedTension = clamp01(tension);
      const depth = amplitude * (0.9 + 0.2 * normalizedTension);
      const lobeLength = Math.hypot(dx, dy) || 1;
      const tx = dx / lobeLength;
      const ty = dy / lobeLength;
      const edgeHandleRatio = 0.15 + (1 - normalizedTension) * 0.12;
      const crestHandleRatio = 0.2 + (1 - normalizedTension) * 0.1;
      const edgeHandleLength = lobeLength * edgeHandleRatio;
      const crestHandleLength = lobeLength * crestHandleRatio;

      for (let i = 0; i < count; i += 1) {
        const startX = sx + dx * i;
        const startY = sy + dy * i;
        const endX = startX + dx;
        const endY = startY + dy;
        const midX = startX + dx * 0.5 + nx * depth;
        const midY = startY + dy * 0.5 + ny * depth;
        const c1x = startX + tx * edgeHandleLength;
        const c1y = startY + ty * edgeHandleLength;
        const c2x = midX - tx * crestHandleLength;
        const c2y = midY - ty * crestHandleLength;
        const c3x = midX + tx * crestHandleLength;
        const c3y = midY + ty * crestHandleLength;
        const c4x = endX - tx * edgeHandleLength;
        const c4y = endY - ty * edgeHandleLength;
        commands.push(
          `C ${round3(c1x)} ${round3(c1y)} ${round3(c2x)} ${round3(c2y)} ${round3(midX)} ${round3(midY)}`,
        );
        commands.push(
          `C ${round3(c3x)} ${round3(c3y)} ${round3(c4x)} ${round3(c4y)} ${round3(endX)} ${round3(endY)}`,
        );
      }
    };

    const resolveEdgeSegments = (length, step) => {
      const safeLength = Math.max(1, length);
      return Math.max(1, Math.floor(safeLength / step));
    };

    const renderRectangleTotem = (svg, width, height, step, edges, waveAmplitudeRatio, waveTension) => {
      const amplitude = Math.max(
        1,
        Math.min(step * 0.48, step * Math.max(0.08, Math.min(0.45, waveAmplitudeRatio))),
      );
      const tension = clamp01(waveTension);
      const maxCornerInset = Math.max(1, Math.min(width, height) / 2 - 1);
      const desiredCornerInset = Math.max(step * 0.18, amplitude * 0.85);
      const cornerInset = Math.max(1, Math.min(maxCornerInset, desiredCornerInset));
      const topWaveStartX = cornerInset;
      const topWaveEndX = Math.max(topWaveStartX + 1, width - cornerInset);
      const topWaveLength = topWaveEndX - topWaveStartX;
      const topSegments = resolveEdgeSegments(topWaveLength, step);
      const commands = [`M ${round3(topWaveStartX)} 0`];

      appendLegacyTotemWaveCommands(commands, {
        sx: topWaveStartX,
        sy: 0,
        ex: topWaveEndX,
        ey: 0,
        nx: 0,
        ny: 1,
        segments: topSegments,
        amplitude,
        tension,
      });

      commands.push(
        `C ${round3(topWaveEndX + cornerInset * SCALLOP_KAPPA)} 0 ${round3(width)} ${round3(cornerInset - cornerInset * SCALLOP_KAPPA)} ${round3(width)} ${round3(cornerInset)}`,
      );

      if (edges === 'all') {
        const rightWaveStartY = cornerInset;
        const rightWaveEndY = Math.max(rightWaveStartY + 1, height - cornerInset);
        const rightWaveLength = rightWaveEndY - rightWaveStartY;
        const rightSegments = resolveEdgeSegments(rightWaveLength, step);

        appendLegacyTotemWaveCommands(commands, {
          sx: width,
          sy: rightWaveStartY,
          ex: width,
          ey: rightWaveEndY,
          nx: -1,
          ny: 0,
          segments: rightSegments,
          amplitude,
          tension,
        });

        commands.push(
          `C ${round3(width)} ${round3(rightWaveEndY + cornerInset * SCALLOP_KAPPA)} ${round3(width - cornerInset + cornerInset * SCALLOP_KAPPA)} ${round3(height)} ${round3(width - cornerInset)} ${round3(height)}`,
        );

        appendLegacyTotemWaveCommands(commands, {
          sx: width - cornerInset,
          sy: height,
          ex: cornerInset,
          ey: height,
          nx: 0,
          ny: -1,
          segments: topSegments,
          amplitude,
          tension,
        });

        commands.push(
          `C ${round3(cornerInset - cornerInset * SCALLOP_KAPPA)} ${round3(height)} 0 ${round3(height - cornerInset + cornerInset * SCALLOP_KAPPA)} 0 ${round3(height - cornerInset)}`,
        );

        appendLegacyTotemWaveCommands(commands, {
          sx: 0,
          sy: height - cornerInset,
          ex: 0,
          ey: cornerInset,
          nx: 1,
          ny: 0,
          segments: rightSegments,
          amplitude,
          tension,
        });

        commands.push(
          `C 0 ${round3(cornerInset - cornerInset * SCALLOP_KAPPA)} ${round3(cornerInset - cornerInset * SCALLOP_KAPPA)} 0 ${round3(topWaveStartX)} 0`,
        );
      } else {
        commands.push(`L ${width} ${height}`);
        commands.push(`L 0 ${height}`);
        commands.push(`L 0 ${round3(cornerInset)}`);
        commands.push(
          `C 0 ${round3(cornerInset - cornerInset * SCALLOP_KAPPA)} ${round3(cornerInset - cornerInset * SCALLOP_KAPPA)} 0 ${round3(topWaveStartX)} 0`,
        );
      }

      commands.push('Z');
      svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
      svg.innerHTML = `<path d="${commands.join(' ')}" fill="currentColor"></path>`;
    };

    const defaultAnimatedParams = () => ({
      waveAmplitudeRatio: 0.28,
      waveTension: 0.5,
      scallopRadiusScale: 1,
    });

    const clampTotemAmplitudeRatio = (value) => Math.max(0.08, Math.min(0.45, value));

    const clampTotemTension = (value) => clamp01(value);

    const resolvePatternAnimationAdapter = (pattern) => {
      if (pattern === 'totem') {
        return {
          supportsParamAnimation: true,
          resolveBaseParams: (dataset) => ({
            waveAmplitudeRatio: clampTotemAmplitudeRatio(
              readDataNumber(dataset, 'perimeterWaveAmplitudeRatio', 0.28),
            ),
            waveTension: clampTotemTension(readDataNumber(dataset, 'perimeterWaveTension', 0.5)),
            scallopRadiusScale: 1,
          }),
          resolveHoverParams: (baseParams, dataset) => {
            const preset = readDataEnum(dataset, 'perimeterHoverMorphPreset', ['default', 'strong'], 'default');
            const presetDeltas =
              preset === 'strong'
                ? { amplitudeDelta: 0.16, tensionDelta: -0.38 }
                : { amplitudeDelta: 0.1, tensionDelta: -0.22 };
            const amplitudeDelta =
              typeof dataset.perimeterHoverWaveAmplitudeDelta === 'string' &&
              dataset.perimeterHoverWaveAmplitudeDelta.trim() !== ''
                ? readDataNumber(dataset, 'perimeterHoverWaveAmplitudeDelta', presetDeltas.amplitudeDelta)
                : presetDeltas.amplitudeDelta;
            const tensionDelta =
              typeof dataset.perimeterHoverWaveTensionDelta === 'string' &&
              dataset.perimeterHoverWaveTensionDelta.trim() !== ''
                ? readDataNumber(dataset, 'perimeterHoverWaveTensionDelta', presetDeltas.tensionDelta)
                : presetDeltas.tensionDelta;
            return {
              waveAmplitudeRatio: clampTotemAmplitudeRatio(baseParams.waveAmplitudeRatio + amplitudeDelta),
              waveTension: clampTotemTension(baseParams.waveTension + tensionDelta),
              scallopRadiusScale: 1,
            };
          },
          interpolateParams: (fromParams, toParams, progress) => ({
            waveAmplitudeRatio: clampTotemAmplitudeRatio(
              lerp(fromParams.waveAmplitudeRatio, toParams.waveAmplitudeRatio, progress),
            ),
            waveTension: clampTotemTension(lerp(fromParams.waveTension, toParams.waveTension, progress)),
            scallopRadiusScale: 1,
          }),
          render: (svg, box, params, edges) =>
            renderRectangleTotem(
              svg,
              box.width,
              box.height,
              box.step,
              edges,
              params.waveAmplitudeRatio,
              params.waveTension,
            ),
        };
      }

      if (pattern === 'scallop') {
        return {
          supportsParamAnimation: true,
          resolveBaseParams: () => ({
            ...defaultAnimatedParams(),
            scallopRadiusScale: 1,
          }),
          resolveHoverParams: (baseParams, dataset) => {
            const preset = readDataEnum(dataset, 'perimeterHoverMorphPreset', ['default', 'strong'], 'default');
            const targetScale = preset === 'strong' ? 1.28 : 1.14;
            return {
              ...baseParams,
              scallopRadiusScale: targetScale,
            };
          },
          interpolateParams: (fromParams, toParams, progress) => ({
            ...fromParams,
            scallopRadiusScale: lerp(fromParams.scallopRadiusScale, toParams.scallopRadiusScale, progress),
          }),
          render: (svg, box, params, edges) =>
            renderRectangleScallop(
              svg,
              box.width,
              box.height,
              box.step,
              edges,
              params.scallopRadiusScale,
            ),
        };
      }

      return {
        supportsParamAnimation: false,
        resolveBaseParams: () => defaultAnimatedParams(),
        resolveHoverParams: (baseParams) => baseParams,
        interpolateParams: (fromParams) => fromParams,
        render: (svg, box, _params, edges) => renderRectangleScallop(svg, box.width, box.height, box.step, edges),
      };
    };

    const circleOuterDiameter = (step, lobes) => {
      if (lobes < 3) {
        return step;
      }
      return step * (1 + 1 / Math.sin(Math.PI / lobes));
    };

    const findCircleLobes = (availableDiameter, step, minLobes) => {
      let bestLobes = 0;
      for (let lobes = 3; lobes <= 128; lobes += 1) {
        const diameter = circleOuterDiameter(step, lobes);
        if (diameter <= availableDiameter + 0.01) {
          bestLobes = lobes;
          continue;
        }
        break;
      }

      if (bestLobes === 0) {
        return { lobes: 0, diameter: Math.max(step, Math.floor(availableDiameter)) };
      }

      const target = Math.max(3, minLobes);
      const resolvedLobes = bestLobes >= target ? bestLobes : bestLobes;
      return {
        lobes: resolvedLobes,
        diameter: circleOuterDiameter(step, resolvedLobes),
      };
    };

    const renderCircleSvg = (svg, diameter, step, lobes) => {
      const center = diameter / 2;
      const radius = step / 2;

      if (lobes < 3) {
        svg.setAttribute('viewBox', `0 0 ${diameter} ${diameter}`);
        svg.innerHTML = `<circle cx="${center}" cy="${center}" r="${center}" fill="currentColor"></circle>`;
        return;
      }

      const ringRadius = step / (2 * Math.sin(Math.PI / lobes));
      const pieces = [
        `<circle cx="${round3(center)}" cy="${round3(center)}" r="${round3(ringRadius)}" fill="currentColor"></circle>`,
      ];

      for (let index = 0; index < lobes; index += 1) {
        const angle = (Math.PI * 2 * index) / lobes - Math.PI / 2;
        const cx = round3(center + ringRadius * Math.cos(angle));
        const cy = round3(center + ringRadius * Math.sin(angle));
        pieces.push(`<circle cx="${cx}" cy="${cy}" r="${round3(radius)}" fill="currentColor"></circle>`);
      }

      svg.setAttribute('viewBox', `0 0 ${round3(diameter)} ${round3(diameter)}`);
      svg.innerHTML = pieces.join('');
    };

    const clearContentMask = (root) => {
      root.style.removeProperty('--perimeter-content-mask');
    };

    const serializeMaskSvg = (svg) => {
      const viewBox = svg.getAttribute('viewBox');
      if (!viewBox) {
        return null;
      }
      const normalizedShape = svg.innerHTML.replace(/currentColor/g, '#000');
      const markup = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="${viewBox}" preserveAspectRatio="none">${normalizedShape}</svg>`;
      return `url("data:image/svg+xml,${encodeURIComponent(markup)}")`;
    };

    const applyContentMask = (root, svg) => {
      const serialized = serializeMaskSvg(svg);
      if (!serialized) {
        clearContentMask(root);
        return;
      }
      root.style.setProperty('--perimeter-content-mask', serialized);
    };

    const clearOutlineFrame = (outlineSvg) => {
      if (!outlineSvg) {
        return;
      }
      outlineSvg.innerHTML = '';
    };

    const renderAlphaOutlineFrame = (outlineSvg, shapeSvg, outlineWidth, outlineFilterId) => {
      if (!outlineSvg || !shapeSvg) {
        return;
      }

      const viewBox = shapeSvg.getAttribute('viewBox');
      const shapeMarkup = shapeSvg.innerHTML.trim();
      if (!viewBox || !shapeMarkup || outlineWidth <= 0) {
        clearOutlineFrame(outlineSvg);
        return;
      }

      outlineSvg.setAttribute('viewBox', viewBox);
      outlineSvg.innerHTML = [
        '<defs>',
        `<filter id="${outlineFilterId}" color-interpolation-filters="sRGB">`,
        `<feMorphology in="SourceAlpha" operator="erode" radius="${round3(outlineWidth)}" result="inner"></feMorphology>`,
        '<feComposite in="SourceGraphic" in2="inner" operator="out"></feComposite>',
        '</filter>',
        '</defs>',
        `<g filter="url(#${outlineFilterId})">${shapeMarkup}</g>`,
      ].join('');
    };

    const parseViewBox = (value) => {
      if (typeof value !== 'string') {
        return null;
      }
      const parts = value
        .trim()
        .split(/\s+/)
        .map((part) => Number.parseFloat(part));
      if (parts.length !== 4 || parts.some((part) => !Number.isFinite(part))) {
        return null;
      }
      return { x: parts[0], y: parts[1], width: parts[2], height: parts[3] };
    };

    const renderGeometricOutlineFrame = (outlineSvg, shapeSvg, pathData, outlineWidth, placement, outlineMaskId) => {
      if (!outlineSvg || !shapeSvg || !pathData || outlineWidth <= 0) {
        clearOutlineFrame(outlineSvg);
        return;
      }
      const viewBox = shapeSvg.getAttribute('viewBox');
      if (!viewBox) {
        clearOutlineFrame(outlineSvg);
        return;
      }
      outlineSvg.setAttribute('viewBox', viewBox);
      if (placement === 'outside' && outlineMaskId) {
        const parsedViewBox = parseViewBox(viewBox);
        if (!parsedViewBox) {
          clearOutlineFrame(outlineSvg);
          return;
        }
        const expandedStrokeWidth = Math.max(0.001, outlineWidth * 2);
        const spread = Math.max(1, expandedStrokeWidth * 2 + 2);
        const maskX = parsedViewBox.x - spread;
        const maskY = parsedViewBox.y - spread;
        const maskWidth = parsedViewBox.width + spread * 2;
        const maskHeight = parsedViewBox.height + spread * 2;
        outlineSvg.innerHTML = [
          '<defs>',
          `<mask id="${outlineMaskId}" maskUnits="userSpaceOnUse" x="${round3(maskX)}" y="${round3(maskY)}" width="${round3(maskWidth)}" height="${round3(maskHeight)}">`,
          `<rect x="${round3(maskX)}" y="${round3(maskY)}" width="${round3(maskWidth)}" height="${round3(maskHeight)}" fill="#fff"></rect>`,
          `<path d="${pathData}" fill="#000"></path>`,
          '</mask>',
          '</defs>',
          `<path d="${pathData}" fill="none" stroke="currentColor" stroke-width="${round3(
            expandedStrokeWidth,
          )}" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" shape-rendering="geometricPrecision" mask="url(#${outlineMaskId})"></path>`,
        ].join('');
        return;
      }
      outlineSvg.innerHTML = `<path d="${pathData}" fill="none" stroke="currentColor" stroke-width="${round3(
        outlineWidth,
      )}" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" shape-rendering="geometricPrecision"></path>`;
    };

    const update = (root) => {
      const svg = root.querySelector('.scallop-frame');
      const outlineSvg = root.querySelector('.scallop-outline-frame');
      const content = root.querySelector('.scallop-content');
      const parent = root.parentElement;
      const state = runtime.states.get(root);

      if (!svg || !content || !parent || !state) {
        return;
      }

      const shape = readDataEnum(root, 'perimeterShape', ['rectangle', 'circle'], 'rectangle');
      const shouldClipContent = readDataBool(root, 'perimeterClipContentToShape', false);
      const shouldExportShapeMask = readDataBool(root, 'perimeterExportShapeMask', false);
      const shouldExposeMask = shouldClipContent || shouldExportShapeMask;
      if (!shouldExposeMask) {
        clearContentMask(root);
      }
      const outlineEnabled = readDataBool(root, 'perimeterOutlineEnabled', false);
      if (!outlineEnabled) {
        clearOutlineFrame(outlineSvg);
      }
      const rootStyles = outlineEnabled ? window.getComputedStyle(root) : null;
      const requestedOutlineMode = readDataEnum(root, 'perimeterOutlineMode', ['alpha', 'geometric'], 'alpha');
      const requestedOutlinePlacement = readDataEnum(
        root,
        'perimeterOutlinePlacement',
        ['center', 'outside'],
        'center',
      );
      const outlineWidth = outlineEnabled
        ? Math.max(0, readNumber(rootStyles?.getPropertyValue('--perimeter-outline-width'), 0))
        : 0;
      const outlineColor = outlineEnabled
        ? rootStyles?.getPropertyValue('--perimeter-outline-color').trim() || 'transparent'
        : 'transparent';
      const geometricOutlineSupported =
        requestedOutlineMode === 'geometric' &&
        shape === 'rectangle' &&
        readDataEnum(root, 'perimeterEdgePattern', ['scallop', 'totem'], 'scallop') === 'scallop';
      const outlineMode = geometricOutlineSupported ? 'geometric' : 'alpha';
      const outlinePlacement = geometricOutlineSupported ? requestedOutlinePlacement : 'center';
      const shouldRenderOutline = outlineEnabled && outlineWidth > 0 && outlineColor !== 'transparent';
      if (outlineSvg) {
        outlineSvg.style.color = outlineColor;
      }
      const edgePattern = readDataEnum(root, 'perimeterEdgePattern', ['scallop', 'totem'], 'scallop');
      const edges = readDataEnum(root, 'perimeterEdges', ['all', 'top'], 'all');
      const animationAdapter = resolvePatternAnimationAdapter(edgePattern);
      const hoverMorphEnabled =
        shape === 'rectangle' &&
        readDataBool(root, 'perimeterHoverMorph', false) &&
        animationAdapter.supportsParamAnimation;
      const animationProgress = hoverMorphEnabled ? clamp01(state.animProgress) : 0;
      const baseStep = Math.max(1, readDataNumber(root, 'perimeterStep', 40));
      const available = resolveAvailableSize(root, parent, baseStep);
      const effectiveStep = resolveEffectiveStep(baseStep, available.width, available.height);
      const minCols = clampInt(readDataInt(root, 'perimeterMinCols', 12), 1);
      const minRows = clampInt(readDataInt(root, 'perimeterMinRows', 8), 1);
      const minLobes = clampInt(readDataInt(root, 'perimeterMinLobes', 8), 3);
      const baseParams = animationAdapter.resolveBaseParams(root.dataset);
      const hoverParams = hoverMorphEnabled
        ? animationAdapter.resolveHoverParams(baseParams, root.dataset)
        : baseParams;
      const activeParams = hoverMorphEnabled
        ? animationAdapter.interpolateParams(baseParams, hoverParams, animationProgress)
        : baseParams;
      let signature = `${shape}:${edgePattern}:${edges}:${effectiveStep}:${round3(
        activeParams.waveAmplitudeRatio,
      )}:${round3(activeParams.waveTension)}:${round3(activeParams.scallopRadiusScale)}:${round3(animationProgress)}:${
        shouldRenderOutline
          ? `outline:${outlineMode}:${outlinePlacement}:${round3(outlineWidth)}:${outlineColor}`
          : 'outline:none'
      }`;

      root.dataset.perimeterEffectiveStep = String(effectiveStep);
      root.dataset.perimeterMorphProgress = String(round3(animationProgress));
      root.dataset.ready = 'true';

      if (shape === 'circle') {
        const availableDiameter = Math.max(1, Math.min(available.width, available.height));
        const circle = findCircleLobes(availableDiameter, effectiveStep, minLobes);
        const snappedDiameter = round3(circle.diameter);
        signature = `${signature}:${snappedDiameter}:${circle.lobes}`;

        applyBoxSize(root, state, snappedDiameter, snappedDiameter);
        root.dataset.perimeterLobes = String(circle.lobes);
        root.dataset.perimeterCols = '';
        root.dataset.perimeterRows = '';
        root.dataset.perimeterOverflowed = content.scrollHeight > snappedDiameter ? 'true' : 'false';
        root.dataset.scallopLobes = String(circle.lobes);
        root.dataset.scallopCols = '';
        root.dataset.scallopRows = '';

        if (signature !== state.lastSignature) {
          renderCircleSvg(svg, snappedDiameter, effectiveStep, circle.lobes);
          if (shouldExposeMask) {
            applyContentMask(root, svg);
          } else {
            clearContentMask(root);
          }
          if (shouldRenderOutline) {
            renderAlphaOutlineFrame(outlineSvg, svg, outlineWidth, state.outlineFilterId);
          } else {
            clearOutlineFrame(outlineSvg);
          }
          state.lastSignature = signature;
        }
        root.dataset.perimeterSignature = signature;
        root.dataset.scallopSignature = signature;
        return;
      }

      const widthBudget = Math.max(1, Math.floor(available.width));
      const heightBudget = Math.max(1, Math.floor(available.height));

      const fitMode = resolveFitMode(readDataEnum(root, 'perimeterFit', ['contain', 'cover'], 'contain'));
      const floorCols = Math.max(1, Math.floor(widthBudget / effectiveStep));
      const ceilCols = Math.max(1, Math.ceil(widthBudget / effectiveStep));
      const floorRows = Math.max(1, Math.floor(heightBudget / effectiveStep));
      const baseCols = fitMode === 'cover' ? ceilCols : floorCols;
      const cols = minCols * effectiveStep <= widthBudget ? Math.max(minCols, baseCols) : baseCols;
      const rows = minRows * effectiveStep <= heightBudget ? Math.max(minRows, floorRows) : floorRows;
      const snappedWidth = cols * effectiveStep;
      const snappedHeight = rows * effectiveStep;
      const requiredContentHeight = Math.ceil(content.scrollHeight);
      signature = `${signature}:${snappedWidth}:${snappedHeight}:${cols}:${rows}`;
      const snapMismatch = snappedWidth !== widthBudget || snappedHeight !== heightBudget;
      root.dataset.perimeterSnapMismatch = snapMismatch ? 'true' : 'false';
      if (snapMismatch) {
        const rootComputedStyle = window.getComputedStyle(root);
        const minHeightPx = readNumber(rootComputedStyle.minHeight, 0);
        const maxHeightRaw = rootComputedStyle.maxHeight;
        const maxHeightPx = maxHeightRaw === 'none' ? 0 : readNumber(maxHeightRaw, 0);
        const hasFixedHeightConstraint =
          minHeightPx > 0 &&
          maxHeightPx > 0 &&
          Math.abs(minHeightPx - maxHeightPx) < 0.5;

        if (hasFixedHeightConstraint && isLocalDebugHost && !state.hasLoggedSnapMismatch) {
          console.warn('[quantized-perimeter] snap mismatch on fixed-height element', {
            budget: { width: widthBudget, height: heightBudget },
            snapped: { width: snappedWidth, height: snappedHeight },
            effectiveStep,
            perimeterClass: root.className,
          });
          state.hasLoggedSnapMismatch = true;
        }
      } else {
        state.hasLoggedSnapMismatch = false;
      }

      applyBoxSize(root, state, snappedWidth, snappedHeight);
      root.dataset.perimeterCols = String(cols);
      root.dataset.perimeterRows = String(rows);
      root.dataset.perimeterLobes = '';
      root.dataset.perimeterOverflowed = requiredContentHeight > snappedHeight ? 'true' : 'false';
      root.dataset.scallopCols = String(cols);
      root.dataset.scallopRows = String(rows);
      root.dataset.scallopLobes = '';

        if (signature !== state.lastSignature) {
          animationAdapter.render(
            svg,
            { width: snappedWidth, height: snappedHeight, step: effectiveStep },
            activeParams,
            edges,
          );
          if (shouldExposeMask) {
            applyContentMask(root, svg);
          } else {
            clearContentMask(root);
          }
          if (shouldRenderOutline) {
            if (outlineMode === 'geometric') {
              const outlinePath = buildRectangleScallopOutlinePath(
                snappedWidth,
                snappedHeight,
                effectiveStep,
                edges,
                activeParams.scallopRadiusScale,
              );
              renderGeometricOutlineFrame(
                outlineSvg,
                svg,
                outlinePath,
                outlineWidth,
                outlinePlacement,
                state.outlineMaskId,
              );
            } else {
              renderAlphaOutlineFrame(outlineSvg, svg, outlineWidth, state.outlineFilterId);
            }
          } else {
            clearOutlineFrame(outlineSvg);
          }
          state.lastSignature = signature;
        }

      root.dataset.perimeterSignature = signature;
      root.dataset.scallopSignature = signature;
    };

    const schedule = (root) => {
      const state = runtime.states.get(root);
      if (!state || state.rafId !== 0) {
        return;
      }
      state.rafId = lifecycle.requestAnimationFrame(() => {
        state.rafId = 0;
        update(root);
      });
    };

    const stopAnimation = (state) => {
      if (!state?.animControl) {
        return;
      }
      state.animControl.stop();
      state.animControl = null;
    };

    const animateHoverParams = (root, target) => {
      const state = runtime.states.get(root);
      if (!state) {
        return;
      }

      const clampedTarget = clamp01(target);
      stopAnimation(state);
      state.animTarget = clampedTarget;

      if (prefersReducedMotion.matches) {
        state.animProgress = clampedTarget;
        schedule(root);
        return;
      }

      const from = clamp01(state.animProgress);
      const duration = Math.max(0.2, readDataNumber(root, 'perimeterMorphSpringDuration', 1.05));
      const bounce = clamp01(readDataNumber(root, 'perimeterMorphSpringBounce', 0.24));

      state.animControl = animate(from, clampedTarget, {
        type: 'spring',
        duration,
        bounce,
        onUpdate: (latest) => {
          state.animProgress = clamp01(latest);
          schedule(root);
        },
        onComplete: () => {
          state.animProgress = clampedTarget;
          state.animControl = null;
          schedule(root);
        },
      });
    };

    const mount = (root, options = {}) => {
      const { scheduleExisting = false } = options;
      if (runtime.roots.has(root)) {
        if (scheduleExisting) {
          schedule(root);
        }
        return false;
      }

      const content = root.querySelector('.scallop-content');
      const parent = root.parentElement;
      if (!content || !parent) {
        return false;
      }

      const observer = new ResizeObserver(() => {
        schedule(root);
      });

      runtime.roots.add(root);
      runtime.states.set(root, {
        observer,
        rafId: 0,
        lastWidth: -1,
        lastHeight: -1,
        lastSignature: '',
        outlineFilterId: `perimeter-outline-${++outlineIdCounter}`,
        outlineMaskId: `perimeter-outline-mask-${outlineIdCounter}`,
        animProgress: 0,
        animTarget: 0,
        animControl: null,
        hasLoggedSnapMismatch: false,
        unbindHoverHandlers: null,
      });

      const state = runtime.states.get(root);
      if (
        state &&
        readDataBool(root, 'perimeterHoverMorph', false) &&
        readDataEnum(root, 'perimeterShape', ['rectangle', 'circle'], 'rectangle') === 'rectangle' &&
        resolvePatternAnimationAdapter(readDataEnum(root, 'perimeterEdgePattern', ['scallop', 'totem'], 'scallop'))
          .supportsParamAnimation
      ) {
        const activate = () => animateHoverParams(root, 1);
        const deactivate = () => animateHoverParams(root, 0);
        root.addEventListener('pointerenter', activate);
        root.addEventListener('pointerleave', deactivate);
        root.addEventListener('focus', activate);
        root.addEventListener('blur', deactivate);
        state.unbindHoverHandlers = () => {
          root.removeEventListener('pointerenter', activate);
          root.removeEventListener('pointerleave', deactivate);
          root.removeEventListener('focus', activate);
          root.removeEventListener('blur', deactivate);
        };
      }

      observer.observe(parent);
      observer.observe(content);

      update(root);
      return true;
    };

    const unmount = (root) => {
      const state = runtime.states.get(root);
      if (state) {
        stopAnimation(state);
        if (typeof state.unbindHoverHandlers === 'function') {
          state.unbindHoverHandlers();
        }
        if (state.rafId !== 0) {
          lifecycle.cancelAnimationFrame(state.rafId);
        }
        state.observer.disconnect();
        runtime.states.delete(root);
      }
      runtime.roots.delete(root);
    };

    const cleanupDisconnectedRoots = () => {
      runtime.roots.forEach((root) => {
        if (!root.isConnected) {
          unmount(root);
        }
      });
    };

    const mountNewRoots = (options = {}) => {
      const { scheduleExisting = false } = options;
      cleanupDisconnectedRoots();
      const roots = document.querySelectorAll('[data-quantized-perimeter]');
      roots.forEach((root) => {
        mount(root, { scheduleExisting });
      });
    };

    const scheduleAll = () => {
      cleanupDisconnectedRoots();
      runtime.roots.forEach((root) => {
        schedule(root);
      });
    };

    const runtimeApi = {
      mountNewRoots,
      scheduleAll,
      destroy() {
        for (const root of Array.from(runtime.roots)) {
          unmount(root);
        }
        lifecycle.dispose();
      },
    };

    lifecycle.addCleanup(
      onAstroPageLoad(() => {
        mountNewRoots({ scheduleExisting: false });
      }),
    );
    lifecycle.on(window, 'resize', scheduleAll);
    lifecycle.onFontsLoadingDone(scheduleAll);

    const installedRuntime = getOrCreateWindowRuntime(runtimeKey, () => runtimeApi);
    if (installedRuntime !== runtimeApi) {
      runtimeApi.destroy();
      installedRuntime?.mountNewRoots?.({ scheduleExisting: false });
      return;
    }

    mountNewRoots({ scheduleExisting: false });
  })();
</script>
