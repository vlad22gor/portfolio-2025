---
import DeviceMockup from './DeviceMockup.astro';
import { GALLERY_ROWS, type GalleryPhoneCard } from '../data/gallery';

export interface Props {
  class?: string;
  viewportClass?: string;
  trackClass?: string;
  itemClass?: string;
  stageItem?: boolean;
  motionStaggerIndex?: number;
  mediaMode?: 'mixed' | 'poster-only';
}

interface TemporaryAdaptiveSlide {
  id: string;
  alt: string;
  screenKind: 'image' | 'video';
  screenSrc: string;
  screenPoster?: string;
}

const {
  class: rootClass = '',
  viewportClass = '',
  trackClass = '',
  itemClass = '',
  stageItem = false,
  motionStaggerIndex,
  mediaMode = 'mixed',
} = Astro.props;

const baseSlides: TemporaryAdaptiveSlide[] = GALLERY_ROWS.flatMap((row) => row.items)
  .filter((item): item is GalleryPhoneCard => item.type === 'phone')
  .slice(0, 9)
  .map((item) => {
    if (mediaMode === 'poster-only' && item.screen.kind === 'video') {
      return {
        id: item.id,
        alt: item.alt,
        screenKind: 'image' as const,
        screenSrc: item.screen.poster ?? item.screen.src,
        screenPoster: undefined,
      };
    }
    return {
      id: item.id,
      alt: item.alt,
      screenKind: item.screen.kind,
      screenSrc: item.screen.src,
      screenPoster: item.screen.poster,
    };
  });

const loopSlides = [...baseSlides, ...baseSlides];

const screensClass = ['temporary-adaptive-notice__screens', rootClass].filter(Boolean).join(' ');
const screensViewportClass = ['temporary-adaptive-notice__screens-viewport', viewportClass].filter(Boolean).join(' ');
const screensTrackClass = ['temporary-adaptive-notice__screens-track', trackClass].filter(Boolean).join(' ');
const screensItemClass = ['temporary-adaptive-notice__screens-item', itemClass].filter(Boolean).join(' ');

const screensAttrs = stageItem
  ? {
      'data-temp-stage-item': '',
      'data-motion-stage-item': '',
      'data-motion-stagger-index': motionStaggerIndex,
    }
  : {};
---

<div class={screensClass} aria-hidden="true" {...screensAttrs}>
  <div class={screensViewportClass} data-temp-slider data-temp-slider-count={baseSlides.length} data-temp-slider-media-mode={mediaMode}>
    <div class={screensTrackClass} data-temp-slider-track>
      {
        loopSlides.map((slide, index) => (
          <div class={screensItemClass} data-temp-slider-item data-temp-slider-index={index}>
            <DeviceMockup
              class="temporary-adaptive-notice__device"
              device="phone"
              size="small"
              screenKind={slide.screenKind}
              screenSrc={slide.screenSrc}
              screenPoster={slide.screenPoster}
              screenAlt={slide.alt}
              priority={index < 3 ? 'critical' : 'lazy'}
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .temporary-adaptive-notice__screens {
    width: 100%;
    overflow: visible;
  }

  .temporary-adaptive-notice__screens-viewport {
    width: 100%;
    max-width: 100vw;
    height: 308px;
    touch-action: pan-y;
    overflow: visible;
    position: relative;
    cursor: grab;
    user-select: none;
  }

  .temporary-adaptive-notice__screens-viewport[data-dragging='true'] {
    cursor: grabbing;
  }

  .temporary-adaptive-notice__screens-track {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    align-items: flex-start;
    gap: 23.4px;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  .temporary-adaptive-notice__screens-item {
    flex: 0 0 auto;
    transform-origin: 50% 0;
    will-change: transform;
  }

  @media (min-width: 768px) and (max-width: 1359px) {
    .temporary-adaptive-notice__screens-viewport {
      height: 320px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .temporary-adaptive-notice__screens-track,
    .temporary-adaptive-notice__screens-item {
      transition: none;
    }
  }
</style>
<script>
  import {
    BREAKPOINT_MOBILE_MAX,
    BREAKPOINT_TABLET_LOW_MAX,
    MEDIA_QUERY_ADAPTIVE,
  } from '../lib/layout/breakpoints';
  import {
    createLifecycle,
    createRafLoop,
    getOrCreateWindowRuntime,
    getWindowRuntime,
    onAstroPageLoad,
    onDomReady,
    readDataBool,
    readDataInt,
  } from '../lib/runtime';

  (() => {
    const runtimeKey = '__temporaryAdaptiveSliderRuntime';
    const existingRuntime = getWindowRuntime(runtimeKey);
    if (existingRuntime) {
      existingRuntime.mount();
      return;
    }

    const lifecycle = createLifecycle();
    const sliderSelector = '[data-temp-slider]';
    const initAttr = 'tempSliderInit';
    const states = new Map();
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const adaptiveQuery = window.matchMedia(MEDIA_QUERY_ADAPTIVE);

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const wrap = (value, size) => {
      if (!Number.isFinite(size) || size <= 0) {
        return 0;
      }
      return ((value % size) + size) % size;
    };

    const ARC_PROFILE = {
      phone: {
        kInfluence: 0.72,
        kCurvature: 0.062,
        rotateCapDeg: 4.2,
        softEdgeRatio: 0.18,
      },
      tablet: {
        kInfluence: 0.84,
        kCurvature: 0.05,
        rotateCapDeg: 3.4,
        softEdgeRatio: 0.14,
      },
    };

    const smoothstep = (t) => {
      const x = clamp(t, 0, 1);
      return x * x * (3 - 2 * x);
    };

    const softClampArcDx = (dx, maxDx, softEdgeRatio) => {
      const safeMaxDx = Math.max(1, maxDx);
      const absDx = Math.abs(dx);
      const zone = Math.max(1, safeMaxDx * clamp(softEdgeRatio, 0.05, 0.45));
      const softStart = safeMaxDx - zone;
      if (absDx <= softStart) {
        return dx;
      }
      if (absDx >= safeMaxDx) {
        return Math.sign(dx) * safeMaxDx;
      }
      const t = (absDx - softStart) / zone;
      const easedAbsDx = softStart + zone * smoothstep(t);
      return Math.sign(dx) * Math.min(easedAbsDx, safeMaxDx);
    };

    const resolveAutoSpeed = (state) => {
      const width = state.viewport.clientWidth;
      const mobileMax = state.isHomeRoute ? BREAKPOINT_TABLET_LOW_MAX : BREAKPOINT_MOBILE_MAX;
      return width <= mobileMax ? 42 : 58;
    };

    const computeArcTransform = (state, itemIndex) => {
      const half = Math.max(1, state.viewportWidth / 2);
      const itemCenter = itemIndex * state.slot + state.itemWidth / 2 - state.offset;
      const dx = itemCenter - half;
      const clampedDx = softClampArcDx(dx, state.arcMaxDx, state.arcSoftEdgeRatio);
      const radius = Math.max(1, state.arcRadius);
      const underRoot = Math.max(0, radius * radius - clampedDx * clampedDx);
      const y = radius - Math.sqrt(underRoot);
      const tangentSin = clamp(clampedDx / radius, -1, 1);
      const tangentAngleDeg = (Math.asin(tangentSin) * 180) / Math.PI;
      const rotate = clamp(tangentAngleDeg, -state.rotateCapDeg, state.rotateCapDeg);
      const normalized = Math.abs(clampedDx) / Math.max(1, state.arcMaxDx);
      const zIndex = String(Math.round((2 - normalized) * 100));
      return {
        transform: `translate3d(0px, ${y.toFixed(2)}px, 0px) rotate(${rotate.toFixed(2)}deg)`,
        zIndex,
      };
    };

    const readMetrics = (state) => {
      const first = state.items[0];
      const second = state.items[1] ?? null;
      if (!(first instanceof HTMLElement)) {
        return;
      }

      const firstRect = first.getBoundingClientRect();
      const secondRect = second instanceof HTMLElement ? second.getBoundingClientRect() : null;
      const trackStyle = getComputedStyle(state.track);
      const fallbackGapCandidate = Number.parseFloat(trackStyle.columnGap || trackStyle.gap || '0');
      const fallbackGap =
        Number.isFinite(fallbackGapCandidate) && fallbackGapCandidate >= 0 ? fallbackGapCandidate : 23.4;
      const slot = secondRect ? secondRect.left - firstRect.left : firstRect.width + fallbackGap;

      state.viewportWidth = state.viewport.clientWidth;
      state.itemWidth = firstRect.width;
      state.slot = slot > 1 ? slot : firstRect.width + fallbackGap;
      state.loopWidth = state.slot * state.baseCount;
      state.totalWidth = state.slot * state.items.length;
      const isTabletViewport = state.isHomeRoute
        ? state.viewportWidth > BREAKPOINT_TABLET_LOW_MAX
        : state.viewportWidth > BREAKPOINT_MOBILE_MAX;
      const profile = isTabletViewport ? ARC_PROFILE.tablet : ARC_PROFILE.phone;
      state.arcMaxDx = clamp(
        state.viewportWidth * profile.kInfluence,
        state.slot * 2.2,
        Math.max(state.slot * 5.2, state.viewportWidth * 0.96),
      );
      state.arcSagitta = clamp(state.arcMaxDx * profile.kCurvature, 18, 38);
      state.arcRadius =
        (state.arcMaxDx * state.arcMaxDx + state.arcSagitta * state.arcSagitta) /
        (2 * state.arcSagitta);
      state.rotateCapDeg = profile.rotateCapDeg;
      state.arcSoftEdgeRatio = profile.softEdgeRatio;
      state.offset = wrap(state.offset, state.loopWidth);
      state.autoSpeed = resolveAutoSpeed(state);
    };

    const render = (state) => {
      state.track.style.transform = `translate3d(${-state.offset.toFixed(3)}px, 0px, 0px)`;
      for (let index = 0; index < state.items.length; index += 1) {
        const item = state.items[index];
        if (!(item instanceof HTMLElement)) {
          continue;
        }
        const arc = computeArcTransform(state, index);
        item.style.transform = arc.transform;
        item.style.opacity = '1';
        item.style.zIndex = arc.zIndex;
      }
    };

    const shouldAutoplay = (state) =>
      adaptiveQuery.matches && !reducedMotionQuery.matches && state.inViewport && !document.hidden && !state.dragging;

    const stepState = (state, dtSec) => {
      if (!(state.root instanceof HTMLElement) || !state.root.isConnected) {
        return false;
      }
      if (!adaptiveQuery.matches) {
        return false;
      }

      if (state.loopWidth <= 0) {
        readMetrics(state);
      }

      if (shouldAutoplay(state)) {
        state.offset = wrap(state.offset + state.autoSpeed * dtSec, state.loopWidth);
      }

      if (!state.dragging && Math.abs(state.inertia) > 0.1) {
        state.offset = wrap(state.offset + state.inertia * dtSec, state.loopWidth);
        state.inertia *= Math.exp(-dtSec * 9);
      }

      render(state);
      return true;
    };

    const loop = createRafLoop((deltaMs) => {
      if (states.size === 0) {
        return false;
      }

      const dtSec = clamp(deltaMs / 1000, 0, 0.05);

      for (const [root, state] of states) {
        if (stepState(state, dtSec)) {
          continue;
        }
        state.cleanups.forEach((cleanup) => cleanup());
        states.delete(root);
      }

      return states.size > 0;
    });

    const startLoop = () => {
      if (states.size === 0) {
        return;
      }
      loop.start();
    };

    const stopLoop = () => {
      loop.stop();
    };

    const bindPointer = (state) => {
      const viewport = state.viewport;
      const onPointerDown = (event) => {
        if (!(event instanceof PointerEvent)) {
          return;
        }
        if (event.pointerType === 'mouse' && event.button !== 0) {
          return;
        }
        state.dragging = true;
        state.dragPointerId = event.pointerId;
        state.lastPointerX = event.clientX;
        state.lastPointerTs = performance.now();
        state.inertia = 0;
        viewport.dataset.dragging = 'true';
        viewport.setPointerCapture(event.pointerId);
      };

      const onPointerMove = (event) => {
        if (!(event instanceof PointerEvent)) {
          return;
        }
        if (!state.dragging || state.dragPointerId !== event.pointerId) {
          return;
        }
        const now = performance.now();
        const dx = event.clientX - state.lastPointerX;
        const dt = Math.max(1, now - state.lastPointerTs);
        state.offset = wrap(state.offset - dx, state.loopWidth);
        state.inertia = clamp((-dx / dt) * 1000, -720, 720);
        state.lastPointerX = event.clientX;
        state.lastPointerTs = now;
        render(state);
      };

      const finishDrag = (event) => {
        if (!(event instanceof PointerEvent)) {
          return;
        }
        if (!state.dragging || state.dragPointerId !== event.pointerId) {
          return;
        }
        state.dragging = false;
        state.dragPointerId = null;
        viewport.dataset.dragging = 'false';
        if (viewport.hasPointerCapture(event.pointerId)) {
          viewport.releasePointerCapture(event.pointerId);
        }
      };

      viewport.addEventListener('pointerdown', onPointerDown);
      viewport.addEventListener('pointermove', onPointerMove);
      viewport.addEventListener('pointerup', finishDrag);
      viewport.addEventListener('pointercancel', finishDrag);
      state.cleanups.push(() => viewport.removeEventListener('pointerdown', onPointerDown));
      state.cleanups.push(() => viewport.removeEventListener('pointermove', onPointerMove));
      state.cleanups.push(() => viewport.removeEventListener('pointerup', finishDrag));
      state.cleanups.push(() => viewport.removeEventListener('pointercancel', finishDrag));
    };

    const initSlider = (root) => {
      if (!(root instanceof HTMLElement)) {
        return;
      }
      if (root.dataset[initAttr] === 'true') {
        return;
      }

      const viewport = root;
      const track = root.querySelector('[data-temp-slider-track]');
      const count = readDataInt(root, 'tempSliderCount', 0);
      if (!(track instanceof HTMLElement) || !Number.isFinite(count) || count < 2) {
        return;
      }

      const items = Array.from(track.querySelectorAll('[data-temp-slider-item]')).filter((item) => item instanceof HTMLElement);
      if (items.length < count * 2) {
        return;
      }

      root.dataset[initAttr] = 'true';

      const state = {
        root,
        isHomeRoute: readDataBool(document.body, 'routeHome', false) && Boolean(root.closest('.home-hero-mobile')),
        viewport,
        track,
        items,
        baseCount: count,
        viewportWidth: viewport.clientWidth,
        itemWidth: 0,
        slot: 0,
        loopWidth: 0,
        totalWidth: 0,
        offset: 0,
        autoSpeed: 44,
        arcMaxDx: 0,
        arcSagitta: 20,
        arcRadius: 1,
        rotateCapDeg: 4.5,
        arcSoftEdgeRatio: 0.16,
        inertia: 0,
        inViewport: true,
        dragging: false,
        dragPointerId: null,
        lastPointerX: 0,
        lastPointerTs: 0,
        cleanups: [],
      };

      bindPointer(state);

      const onResize = () => {
        readMetrics(state);
        render(state);
      };

      window.addEventListener('resize', onResize);
      state.cleanups.push(() => window.removeEventListener('resize', onResize));

      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.target !== root) {
              continue;
            }
            state.inViewport = entry.isIntersecting && entry.intersectionRatio > 0.02;
          }
        },
        { threshold: [0, 0.02, 0.15] },
      );
      io.observe(root);
      state.cleanups.push(() => io.disconnect());

      const ro = new ResizeObserver(() => {
        onResize();
      });
      ro.observe(viewport);
      state.cleanups.push(() => ro.disconnect());

      states.set(root, state);
      readMetrics(state);
      render(state);
      startLoop();
    };

    const mount = () => {
      if (!adaptiveQuery.matches) {
        return;
      }
      document.querySelectorAll(sliderSelector).forEach((root) => {
        initSlider(root);
      });
      startLoop();
    };

    const onVisibilityChange = () => {
      if (!document.hidden) {
        startLoop();
      }
    };

    const onReducedMotionChange = () => {
      for (const state of states.values()) {
        if (reducedMotionQuery.matches) {
          state.inertia = 0;
        }
        render(state);
      }
      startLoop();
    };

    const onAdaptiveQueryChange = () => {
      if (adaptiveQuery.matches) {
        mount();
        return;
      }
      for (const [root, state] of states) {
        state.cleanups.forEach((cleanup) => cleanup());
        states.delete(root);
      }
      stopLoop();
    };

    lifecycle.on(document, 'visibilitychange', onVisibilityChange);
    lifecycle.onMediaQueryChange(reducedMotionQuery, onReducedMotionChange);
    lifecycle.onMediaQueryChange(adaptiveQuery, onAdaptiveQueryChange);
    lifecycle.addCleanup(onAstroPageLoad(mount));
    lifecycle.addCleanup(onDomReady(mount));

    const runtime = {
      mount,
      destroy() {
        for (const [root, state] of states) {
          state.cleanups.forEach((cleanup) => cleanup());
          states.delete(root);
        }
        stopLoop();
        lifecycle.dispose();
      },
    };

    const installedRuntime = getOrCreateWindowRuntime(runtimeKey, () => runtime);
    if (installedRuntime !== runtime) {
      runtime.destroy();
      installedRuntime?.mount?.();
      return;
    }

    mount();
  })();
</script>
