---
import Button from './Button.astro';
import AdaptivePhoneArcSlider from './AdaptivePhoneArcSlider.astro';
---

<section class="temporary-adaptive-notice" aria-labelledby="temporary-adaptive-title">
  <div
    class="temporary-adaptive-notice__content"
    data-temp-adaptive-content
    data-motion-inview="temporary-adaptive-stagger-v1"
  >
    <AdaptivePhoneArcSlider stageItem={true} motionStaggerIndex={0} />

    <div class="temporary-adaptive-notice__text">
      <h1
        id="temporary-adaptive-title"
        class="type-t4 temporary-adaptive-notice__title"
        data-temp-stage-item
        data-motion-stagger-index="1"
      >
        mobile version is coming soon
      </h1>
      <p class="type-body temporary-adaptive-notice__subtitle" data-temp-stage-item data-motion-stagger-index="2">
        To view the portfolio, please switch to desktop. If you’d like to chat or book a call, just send me a
        message
      </p>
      <div class="temporary-adaptive-notice__button-wrap" data-temp-stage-item data-motion-stagger-index="3">
        <Button href="https://linktr.ee/vladhorovyy" target="_blank">message me</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .temporary-adaptive-notice {
    width: 100%;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 24px 0;
    box-sizing: border-box;
  }

  .temporary-adaptive-notice__content {
    width: 100%;
    display: grid;
    justify-items: center;
    gap: 40px;
  }

  .temporary-adaptive-notice__text {
    width: min(390px, calc(100vw - 24px));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding-inline: 32px;
    box-sizing: border-box;
    text-align: center;
  }

  .temporary-adaptive-notice__title {
    margin: 0;
    max-width: 326px;
    color: var(--color-text-default);
    text-transform: lowercase;
  }

  .temporary-adaptive-notice__subtitle {
    margin: 0;
    max-width: 326px;
    color: var(--color-text-secondary);
  }

  .temporary-adaptive-notice__button-wrap {
    display: inline-flex;
  }

  @media (min-width: 768px) and (max-width: 1359px) {
    .temporary-adaptive-notice {
      padding: 48px 0;
    }

    .temporary-adaptive-notice__text {
      width: min(390px, calc(100vw - 64px));
    }
  }
</style>
